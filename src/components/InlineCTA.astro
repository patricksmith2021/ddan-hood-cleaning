---
import business from '../data/business.json';

interface Props {
  headline?: string;
}

const { headline = 'Get Your Kitchen Hood Cleaned Today!' } = Astro.props;
---

<div class="bg-[#111111] border-2 border-[#FF5E15] rounded-xl p-6 my-8 mx-5 max-w-[1200px] md:mx-auto overflow-hidden reveal">
  <div class="flex flex-col md:flex-row items-center gap-6">
    <div class="flex-1 text-center md:text-left">
      <h3 class="font-heading font-bold text-lg md:text-xl text-[#FF5E15] mb-3">{headline}</h3>
      <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2 text-white font-heading font-bold text-lg hover:text-[#FF5E15] transition-all duration-300">
        <svg class="w-5 h-5 text-[#FF5E15]" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
        Call Now: {business.phone}
      </a>
    </div>
    <div class="truck-drive-in">
      <img src="/images/truck.png" alt="DDAN Hood Cleaning truck" class="w-48 md:w-56" loading="lazy" />
    </div>
  </div>
</div>
