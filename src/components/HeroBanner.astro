---
interface Props {
  headline: string;
  breadcrumbs: Array<{ label: string; href?: string }>;
  subheadline?: string;
}

const { headline, breadcrumbs, subheadline } = Astro.props;
---

<section class="relative min-h-[250px] md:min-h-[350px] flex items-center overflow-hidden">
  <div class="absolute inset-0 bg-[#1A1A1A]"></div>
  <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.15) 0%, rgba(17,17,17,0.8) 70%);"></div>
  <div class="relative z-10 max-w-[1200px] mx-auto px-5 py-12 md:py-16 w-full">
    <h1 class="font-display text-white text-2xl md:text-4xl lg:text-[3rem] font-bold leading-[1.2] mb-3">{headline}</h1>
    {subheadline && <p class="font-heading text-sm md:text-base text-[#D4D4D4] max-w-2xl mb-4">{subheadline}</p>}
    <nav aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/70">
        {breadcrumbs.map((crumb, i) => (
          <>
            {i > 0 && <li class="text-[#FF5E15]">/</li>}
            <li>
              {crumb.href ? (
                <a href={crumb.href} class="hover:text-[#FF5E15] transition-all duration-300">{crumb.label}</a>
              ) : (
                <span class="text-white">{crumb.label}</span>
              )}
            </li>
          </>
        ))}
      </ol>
    </nav>
  </div>
</section>
