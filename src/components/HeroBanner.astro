---
interface Props {
  headline: string;
  breadcrumbs: Array<{ label: string; href?: string }>;
  subheadline?: string;
}

const { headline, breadcrumbs, subheadline } = Astro.props;
---

<section class="relative min-h-[300px] md:min-h-[350px] flex items-center overflow-hidden">
  <div class="absolute inset-0 bg-secondary"></div>
  <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.7) 70%);"></div>
  <div class="container-narrow relative z-10 py-16 text-white">
    <h1 class="font-display text-3xl md:text-4xl font-bold leading-tight mb-3">{headline}</h1>
    {subheadline && <p class="font-heading text-sm md:text-base text-body-text max-w-2xl mb-4">{subheadline}</p>}
    <nav aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
        {breadcrumbs.map((crumb, i) => (
          <>
            {i > 0 && <li class="text-primary">/</li>}
            <li>
              {crumb.href ? (
                <a href={crumb.href} class="hover:text-primary transition-colors">{crumb.label}</a>
              ) : (
                <span class="text-white">{crumb.label}</span>
              )}
            </li>
          </>
        ))}
      </ol>
    </nav>
  </div>
</section>
