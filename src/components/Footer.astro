            { label: 'Apple Maps', href: business.socialLinks.appleMaps, d: 'M384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0C267 435 384 279.4 384 192zM192 128a64 64 0 110 128 64 64 0 010-128z' },
            { label: 'Google', href: business.socialLinks.google, d: 'M488 261.8C488 403.3 391.1 504 248 504 110.8 504 0 393.2 0 256S110.8 8 248 8c66.8 0 123 24.5 166.3 64.9l-67.5 64.9C258.5 52.6 94.3 116.6 94.3 256c0 86.5 69.1 156.6 153.7 156.6 98.2 0 135-70.4 140.8-106.9H248v-85.3h236.1c2.3 12.7 3.9 24.9 3.9 41.4z' },
            { label: 'Yellow Pages', href: business.socialLinks.yellowPages, d: 'M64 0C28.7 0 0 28.7 0 64V448c0 35.3 28.7 64 64 64H320c35.3 0 64-28.7 64-64V160H256c-17.7 0-32-14.3-32-32V0H64zM256 0V128H384L256 0zM112 256H272c8.8 0 16 7.2 16 16s-7.2 16-16 16H112c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 64H272c8.8 0 16 7.2 16 16s-7.2 16-16 16H112c-8.8 0-16-7.2-16-16s7.2-16 16-16zm0 64H272c8.8 0 16 7.2 16 16s-7.2 16-16 16H112c-8.8 0-16-7.2-16-16s7.2-16 16-16z' },
          ].map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="w-11 h-11 flex items-center justify-center border-2 border-[#FF5E15] rounded-full bg-transparent hover:bg-[#FF5E15] group transition-all duration-300">
              <svg class="w-[18px] h-[18px] fill-[#FF5E15] group-hover:fill-white transition-all duration-300" viewBox="0 0 512 512"><path d={s.d} /></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- COL 2: Quick Links -->
      <div class="text-center md:text-left">
        <h3 class="text-[#FF5E15] font-heading font-bold text-2xl mb-2">Quick Links</h3>
        <div class="w-[60px] h-[3px] bg-[#FF5E15] mb-5"></div>
        <ul class="space-y-2.5">
          {[
            { label: 'Home', href: '/' },
            { label: 'About', href: '/about-ddan-hood-cleaning-and-repair/' },
            { label: 'Services', href: '/kitchen-exhaust-services-overview/' },
            { label: 'NFPA Standards', href: '/nfpa-code-96-standards/' },
            { label: 'How Your System Works', href: '/how-your-kitchen-ventilation-system-works/' },
            { label: 'Reviews', href: '/verified-reviews/' },
            { label: 'Gallery', href: '/gallery/' },
            { label: 'News', href: '/news/' },
            { label: 'Updates', href: '/news/' },
            { label: 'FAQs', href: '/kitchen-exhaust-faq/' },
            { label: 'Service Areas', href: '/cleaning/' },
            { label: 'Contact', href: '/contact/' },
          ].map((link) => (
            <li>
              <a href={link.href} class="flex items-center gap-2.5 text-lg text-[#E0E0E0] hover:text-[#FF5E15] transition-all duration-300 font-medium">
                <svg class="w-3.5 h-3.5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- COL 3: Our Services -->
      <div class="text-center md:text-left">
        <h3 class="text-[#FF5E15] font-heading font-bold text-2xl mb-2">Our Services</h3>
        <div class="w-[60px] h-[3px] bg-[#FF5E15] mb-5"></div>
        <ul class="space-y-2.5">
          {[
            { label: 'Hood Cleaning', href: '/cleaning/' },
            { label: 'Hood Repair', href: '/repair/' },
            { label: 'Parts & Installation', href: '/parts-installation/' },
            { label: 'Grease Containment', href: '/grease-containment/' },
            { label: 'Hinge Kit Installation', href: '/exhaust-fan-hinge-kit-installation/' },
            { label: 'Belt & Motor Repair', href: '/exhaust-fan-belt-motor-repair/' },
            { label: 'Access Panels', href: '/access-panel-installation/' },
            { label: 'Fire Suppression', href: '/restaurant-fire-suppression-systems/' },
          ].map((link) => (
            <li>
              <a href={link.href} class="flex items-center gap-2.5 text-lg text-[#E0E0E0] hover:text-[#FF5E15] transition-all duration-300 font-medium">
                <svg class="w-3.5 h-3.5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <!-- BBB Badge -->
        <a href={business.socialLinks.bbb} target="_blank" rel="noopener noreferrer" class="inline-block mt-6">
          <img src={`${HP}/images.png`} alt="BBB Accredited Business" width="225" height="225" class="w-[150px] object-contain rounded-xl" loading="lazy" />
        </a>
      </div>

      <!-- COL 4: Contact Us -->
      <div class="text-center md:text-left">
        <h3 class="text-[#FF5E15] font-heading font-bold text-2xl mb-2">Contact Us</h3>
        <div class="w-[60px] h-[3px] bg-[#FF5E15] mb-5"></div>
        <ul class="space-y-4 mb-6">
          <li class="flex items-center gap-3">
            <svg class="w-6 h-6 text-[#FF5E15] flex-shrink-0" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
            <a href={`tel:${business.phoneRaw}`} class="text-lg text-[#E0E0E0] hover:text-[#FF5E15] transition-all duration-300 font-semibold">{business.phone}</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-6 h-6 text-[#FF5E15] flex-shrink-0" fill="currentColor" viewBox="0 0 512 512"><path d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-48-48-48H48zM0 176V384c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V176L294.4 339.2c-22.8 17.1-54 17.1-76.8 0L0 176z"/></svg>
            <a href={`mailto:${business.email}`} class="text-lg text-[#E0E0E0] hover:text-[#FF5E15] transition-all duration-300 font-medium">{business.email}</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-6 h-6 text-[#FF5E15] flex-shrink-0" fill="currentColor" viewBox="0 0 384 512"><path d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 110 128 64 64 0 010-128z"/></svg>
            <a href={business.googleMapsUrl} target="_blank" rel="noopener" class="text-lg text-[#E0E0E0] hover:text-[#FF5E15] transition-all duration-300 font-medium">Entire Nashville Metro Area</a>
          </li>
        </ul>
        <!-- Google Maps Embed -->
        <div class="rounded-xl overflow-hidden mb-4 [&_iframe]:!h-[200px]" set:html={business.googleMapsEmbed} />
        <!-- Payment Logos -->
        <img src={`${HP}/fae176_59216dc7684e42b2818998b6e2bbec6cmv2.png`} alt="Accepted payment methods" width="910" height="510" class="w-full rounded-xl" loading="lazy" />
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-5 border-t border-[#222222]">
      <div class="flex flex-col md:flex-row items-center justify-between text-sm text-[#777777] gap-2">
        <p>DDAN &copy; {new Date().getFullYear()} All Rights Reserved.</p>
        <p class="flex items-center gap-3">
          <a href="/privacy-policy/" class="hover:text-[#FF5E15] transition-all duration-300">Terms &amp; Condition</a>
          <span class="text-[#444]">&bull;</span>
          <a href="/privacy-policy/" class="hover:text-[#FF5E15] transition-all duration-300">Privacy</a>
          <span class="text-[#444]">&bull;</span>
          <a href="/contact/" class="hover:text-[#FF5E15] transition-all duration-300">Support</a>
        </p>
      </div>
      <p class="text-center text-sm text-[#777777] mt-3">
        Built with Love by <a href="https://nashvillebusinessfoundry.com" target="_blank" rel="noopener" class="hover:text-[#FF5E15] transition-all duration-300">Nashville Business Foundry</a>
      </p>
    </div>
  </div>
</footer>
