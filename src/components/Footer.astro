---
import business from '../data/business.json';
const HP = '/images/homepage';
---

<!-- ========== FOOTER — INDUSTRIAL / BOLD / HIGH-CONTRAST ========== -->
<footer class="relative text-[#E0E0E0]" style="background:#080808;">
  <!-- Subtle grid texture overlay -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image:repeating-linear-gradient(0deg,transparent,transparent 39px,#FF5E15 39px,#FF5E15 40px),repeating-linear-gradient(90deg,transparent,transparent 39px,#FF5E15 39px,#FF5E15 40px);"></div>
  <div class="relative z-10 max-w-[1200px] mx-auto px-5 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

      <!-- COL 1: Brand -->
      <div class="text-center md:text-left">
        <a href="/">
          <img src="/images/logos/DDAN Hood Cleaning and Repair Logo Black BG.png" alt={business.name} width="280" height="280" class="w-56 mb-5 mx-auto md:mx-0" />
        </a>
        <a href={business.googleMapsUrl} target="_blank" rel="noopener" class="block text-base leading-relaxed text-[#E0E0E0] hover:text-[#FF5E15] transition-all duration-300 mb-6">
          Commercial Kitchen Exhaust System Experts: Cleaning, Repair, Installation &amp; Parts Sales in the Nashville Metro Area
        </a>
        <!-- Social Icons — Wireframe/outline style -->
        <div class="grid grid-cols-5 gap-3 mt-4 justify-items-center md:justify-items-start">
