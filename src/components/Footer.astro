---

<footer class="bg-dark-base text-body-text">
  <div class="container-narrow section-padding">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Column 1: Logo & About -->
      <div>
        <a href="/">
          <img src="/images/logos/ddan-logo-white.png" alt={business.name} width="120" height="120" class="w-24 mb-4" />
        </a>
        <p class="text-sm mb-4">{business.descriptions.short.split('.')[0]}.</p>
        <div class="flex flex-wrap gap-3 mt-4">
          {socialIcons.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 flex items-center justify-center bg-secondary rounded hover:bg-primary transition-colors"
              aria-label={social.name}
            >
              <svg class="w-4 h-4 fill-current" viewBox="0 0 512 512"><path d={social.icon} /></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="text-primary font-heading font-semibold text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-body-text hover:text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Our Services -->
      <div>
        <h3 class="text-primary font-heading font-semibold text-lg mb-4">Our Services</h3>
        <ul class="space-y-2">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-body-text hover:text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact Us -->
      <div>
        <h3 class="text-primary font-heading font-semibold text-lg mb-4">Contact Us</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
            <a href={`tel:${business.phoneRaw}`} class="hover:text-primary transition-colors">{business.phone}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 512 512"><path d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-48-48-48H48zM0 176V384c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V176L294.4 339.2c-22.8 17.1-54 17.1-76.8 0L0 176z"/></svg>
            <a href={`mailto:${business.email}`} class="hover:text-primary transition-colors">{business.email}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 384 512"><path d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 110 128 64 64 0 010-128z"/></svg>
            <span>{business.address.city}, {business.address.state} {business.address.zip}</span>
          </li>
        </ul>
        <div class="mt-4 flex flex-wrap gap-2">
          {business.credentials.map((cred: string) => (
            <span class="text-xs bg-secondary px-2 py-1 rounded text-body-text">{cred}</span>
          ))}
        </div>
        <!-- BBB Badge -->
        <a href={business.socialLinks.bbb} target="_blank" rel="noopener noreferrer" class="inline-block mt-4">
          <div class="bg-white text-dark-base px-3 py-2 rounded text-xs font-heading font-bold flex items-center gap-1">
            <span class="text-blue-700 text-lg font-bold">BBB</span>
            <span>Accredited</span>
          </div>
        </a>
      </div>
    </div>

    <!-- Payment Methods -->
    <div class="mt-10 pt-6 border-t border-border-subtle">
      <p class="text-xs text-muted-text mb-3 text-center">We Accept</p>
      <div class="flex flex-wrap justify-center gap-3 text-xs text-muted-text">
        {['Visa', 'Mastercard', 'Amex', 'Discover', 'PayPal', 'Venmo', 'Cash App', 'Zelle', 'Stripe'].map((method) => (
          <span class="bg-secondary px-3 py-1.5 rounded">{method}</span>
        ))}
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-6 border-t border-border-subtle text-center text-xs text-muted-text">
      <p>&copy; {new Date().getFullYear()} {business.name}. All rights reserved.</p>
      <p class="mt-2">
        Built with Love by <a href="https://nashvillebusinessfoundry.com" target="_blank" rel="noopener" class="hover:text-primary transition-colors">Nashville Business Foundry</a>
      </p>
    </div>
  </div>
</footer>
