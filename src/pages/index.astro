---

<BaseLayout
  title="Commercial Kitchen Hood Cleaning and Repair in Nashville, TN"
  description="Commercial kitchen hood cleaning and repair in Mt Juliet and the greater Nashville Metro. Full-service, NFPA 96 compliant, 24/7 emergency service."
>

<!-- ===================== SECTION 1: HERO SLIDESHOW ===================== -->
<section class="relative min-h-[90vh] md:min-h-[90vh] flex items-center justify-center overflow-hidden" id="hero">
  <div class="absolute inset-0 z-0">
    <div class="hero-slide absolute inset-0 opacity-100 transition-opacity duration-500 bg-cover bg-center" style={`background-image:url('${HP}/hero-slide-1.jpg')`}></div>
    <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-500 bg-cover bg-center" style={`background-image:url('${HP}/hero-slide-2.jpg')`}></div>
    <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-500 bg-cover bg-center" style={`background-image:url('${HP}/hero-slide-3.jpg')`}></div>
    <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-500 bg-cover bg-center" style={`background-image:url('${HP}/hero-slide-4.jpg')`}></div>
    <div class="absolute inset-0 bg-black/70"></div>
  </div>

  <div class="relative z-10 w-full max-w-[1280px] mx-auto px-5 py-12 flex flex-col items-center text-center gap-2.5">
    <!-- Company Name -->
    <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide animate-fadeInUp">DDAN Hood Cleaning and Repair</p>

    <!-- Desktop Animated H1 -->
    <h1 class="hidden md:block font-display text-white text-[4.4rem] leading-[1.3] font-semibold">
      Commercial Kitchen Exhaust <span id="typing-text" class="text-[#FF5E15]"></span><span id="typing-cursor" class="text-[#FF5E15]">|</span><br/> Installation &amp; Parts
    </h1>

    <!-- Mobile Static H2 -->
    <h2 class="md:hidden font-display text-white text-[2.1rem] leading-[1.5] font-semibold">
      Commercial Kitchen Exhaust Fan <span class="text-[#FF5E15]">Cleaning &amp; Repair</span>, Installation &amp; Parts
    </h2>

    <!-- Subtitle -->
    <p class="text-white font-body text-base md:text-lg font-bold text-center w-[70%] md:w-[70%] max-w-[1000px] mx-auto animate-fadeInUp" style="animation-delay:0.3s">
      Serving Mt. Juliet and the Nashville Metro | 24/7 Emergency Response
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col-reverse sm:flex-row items-center justify-center gap-3 mt-4 animate-fadeInUp" style="animation-delay:0.5s">
      <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-[1.2rem] font-medium rounded hover:bg-[#FF5E15] transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Call Us: {business.phone}
      </a>
      <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-[1.2rem] font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Get Service Today
      </button>
    </div>

    <!-- Trust Badges -->
    <div class="flex flex-wrap items-center justify-center gap-4 md:gap-6 mt-6 animate-fadeInUp" style="animation-delay:0.7s">
      {[
        { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
        { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
        { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
      ].map((badge) => (
        <div class="flex flex-col items-center gap-1 border border-[#FF5E15] rounded-2xl px-4 py-1">
          <img src={badge.img} alt="" class="h-6 md:h-7 object-contain" style={`width:${badge.w};max-width:140px`} loading="lazy" />
          <div class="flex gap-0.5">
            {Array(5).fill(0).map(() => <svg class="w-4 h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===================== SECTION 2: KEEP YOUR KITCHEN RUNNING ===================== -->
<section class="bg-black pt-16 pb-0 px-4 reveal">
  <div class="max-w-[1280px] mx-auto flex flex-col lg:flex-row gap-8 items-start justify-between">
    <div class="lg:w-[55%]">
      <h2 class="font-display text-[#FF5E15] text-[3rem] md:text-[3rem] font-semibold leading-[1.2] mb-4 reveal-child">Keep Your Commercial Kitchen Running Smoothly</h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-4 w-[93%] reveal-child">Welcome to DDAN Hood Cleaning and Repair — Middle Tennessee's trusted partner in commercial kitchen exhaust system care. We specialize in NFPA 96 compliant:</p>
      <ul class="space-y-2 mb-6 reveal-child">
        {['Restaurant Hood Cleaning','Restaurant Hood Repair','Full Kitchen Ventilation System Installation','Rooftop Grease Containment Solutions','Commercial Kitchen Exhaust Fan Part Sales'].map((item) => (
          <li class="flex items-center gap-2 text-white text-[15px] font-medium font-heading">
            <svg class="w-4 h-4 text-[#FF5E15] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            {item}
          </li>
        ))}
      </ul>
      <a href="/about-ddan-hood-cleaning-and-repair/" class="inline-flex items-center flex-row-reverse gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-base font-medium rounded hover:bg-[#FF5E15] transition-colors mt-2 reveal-child">
        Learn More About Us
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="lg:w-[45%] border-[3px] border-[#FF5E15] rounded-2xl p-5 flex items-center justify-center reveal-child">
      <img src={`${HP}/grease-hood-cleaning-near-me-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-768x1024.jpg`} alt="grease hood cleaning near me nashville tn - DDAN Hood Cleaning and Repair (615) 881-6968" class="w-full h-[400px] object-cover rounded-2xl" loading="lazy" />
    </div>
  </div>
</section>

<!-- ===================== SECTION 3: EXPERIENCE + SERVICES LIST ===================== -->
<section class="bg-black pt-8 pb-0 px-4 reveal">
  <div class="max-w-[1280px] mx-auto flex flex-col lg:flex-row gap-8 items-start justify-between">
    <div class="lg:w-[55%] order-2 lg:order-1">
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-4 reveal-child">Whether you need emergency exhaust fan repair, a complete hood system installation, or scheduled quarterly cleanings, DDAN's your one-stop shop for comprehensive kitchen exhaust system services.</p>
      <ul class="space-y-2 mb-6 reveal-child">
        {['Over 18 Years of Experience','Serving Restaurants, Churches, Schools, and more','Helping the Nashville area stay clean, operational, and inspection-ready','24/7 Emergency Repair Services','Rapid Overnight Cleans to Keep You 100% Operational'].map((item) => (
          <li class="flex items-center gap-2 text-white text-[15px] font-medium font-heading">
            <svg class="w-4 h-4 text-[#FF5E15] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            {item}
          </li>
        ))}
      </ul>
      <a href="/kitchen-exhaust-services-overview/" class="inline-flex items-center flex-row-reverse gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-base font-medium rounded hover:bg-[#FF5E15] transition-colors reveal-child">
        See Our Services
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="lg:w-[45%] order-1 lg:order-2 border-[3px] border-[#FF5E15] rounded-2xl p-5 flex items-center justify-center reveal-child">
      <img src={`${HP}/certified-hood-cleaning-company-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-1024x768.webp`} alt="certified hood cleaning company nashville tn - DDAN Hood Cleaning and Repair (615) 881-6968" class="w-full h-[400px] object-cover rounded-2xl" loading="lazy" />
    </div>
  </div>
</section>

<!-- ===================== SECTION 4: THREE PROCESS CARDS ===================== -->
<section class="bg-black pt-4 pb-16 px-4">
  <div class="max-w-[1280px] mx-auto flex flex-col md:flex-row flex-wrap gap-5 items-stretch justify-center reveal">
    {[
      { title: 'Free Inspection & Quote', desc: 'Get a 100% free, no-obligation estimate for businesses within 15 miles of Mt. Juliet.', bg: 'bg-[#032C5B]', mt: 'mt-[50px] md:mt-[50px]' },
      { title: 'Schedule Your Service', desc: 'We prioritize accommodating your business hours.', bg: 'bg-[#FF5E15]', mt: 'mt-0' },
      { title: 'Full Service & Comprehensive Report', desc: "Our certified team delivers complete, professional work \u2014 whether it's meticulous cleaning, expert repair, or precision installation.", bg: 'bg-[#032C5B]', mt: 'mt-[50px] md:mt-[50px]' },
    ].map((card) => (
      <div class={`${card.bg} ${card.mt} w-full md:w-[31%] lg:w-[31%] rounded-[25px] p-8 text-white hover:-translate-y-4 transition-transform duration-300 reveal-child`}>
        <h3 class="font-body text-[1.8rem] font-semibold leading-[1.2] mb-3">{card.title}</h3>
        <p class="text-white/90 text-lg">{card.desc}</p>
      </div>
    ))}
    <div class="w-full text-center mt-6">
      <button type="button" class="popup-trigger inline-flex items-center gap-2 px-[100px] py-5 bg-transparent text-white font-body text-[1.2rem] font-medium border-2 border-[#FF5E15] rounded-full hover:bg-[#FF5E15] transition-colors reveal-child">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Get Started
      </button>
    </div>
  </div>
</section>

<!-- ===================== SECTION 5: WHY CHOOSE DDAN ===================== -->
<section class="bg-black py-16 px-4 reveal">
  <div class="max-w-[1280px] mx-auto flex flex-col lg:flex-row gap-10 items-start">
    <div class="lg:w-[55%]">
      <h2 class="font-display text-[#FF5E15] text-[3rem] font-semibold leading-[1.2] mb-3 reveal-child">Why Choose DDAN Hood Cleaning and Repair?</h2>
      <h3 class="font-heading text-white text-xl md:text-2xl font-semibold leading-snug mb-4 reveal-child">We do more than just clean; we fix, install, and protect your commercial kitchen's most vital system.</h3>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-6 reveal-child">Unlike many "hood cleaners" who only provide surface-level work, DDAN offers end-to-end commercial kitchen exhaust system care. We meticulously clean every component to bare metal, expertly repair exhaust fan failures, professionally install new restaurant hood systems, and proactively solve ventilation problems before they can shut you down. Our work consistently meets and exceeds all health, fire, and safety standards, and every service is thoroughly documented with photos for your records.</p>
      <a href="/contact/" class="inline-flex items-center flex-row-reverse gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-base font-medium rounded hover:bg-[#FF5E15] transition-colors reveal-child">
        Get Service Today
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="lg:w-[45%] reveal-child">
      <img src={`${HP}/restaurant-hood-cleaning-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968.jpg`} alt="restaurant hood cleaning nashville tn - DDAN Hood Cleaning and Repair (615) 881-6968" class="w-full rounded-2xl" loading="lazy" />
    </div>
  </div>
</section>

<!-- ===================== SECTION 6: WHAT SETS DDAN APART ===================== -->
<section class="bg-black py-12 px-4 reveal">
  <div class="max-w-[1280px] mx-auto">
    <h4 class="text-[#FF5E15] font-heading text-[22px] font-medium capitalize leading-snug mb-6 reveal-child">What sets DDAN apart</h4>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {['Over 18 years of proven results','24-hour emergency service','Everything to NFPA 96 standards','Verified completion of every service','We are problem solvers, not invoice hunters','Fully licensed and insured for your peace of mind'].map((item) => (
        <div class="flex items-start gap-3 border border-[#FF5E15] rounded-2xl p-5 hover:border-white transition-colors reveal-child">
          <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center bg-[#FF5E15] rounded-lg">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          </div>
          <p class="text-white font-heading text-base font-medium">{item}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===================== SECTION 7: VERIFIED REVIEWS (Trustindex) ===================== -->
<section class="bg-black py-16 px-4 reveal">
  <div class="max-w-[1280px] mx-auto text-center">
    <h2 class="font-display text-[#FF5E15] text-[2.8rem] font-semibold leading-[1.2] mb-3 reveal-child">Verified Customer Reviews in Mid Tennessee</h2>
    <p class="text-[#DDDDDD] font-body text-base leading-relaxed max-w-3xl mx-auto mb-8 reveal-child">Read verified reviews from our happy customers from the past 19 years in service! From spotless results to reliable fixes, our clients trust us for quality work, on-time service, and long-lasting solutions. Your satisfaction is our priority.</p>
    <div class="bg-[#DDDDDD] rounded-2xl p-5 w-[90%] mx-auto mb-6 reveal-child" style="--overlay-opacity:0.6">
      <div id="trustindex-widget">
        <script is:inline type="text/javascript" src="https://cdn.trustindex.io/loader.js?wp-widget" defer></script>
      </div>
    </div>
    <a href={business.googleReviewUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-7 py-3 bg-[#FF5E15] text-white font-heading text-lg font-medium rounded hover:bg-[#032C5B] transition-colors reveal-child">
