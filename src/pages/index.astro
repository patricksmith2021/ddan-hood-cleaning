---
import BaseLayout from '../layouts/BaseLayout.astro';
import business from '../data/business.json';

const HP = '/images/homepage';

const services = [
  { title: 'Hood Cleaning', img: `${HP}/vent-hood-cleaning-service-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-1024x576.jpg`, alt: 'vent hood cleaning service nashville tn - DDAN Hood Cleaning and Repair (615) 881-6968', desc: 'Our NFPA 96 compliant exhaust hood cleaning service is thorough and efficient — designed for hood cleaning for health inspection compliance, fire marshal approval, and insurance requirements. Our process includes:', href: '/cleaning/', bg: 'bg-[#FF5E15]', btnBg: 'bg-[#032C5B]' },
  { title: 'Exhaust Fan Repair & Replacement', img: `${HP}/NFPA-96-hood-repair-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-1024x768.jpg`, alt: 'Exhaust fan repair and replacement Nashville TN - DDAN Hood Cleaning and Repair (615) 881-6968', desc: 'Burned-out motors, seized bearings, worn belts, failed fans — we diagnose and fix it the same day. Full fan replacements with proper sizing, wiring, and hinge kits included.', href: '/fan-repair/', bg: 'bg-[#032C5B]', btnBg: 'bg-[#FF5E15]' },
  { title: 'Hood System Installation', img: `${HP}/exhaust-hood-system-repair-services-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968.jpg`, alt: 'Commercial kitchen exhaust hood system installation Nashville TN - DDAN Hood Cleaning and Repair (615) 881-6968', desc: 'Turnkey kitchen exhaust installation — hoods, ductwork, fans, make-up air, and fire suppression coordination. Permitted, installed, and inspected. New builds and retrofits.', href: '/fan-hood-installation/', bg: 'bg-[#FF5E15]', btnBg: 'bg-[#032C5B]' },
  { title: 'Grease Containment', img: `${HP}/NFPA-96-hood-cleaning-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-1024x768.webp`, alt: 'NFPA 96 hood cleaning nashville tn - DDAN Hood Cleaning and Repair (615) 881-6968', desc: 'Rooftop grease management protects your roof and keeps you code-compliant.', href: '/grease-containment/', bg: 'bg-[#032C5B]', btnBg: 'bg-[#FF5E15]' },
  { title: 'Parts & Equipment', img: `${HP}/certified-hood-cleaning-company-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-1024x768.webp`, alt: 'Commercial kitchen exhaust fan parts Nashville TN - DDAN Hood Cleaning and Repair (615) 881-6968', desc: 'Motors, belts, fans, filters, hinge kits, grease containment, and make-up air units — in stock or next-day sourced. Professional installation available.', href: '/parts-installation/', bg: 'bg-[#FF5E15]', btnBg: 'bg-[#032C5B]' },
  { title: 'Exhaust Fan Hinge Kit Installation', img: `${HP}/DDAN-Hood-Cleaning-and-Repair-615-881-6968-768x1024.jpg`, alt: 'vent hood cleaning service Nashville, TN - DDAN Hood Cleaning and Repair', desc: 'Hinge kits are required for proper fan cleaning and inspection.', href: '/exhaust-fan-hinge-kit-installation/', bg: 'bg-[#032C5B]', btnBg: 'bg-[#FF5E15]' },
  { title: 'Exhaust Fan Belt & Motor Repair', img: `${HP}/grease-hood-system-repair-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-1024x768.jpg`, alt: 'grease hood system repair nashville tn - DDAN Hood Cleaning and Repair (615) 881-6968', desc: "If your fan is noisy, slow, or non-functional, we'll get it back in shape fast.", href: '/exhaust-fan-belt-motor-repair/', bg: 'bg-[#FF5E15]', btnBg: 'bg-[#032C5B]' },
  { title: 'Access Panel Installation', img: `${HP}/exhaust-fan-hinge-kit-installation-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968.webp`, alt: 'exhaust fan hinge kit installation nashville tn - DDAN Hood Cleaning and Repair (615) 881-6968', desc: 'Duct access panels are required for proper cleaning and inspection.', href: '/access-panel-installation/', bg: 'bg-[#032C5B]', btnBg: 'bg-[#FF5E15]' },
  { title: 'Restaurant Fire Suppression Systems', img: `${HP}/restaurant-fire-suppression-system-installation-Nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-1024x683.jpg`, alt: 'restaurant-fire-suppression-system-installation-Nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968', desc: 'We install and integrate UL 300-compliant fire suppression systems as part of your overall commercial kitchen ventilation.', href: '/restaurant-fire-suppression-systems/', bg: 'bg-[#FF5E15]', btnBg: 'bg-[#032C5B]' },
];

const areas = [
  { city: 'Mt. Juliet, TN', zips: '37122, 37121', slug: 'mount-juliet-tn' },
  { city: 'Lebanon, TN', zips: '37087, 37090', slug: 'lebanon-tn' },
  { city: 'Smyrna, TN', zips: '37167', slug: 'smyrna-tn' },
  { city: 'Gallatin, TN', zips: '37066', slug: 'gallatin-tn' },
  { city: 'La Vergne, TN', zips: '37086', slug: 'la-vergne-tn' },
  { city: 'Goodlettsville, TN', zips: '37072', slug: 'goodlettsville-tn' },
  { city: 'Hendersonville, TN', zips: '37075, 37077', slug: 'hendersonville-tn' },
  { city: 'Nashville, TN', zips: '37201-37221, 37228-37250', slug: 'nashville-tn' },
  { city: 'Brentwood, TN', zips: '37027, 37024', slug: 'brentwood-tn' },
  { city: 'Franklin, TN', zips: '37064, 37067, 37069, 37065, 37068, 37027', slug: 'franklin-tn', vertical: 'fan-repair' },
  { city: 'Murfreesboro, TN', zips: '37127, 37128, 37129, 37130', slug: 'murfreesboro-tn' },
  { city: 'Bellevue, TN', zips: '37221, 37209, 37143', slug: 'nashville-tn', vertical: 'cleaning' },
];

const faqs = [
  { q: 'How often do I need my commercial kitchen hood cleaned?', a: 'Most high-volume commercial kitchens, especially restaurants, require cleaning <strong>every 3 months (quarterly)</strong> to stay code-compliant with <strong>NFPA 96</strong> and fire-safe. Some lower-use facilities can extend to 6 months, but we consistently recommend quarterly service for optimal safety and compliance.' },
  { q: 'Do you service all types of commercial kitchens, including restaurants, churches, and schools?', a: 'Yes! We specialize in and proudly serve commercial kitchens of all types, including quick-service restaurants, full-service restaurants, church kitchens, school cafeterias, hotel kitchens, and commissaries.' },
  { q: 'What if something is found broken or damaged during a cleaning service?', a: "Transparency is key. We'll immediately show you the issue, document it thoroughly in our service report, and provide you with clear, no-pressure options for repair or replacement before proceeding." },
  { q: 'Do you provide compliance certificates?', a: 'While Tennessee itself may not always mandate formal "hood cleaning certificates," we clean all systems to the <strong>full NFPA 96 standards</strong> and provide <strong>comprehensive detailed reports</strong> that consistently satisfy local fire marshals, health inspectors, and insurance requirements.' },
  { q: 'How quickly can I get service, especially for an emergency?', a: 'For <strong>emergencies</strong>, we offer <strong>24/7 same-day response</strong> to get your kitchen back online as quickly as possible. For scheduled work, we typically book appointments within 1\u20133 business days, often accommodating urgent requests.' },
  { q: 'Do you handle everything, or do I need multiple contractors for cleaning, repair, and installation?', a: "DDAN is your <strong>all-in-one solution</strong>. We expertly handle <strong>cleaning, repairs, installation, and parts sales</strong> for commercial kitchen exhaust systems. You'll only deal with one trusted, professional team \u2013 no subcontractors, no delays, and consistent quality across all services." },
];

const galleryImgs = [
  `${HP}/gallery-1.jpg`,
  `${HP}/119280791_180137593554824_8912214928319172354_n.jpg`,
  `${HP}/461794000_1271556883906009_7916879387880277431_n.jpg`,
  `${HP}/469778380_1098682555033652_455391933703696342_n.jpg`,
  `${HP}/469797908_1098664541702120_287504172955796308_n.jpg`,
  `${HP}/469805687_1098682605033647_3324071844564978738_n.jpg`,
  `${HP}/484228403_1393752375019792_506057596076959451_n-e1752434231691.jpg`,
  `${HP}/484303716_1393752738353089_8141754902918181360_n-e1752434270970-768x725.jpg`,
  `${HP}/gallery-9.jpg`,
  `${HP}/gallery-10.jpg`,
  `${HP}/gallery-11.jpg`,
  `${HP}/494512892_1437622623966100_4044307143311864352_n.jpg`,
];

const mapCities = [
  { city: 'Mt Juliet TN', zips: '37121, 37122, 37138' },
  { city: 'Nashville TN', zips: '37201\u201337250' },
  { city: 'Hendersonville TN', zips: '37066, 37075, 37077' },
  { city: 'Goodlettsville TN', zips: '37070, 37072' },
  { city: 'Lebanon TN', zips: '37087, 37088, 37090' },
  { city: 'La Vergne TN', zips: '37086, 37089' },
  { city: 'Smyrna TN', zips: '37086, 37129, 37167' },
];

const siteUrl = import.meta.env.SITE || 'https://ddanhoodservices.com';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${siteUrl}/`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": business.address.city,
        "addressRegion": business.address.state,
        "postalCode": business.address.zip,
        "addressCountry": "US"
      },
      "areaServed": { "@type": "State", "name": "Tennessee" },
      "priceRange": "$$"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` }
      ]
    }
  ]
};
---

<BaseLayout
  title="Kitchen Exhaust Cleaning & Repair | DDAN Hood Services"
  description="DDAN Hood Cleaning serves Middle Tennessee. NFPA 96 hood cleaning, 24/7 exhaust fan repair, and commercial kitchen parts. (615) 881-6968"
>
<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

<!-- ===================== SECTION 1: HERO SLIDESHOW ===================== -->
<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden" id="hero">
  <div class="absolute inset-0 z-0">
    <div class="hero-slide absolute inset-0 opacity-100 transition-opacity duration-500 bg-cover bg-center" style="background-image:url('/images/homepage-hero/kitchen-exhaust-cleaning-services-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968.jpg')"></div>
    <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-500 bg-cover bg-center" style="background-image:url('/images/homepage-hero/vent-hood-cleaning-service-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968.jpg')"></div>
    <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-500 bg-cover bg-center" style="background-image:url('/images/homepage-hero/restaurant-hood-fan-repair-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968.jpg')"></div>
    <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-500 bg-cover bg-center" style="background-image:url('/images/homepage-hero/kitchen-hood-motor-repair-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968.jpg')"></div>
    <div class="absolute inset-0 bg-black/70"></div>
  </div>
  <div class="relative z-10 w-full max-w-[1280px] mx-auto px-5 py-12 flex flex-col items-center text-center gap-2.5">
    <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide animate-fadeInUp">DDAN Hood Cleaning and Repair</p>
    <h1 class="hidden md:block font-display text-white text-2xl md:text-[4.4rem] leading-[1.3] font-semibold">
      Commercial Kitchen Exhaust <span id="typing-text" class="text-[#FF5E15]"></span><span id="typing-cursor" class="text-[#FF5E15]">|</span><br/> Installation &amp; Parts
    </h1>
    <h2 class="md:hidden font-display text-white text-3xl leading-[1.3] font-bold">
      Commercial Kitchen Exhaust Fan <span class="text-[#FF5E15]">Cleaning &amp; Repair</span>, Installation &amp; Parts
    </h2>
    <p class="text-white font-body text-base md:text-lg font-bold text-center w-full md:w-[70%] max-w-[1000px] mx-auto animate-fadeInUp" style="animation-delay:0.3s">
      Serving Mt. Juliet and the Nashville Metro | 24/7 Emergency Response
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mt-4 animate-fadeInUp w-full sm:w-auto" style="animation-delay:0.5s">
      <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-[1.2rem] font-medium rounded hover:bg-[#FF5E15] transition-all duration-300 w-full sm:w-auto">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Call Us: {business.phone}
      </a>
      <button type="button" class="popup-trigger inline-flex items-center justify-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-[1.2rem] font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300 w-full sm:w-auto">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
