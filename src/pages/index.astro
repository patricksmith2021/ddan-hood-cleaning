      </button>
    </div>
    <div class="flex flex-row items-center justify-center gap-3 md:gap-10 mt-6 md:mt-8 animate-fadeInUp" style="animation-delay:0.7s">
      {[
        { img: `${HP}/google-white-logo-1024x337.png`, w: '70%', alt: 'Google Reviews - 5 Stars' },
        { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%', alt: 'Facebook Reviews - 5 Stars' },
        { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%', alt: 'Yelp Reviews - 5 Stars' },
      ].map((badge) => (
        <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-6 md:py-2.5">
          <img src={badge.img} alt={badge.alt} class="h-5 md:h-11 object-contain" style={`width:${badge.w};max-width:220px`} loading="lazy" />
          <div class="flex gap-0.5 md:gap-1">
            {Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-6 md:h-6 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===================== SECTION 2: KEEP YOUR KITCHEN RUNNING ===================== -->
<!-- CHANGE 2: Increased padding py-16 md:py-20 -->
<section class="bg-black py-10 md:py-16 lg:py-20 px-5 reveal">
  <div class="max-w-[1280px] mx-auto flex flex-col lg:flex-row gap-10 items-start justify-between">
    <div class="lg:w-[55%]">
      <h2 class="font-heading text-[#FF5E15] text-xl md:text-[3rem] font-semibold leading-[1.2] mb-4 text-center md:text-left reveal-child">Keep Your Commercial Kitchen Running Smoothly</h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-4 w-full md:w-[93%] reveal-child">Welcome to DDAN Hood Cleaning and Repair — Middle Tennessee's trusted partner in commercial kitchen exhaust system care. We specialize in NFPA 96 compliant:</p>
      <ul class="space-y-2 mb-6 reveal-child">
        {['Restaurant Hood Cleaning','Restaurant Hood Repair','Full Kitchen Ventilation System Installation','Rooftop Grease Containment Solutions','Commercial Kitchen Exhaust Fan Part Sales'].map((item) => (
          <li class="flex items-center gap-2 text-white text-[15px] font-medium font-heading">
            <svg class="flex-shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="1" y="1" width="22" height="22" rx="4" stroke="#FF5E15" stroke-width="2" fill="none"/><path d="M7 12.5l3 3 7-7" stroke="#FF5E15" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            {item}
          </li>
        ))}
      </ul>
      <a href="/about-ddan-hood-cleaning-and-repair/" class="inline-flex items-center flex-row-reverse gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-base font-medium rounded hover:bg-[#FF5E15] transition-all duration-300 mt-2 reveal-child">
        Learn More About Us
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="lg:w-[45%] border-[3px] border-[#FF5E15] rounded-2xl p-5 flex items-center justify-center mb-6 lg:mb-0 reveal-child">
      <img src={`${HP}/grease-hood-cleaning-near-me-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-768x1024.jpg`} alt="grease hood cleaning near me nashville tn" width="768" height="1024" class="w-full h-[400px] object-cover rounded-2xl" loading="lazy" />
    </div>
  </div>
</section>

<!-- ===================== SECTION 3: EXPERIENCE + SERVICES LIST ===================== -->
<section class="bg-black py-10 md:py-16 lg:py-20 px-5 reveal">
  <div class="max-w-[1280px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <div class="border-[3px] border-[#FF5E15] rounded-2xl p-5 flex items-center justify-center reveal-child">
      <img src={`${HP}/certified-hood-cleaning-company-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-1024x768.webp`} alt="certified hood cleaning company nashville tn" width="1024" height="768" class="w-full max-h-[500px] object-cover rounded-2xl" loading="lazy" />
    </div>
    <div>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-4 reveal-child">Whether you need emergency exhaust fan repair, a complete hood system installation, or scheduled quarterly cleanings, DDAN's your one-stop shop for comprehensive kitchen exhaust system services.</p>
      <ul class="space-y-2 mb-6 reveal-child">
        {['Over 20 Years of Experience','Serving Restaurants, Churches, Schools, and more','Helping the Nashville area stay clean, operational, and inspection-ready','24/7 Emergency Repair Services','Rapid Overnight Cleans to Keep You 100% Operational'].map((item) => (
          <li class="flex items-center gap-2 text-white text-[15px] font-medium font-heading">
            <svg class="flex-shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="1" y="1" width="22" height="22" rx="4" stroke="#FF5E15" stroke-width="2" fill="none"/><path d="M7 12.5l3 3 7-7" stroke="#FF5E15" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            {item}
          </li>
        ))}
      </ul>
      <a href="/kitchen-exhaust-services-overview/" class="inline-flex items-center flex-row-reverse gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-base font-medium rounded hover:bg-[#FF5E15] transition-all duration-300 reveal-child">
        See Our Services
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- ===================== SECTION 4: THREE PROCESS CARDS ===================== -->
<section class="bg-black py-10 md:py-16 lg:py-20 px-5">
  <div class="max-w-[1280px] mx-auto reveal">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6 mt-8">
      {[
        { num: '01', title: 'Free Inspection & Quote', desc: 'Get a 100% free, no-obligation estimate for businesses within 15 miles of Mt. Juliet.', cta: 'Free Quote' },
        { num: '02', title: 'Get Scheduled Right Away', desc: 'We prioritize accommodating your business hours.', cta: 'Get Schedule' },
        { num: '03', title: 'Satisfaction Guaranteed', desc: "Our certified team delivers complete, professional work \u2014 whether it's meticulous cleaning, expert repair, or precision installation.", cta: 'Get Report' },
      ].map((card) => (
        <div class="relative bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl pt-12 pb-6 px-6 flex flex-col min-h-[240px] hover:border-white hover:-translate-y-2 transition-all duration-300 reveal-child">
          <span class="absolute -top-6 left-1/2 -translate-x-1/2 w-[50px] h-[50px] bg-[#FF5E15] rounded-lg flex items-center justify-center text-white font-heading font-bold text-2xl shadow-lg">{card.num}</span>
          <h3 class="font-heading text-[#FF5E15] text-xl font-bold mb-3 text-center md:text-left">{card.title}</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 flex-grow text-center md:text-left">{card.desc}</p>
