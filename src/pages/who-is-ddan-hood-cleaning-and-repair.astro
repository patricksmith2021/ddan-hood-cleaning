---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import business from '../data/business.json';

const title = "Who Is DDAN Hood Cleaning & Repair?";
const description = "DDAN Hood Cleaning & Repair is a professional commercial kitchen exhaust service company based in Mt. Juliet, Tennessee serving Middle Tennessee.";
const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Who Is DDAN?" }
];
---

<BaseLayout title={title} description={description}>
  <HeroBanner title={title} breadcrumbs={breadcrumbs} />

  <section class="bg-dark-base section-padding">
    <div class="container-narrow reveal">
      <p class="text-body-text leading-relaxed">
        DDAN Hood Cleaning &amp; Repair is a professional commercial kitchen exhaust service company based in Mt. Juliet, Tennessee, serving Nashville, Mt. Juliet, Goodlettsville, Hendersonville, La Vergne, Smyrna, Murfreesboro, Brentwood, Franklin, Bellevue, and the surrounding Middle Tennessee region. We provide NFPA 96-compliant hood cleaning, repair, installation, and full exhaust system care to keep commercial kitchens safe, efficient, and always inspection-ready.
      </p>
    </div>
  </section>

  <section class="bg-dark-base section-padding">
    <div class="container-narrow reveal">
      <h2 class="text-primary font-heading text-section-headline font-semibold mb-6">Our Purpose</h2>
      <p class="text-body-text leading-relaxed">
        DDAN exists to protect Middle Tennessee's kitchens from fire hazards, grease buildup, and equipment failure. Our mission is to deliver dependable, documented, NFPA 96-compliant service to facilities across the region. Every service visit includes full photographic documentation for compliance, insurance, and inspection records.
      </p>
    </div>
  </section>

  <section class="bg-dark-base section-padding">
    <div class="container-narrow reveal">
      <h2 class="text-primary font-heading text-section-headline font-semibold mb-6">Who We Serve</h2>
      <p class="text-body-text leading-relaxed">
        We work with restaurants, food trucks, churches, schools, bars, hotels, commissaries, and corporate kitchens. Businesses throughout Middle Tennessee rely on DDAN for hood and duct cleaning, exhaust fan repair, hinge kit installation, belt and motor replacement, grease containment, access panels, fire suppression systems, and full ventilation upgrades.
      </p>
    </div>
  </section>

  <section class="bg-dark-base section-padding">
    <div class="container-narrow reveal">
      <h2 class="text-primary font-heading text-section-headline font-semibold mb-6">How We Provide Kitchen Exhaust Services</h2>
      <p class="text-body-text leading-relaxed">
        All services are delivered by trained technicians following NFPA 96 standards. We service, repair, clean, and maintain the entire kitchen exhaust system — hoods, ducts, fans, filters, access panels, grease containment, makeup air units, and fire suppression equipment. Every job is documented with before-and-after pictures, and we provide 24/7 emergency service.
      </p>
    </div>
  </section>

  <section class="bg-dark-base section-padding">
    <div class="container-narrow reveal">
      <h2 class="text-primary font-heading text-section-headline font-semibold mb-6">Where We Serve Clients</h2>
      <p class="text-body-text leading-relaxed">
        DDAN Hood Cleaning &amp; Repair is headquartered in Mt. Juliet and proudly serves Nashville, Mt. Juliet, Goodlettsville, Hendersonville, La Vergne, Smyrna, Murfreesboro, Brentwood, Franklin, Bellevue, and surrounding Middle Tennessee. If your facility has a commercial kitchen exhaust system anywhere in Middle Tennessee, DDAN can clean it, repair it, install it, maintain it, and bring it into NFPA 96 compliance.
      </p>
    </div>
  </section>

  <section class="bg-dark-base section-padding">
    <div class="container-narrow text-center reveal">
      <a href={`tel:${business.phoneRaw}`} class="btn-primary mb-4">
        Call Us: {business.phone}
      </a>
      <br/><br/>
      <button type="button" class="btn-ghost popup-trigger">
        Request Service Online
      </button>
    </div>
  </section>
</BaseLayout>
