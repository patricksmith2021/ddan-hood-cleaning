---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import business from '../data/business.json';

const title = "Who Is DDAN Hood Services?";
const description = "DDAN Hood Services is a professional commercial kitchen exhaust service company based in Mt. Juliet, Tennessee serving Middle Tennessee.";
const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Who Is DDAN?" }
];

const siteUrl = import.meta.env.SITE || 'https://ddanhoodservices.com';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${siteUrl}/who-is-ddan-hood-cleaning-and-repair/`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": business.address.city,
        "addressRegion": business.address.state,
        "postalCode": business.address.zip,
        "addressCountry": "US"
      },
      "areaServed": { "@type": "State", "name": "Tennessee" },
      "priceRange": "$$",
      "openingHours": "Mo-Su 00:00-23:59",
      "description": "Commercial kitchen exhaust cleaning, fan repair, installation, and parts for restaurants across Middle Tennessee. Licensed, bonded, insured. NFPA 96 compliant since 2006.",
      "hasCredential": [{"@type": "EducationalOccupationalCredential","credentialCategory": "Professional Certification","name": "NFPA 96 Compliant","recognizedBy": {"@type": "Organization","name": "National Fire Protection Association"}}]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "Who is DDAN Hood Services?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "DDAN Hood Services is a professional commercial kitchen exhaust service company based in Mt. Juliet, Tennessee, serving Nashville and 27 cities across Middle Tennessee. Founded in 2007 as a Christian, family-owned business, DDAN provides NFPA 96 compliant hood cleaning, exhaust fan repair, parts sales, and full system installation. Licensed, bonded, insured. Se Habla Español. Phone: (615) 881-6968."
        }
      }]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Who Is DDAN?" }
      ]
    }
  ]
};
---

<BaseLayout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <HeroBanner headline={title} breadcrumbs={breadcrumbs} />

  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="container-narrow reveal">
      <p class="text-body-text leading-relaxed">
        DDAN Hood Services &amp; Repair is a professional commercial kitchen exhaust service company based in Mt. Juliet, Tennessee, serving Nashville, Mt. Juliet, Goodlettsville, Hendersonville, La Vergne, Smyrna, Murfreesboro, Brentwood, Franklin, Bellevue, and the surrounding Middle Tennessee region. We provide NFPA 96-compliant hood cleaning, repair, installation, and full exhaust system care to keep commercial kitchens safe, efficient, and always inspection-ready.
      </p>
    </div>
  </section>

  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="container-narrow reveal">
      <h2 class="text-primary font-heading text-section-headline font-semibold mb-6">Our Purpose</h2>
      <p class="text-body-text leading-relaxed">
        DDAN exists to protect Middle Tennessee's kitchens from fire hazards, grease buildup, and equipment failure. Our mission is to deliver dependable, documented, NFPA 96-compliant service to facilities across the region. Every service visit includes thorough written documentation for compliance, insurance, and inspection records.
      </p>
    </div>
  </section>

  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="container-narrow reveal">
      <h2 class="text-primary font-heading text-section-headline font-semibold mb-6">Who We Serve</h2>
      <p class="text-body-text leading-relaxed">
        We work with restaurants, food trucks, churches, schools, bars, hotels, commissaries, and corporate kitchens. Businesses throughout Middle Tennessee rely on DDAN for hood and duct cleaning, exhaust fan repair, hinge kit installation, belt and motor replacement, grease containment, access panels, fire suppression systems, and full ventilation upgrades.
      </p>
    </div>
  </section>

  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="container-narrow reveal">
      <h2 class="text-primary font-heading text-section-headline font-semibold mb-6">How We Provide Kitchen Exhaust Services</h2>
      <p class="text-body-text leading-relaxed">
        All services are delivered by trained technicians following NFPA 96 standards. We service, repair, clean, and maintain the entire kitchen exhaust system — hoods, ducts, fans, filters, access panels, grease containment, makeup air units, and fire suppression equipment. Every job is fully documented with detailed service reports, and we provide 24/7 emergency service.
      </p>
    </div>
  </section>

  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="container-narrow reveal">
      <h2 class="text-primary font-heading text-section-headline font-semibold mb-6">Where We Serve Clients</h2>
      <p class="text-body-text leading-relaxed">
        DDAN Hood Services &amp; Repair is headquartered in Mt. Juliet and proudly serves Nashville, Mt. Juliet, Goodlettsville, Hendersonville, La Vergne, Smyrna, Murfreesboro, Brentwood, Franklin, Bellevue, and surrounding Middle Tennessee. If your facility has a commercial kitchen exhaust system anywhere in Middle Tennessee, DDAN can clean it, repair it, install it, maintain it, and bring it into NFPA 96 compliance.
      </p>
    </div>
  </section>

  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="container-narrow text-center reveal">
      <a href={`tel:${business.phoneRaw}`} class="btn-primary mb-4">
        Call Us: {business.phone}
      </a>
      <br/><br/>
      <button type="button" class="btn-ghost popup-trigger">
        Request Service Online
      </button>
    </div>
  </section>
</BaseLayout>
