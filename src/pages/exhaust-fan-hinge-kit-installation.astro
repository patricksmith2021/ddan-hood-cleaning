---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import InlineCTA from '../components/InlineCTA.astro';
import ServiceAreaGrid from '../components/ServiceAreaGrid.astro';
import TruckCTA from '../components/TruckCTA.astro';
---

<BaseLayout
  title="Exhaust Fan Hinge Kit Installation | DDAN Hood Cleaning"
  description="Install NFPA 96-compliant exhaust fan hinge kits for safe rooftop access and cleaning. Protect your fans and meet code. We install in one visit."
>
  <HeroBanner
    headline="Exhaust Fan Hinge Kit Installation"
    backgroundImage="/images/services/hinge-kit-hero.jpg"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Exhaust Fan Hinge Kit Installation' },
    ]}
  />

  <!-- Code-Compliant intro + What Happens Without a Proper Hinge -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <p class="font-heading font-semibold text-lg text-white mb-4 reveal-child">Code-Compliant. Easy to Clean. Built for Safety.</p>
      <h2 class="section-headline reveal-child">What Happens Without a Proper Exhaust Fan Hinge</h2>
      <p class="text-[#D4D4D4] mb-4 reveal-child">If your rooftop exhaust fan isn't mounted on a hinge, you're setting yourself up for problems. A non-hinged fan makes cleaning dangerous, damages your wiring, and can lead to costly fines or fire hazards. NFPA 96 requires all upblast exhaust fans to be hinged — and for good reason.</p>
      <p class="text-[#D4D4D4] mb-6 reveal-child">At DDAN Hood Cleaning and Repair, we install heavy-duty, NFPA 96-compliant hinge kits that allow your fan to open safely for cleaning and maintenance. Our hinge installs are secure, rust-resistant, and built to last under real commercial kitchen conditions.</p>
    </div>
  </section>

  <!-- What a Proper Hinge Kit Does -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="section-headline reveal-child">What a Proper Hinge Kit Does</h2>
      <ul class="space-y-2 mb-6">
        <li class="check-item reveal-child">Allows rooftop exhaust fans to tilt open for interior cleaning access</li>
        <li class="check-item reveal-child">Protects electrical wiring from stretching or tearing during service</li>
        <li class="check-item reveal-child">Prevents water and grease from leaking into your ductwork</li>
        <li class="check-item reveal-child">Reduces risk of injury during cleaning or maintenance</li>
        <li class="check-item reveal-child">Satisfies NFPA 96 and local fire code requirements</li>
      </ul>
      <p class="text-[#D4D4D4] mb-6 reveal-child">Not sure if your fan has a hinge? If it lifts straight off or is bolted down, it probably doesn't.</p>
    </div>
  </section>

  <!-- Installation Services + Common Issues -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Exhaust Fan Hinge Kit Installation Services</h3>
      <ul class="space-y-2 mb-6">
        <li class="check-item reveal-child">Includes brackets, pins, hardware, and sealing materials</li>
        <li class="check-item reveal-child">Mounting on curb or stack bases depending on fan type</li>
        <li class="check-item reveal-child">Weather-sealed to prevent leaks after installation</li>
        <li class="check-item reveal-child">Low-profile options available for space-restricted rooftops</li>
        <li class="check-item reveal-child">Rust-resistant hardware to withstand harsh rooftop conditions</li>
      </ul>
      <p class="text-[#D4D4D4] mb-6 reveal-child">We carry hinge kits for most brands: CaptiveAire, Greenheck, PennBarry, and more.</p>

      <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Common Issues We Fix</h3>
      <ul class="space-y-2 mb-6">
        <li class="check-item reveal-child">Fan disconnected and laid on the roof during cleaning</li>
        <li class="check-item reveal-child">Damaged or severed electrical connections</li>
        <li class="check-item reveal-child">Grease leaks into ductwork or onto roof</li>
        <li class="check-item reveal-child">Fans not sealed properly after maintenance</li>
        <li class="check-item reveal-child">Failed inspections due to missing hinges</li>
      </ul>
    </div>
  </section>

  <InlineCTA headline="Request Exhaust Fan Parts Now" />

  <!-- Split text/image section -->
  <section class="bg-[#1A1A1A] py-12 md:py-16 lg:py-20 px-5">
    <div class="max-w-[1200px] mx-auto reveal">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="section-headline reveal-child">Installation Cost, Timeline & Availability</h2>
          <ul class="space-y-2 mb-6">
            <li class="check-item reveal-child">Install Time: Most installs completed in under 2 hours</li>
            <li class="check-item reveal-child">Cost Range: $300-$700 depending on fan type and accessibility</li>
            <li class="check-item reveal-child">Emergency Service Available: Need it before inspection? We can help</li>
          </ul>
          <button type="button" class="btn-primary popup-trigger reveal-child">Request Service Online</button>
        </div>
        <div class="reveal-child">
          <img
            src="/images/services/hinge-kit-split.webp"
            alt="exhaust fan hinge kit installation detail - DDAN Hood Cleaning and Repair"
            class="w-full rounded"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <ServiceAreaGrid
    headline="Service Area"
    intro="We provide exhaust fan hinge kit installation across Middle Tennessee."
  />

  <TruckCTA />
</BaseLayout>
