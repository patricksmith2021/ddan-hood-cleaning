---
import BaseLayout from '../layouts/BaseLayout.astro';
import business from '../data/business.json';
import InlineCTA from '../components/InlineCTA.astro';
import ServiceAreaGrid from '../components/ServiceAreaGrid.astro';
import TruckCTA from '../components/TruckCTA.astro';

const siteUrl = import.meta.env.SITE || 'https://ddanhoodservices.com';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${siteUrl}/exhaust-fan-hinge-kit-installation/`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": business.address.city,
        "addressRegion": business.address.state,
        "postalCode": business.address.zip,
        "addressCountry": "US"
      },
      "areaServed": { "@type": "State", "name": "Tennessee" },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "serviceType": "Exhaust Fan Hinge Kit Installation",
      "provider": { "@type": "LocalBusiness", "name": business.name },
      "areaServed": { "@type": "State", "name": "Tennessee" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Hinge Kit Installation" }
      ]
    }
  ]
};
---

<BaseLayout
  title="Exhaust Fan Hinge Kit Installation | DDAN Hood Cleaning"
  description="Install NFPA 96-compliant exhaust fan hinge kits for safe rooftop access and cleaning. Protect your fans and meet code. We install in one visit."
>
<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <!-- SECTION 1: HERO -->
  <section role="img" aria-label="Exhaust fan hinge kit installation service — DDAN Hood Cleaning and Repair" class="min-h-[400px] md:min-h-[550px] flex items-center justify-center" style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.3) 100%), url('/images/services/exhaust-fan-hinge-kit-service.webp') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <p class="text-[#FF5E15] font-heading font-bold text-xs md:text-sm tracking-widest uppercase mb-4">DDAN HOOD CLEANING AND REPAIR</p>
      <h1 class="font-display text-white text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">Exhaust Fan <span class="text-[#FF5E15]">Hinge Kit</span> Installation</h1>
      <p class="text-gray-200 font-body text-lg md:text-xl max-w-2xl mx-auto mb-6">Code-compliant hinge kits that let your rooftop exhaust fan tilt open safely for interior cleaning access. Heavy-duty, rust-resistant, and built to last.</p>
      <p class="text-white font-heading font-bold text-base md:text-lg mb-2">Code-Compliant • Easy to Clean • Built for Safety</p>
      <div class="w-20 h-1 bg-[#FF5E15] mx-auto mt-3 mb-8"></div>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5E15] text-white font-heading font-bold text-lg rounded-lg transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
          Call Now: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-[#FF5E15] text-[#FF5E15] font-heading font-bold text-lg rounded-lg hover:bg-[#FF5E15] hover:text-white transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 320 512"><path d="M272 0H48C21.5 0 0 21.5 0 48v416c0 26.5 21.5 48 48 48h224c26.5 0 48-21.5 48-48V48c0-26.5-21.5-48-48-48zM160 480c-17.7 0-32-14.3-32-32s14.3-32 32-32 32 14.3 32 32-14.3 32-32 32zm112-108c0 6.6-5.4 12-12 12H60c-6.6 0-12-5.4-12-12V60c0-6.6 5.4-12 12-12h200c6.6 0 12 5.4 12 12v312z"/></svg>
          Request Service Online
        </button>
      </div>
      <div class="flex justify-center items-center gap-6 mt-8">
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/google-white-logo-1024x337.png" alt="Google" width="1024" height="337" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/facebook-logo-white-full-transparent-1024x341.png" alt="Facebook" width="1024" height="341" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/YELP_BIG.D-5a67c069-1024x392.png" alt="Yelp" width="1024" height="392" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BREADCRUMB STRIP -->
  <div class="bg-[#0A0A0A] py-2 px-5">
    <div class="max-w-[1200px] mx-auto">
      <nav class="flex items-center gap-2 text-sm font-heading text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF5E15] transition-colors">Home</a>
        <span class="text-[#FF5E15]">/</span>
        <span class="text-gray-300">Exhaust Fan Hinge Kit Installation</span>
      </nav>
    </div>
  </div>

  <!-- Code-Compliant intro + What Happens Without a Proper Hinge -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <p class="font-heading font-semibold text-lg text-white mb-4 reveal-child">Code-Compliant. Easy to Clean. Built for Safety.</p>
      <h2 class="section-headline reveal-child">What Happens Without a Proper Exhaust Fan Hinge</h2>
      <p class="text-[#D4D4D4] mb-4 reveal-child">If your rooftop exhaust fan isn't mounted on a hinge, you're setting yourself up for problems. A non-hinged fan makes cleaning dangerous, damages your wiring, and can lead to costly fines or fire hazards. NFPA 96 requires all upblast exhaust fans to be hinged — and for good reason.</p>
      <p class="text-[#D4D4D4] mb-6 reveal-child">At DDAN Hood Cleaning and Repair, we install heavy-duty, NFPA 96-compliant hinge kits that allow your fan to open safely for cleaning and maintenance. Our hinge installs are secure, rust-resistant, and built to last under real commercial kitchen conditions.</p>
    </div>
  </section>

  <!-- What a Proper Hinge Kit Does -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="section-headline reveal-child">What a Proper Hinge Kit Does</h2>
      <ul class="space-y-2 mb-6">
        <li class="check-item reveal-child">Allows rooftop exhaust fans to tilt open for interior cleaning access</li>
        <li class="check-item reveal-child">Protects electrical wiring from stretching or tearing during service</li>
        <li class="check-item reveal-child">Prevents water and grease from leaking into your ductwork</li>
        <li class="check-item reveal-child">Reduces risk of injury during cleaning or maintenance</li>
        <li class="check-item reveal-child">Satisfies NFPA 96 and local fire code requirements</li>
      </ul>
      <p class="text-[#D4D4D4] mb-6 reveal-child">Not sure if your fan has a hinge? If it lifts straight off or is bolted down, it probably doesn't.</p>
    </div>
  </section>

  <!-- Installation Services + Common Issues -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Exhaust Fan Hinge Kit Installation Services</h3>
      <ul class="space-y-2 mb-6">
        <li class="check-item reveal-child">Includes brackets, pins, hardware, and sealing materials</li>
        <li class="check-item reveal-child">Mounting on curb or stack bases depending on fan type</li>
        <li class="check-item reveal-child">Weather-sealed to prevent leaks after installation</li>
        <li class="check-item reveal-child">Low-profile options available for space-restricted rooftops</li>
        <li class="check-item reveal-child">Rust-resistant hardware to withstand harsh rooftop conditions</li>
      </ul>
      <p class="text-[#D4D4D4] mb-6 reveal-child">We carry hinge kits for most brands: CaptiveAire, Greenheck, PennBarry, and more.</p>

      <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Common Issues We Fix</h3>
      <ul class="space-y-2 mb-6">
        <li class="check-item reveal-child">Fan disconnected and laid on the roof during cleaning</li>
        <li class="check-item reveal-child">Damaged or severed electrical connections</li>
        <li class="check-item reveal-child">Grease leaks into ductwork or onto roof</li>
        <li class="check-item reveal-child">Fans not sealed properly after maintenance</li>
        <li class="check-item reveal-child">Failed inspections due to missing hinges</li>
      </ul>
    </div>
  </section>

  <InlineCTA headline="Request Exhaust Fan Parts Now" />

  <!-- Split text/image section -->
  <section class="bg-[#1A1A1A] py-12 md:py-16 lg:py-20 px-5">
    <div class="max-w-[1200px] mx-auto reveal">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="section-headline reveal-child">Installation Cost, Timeline & Availability</h2>
          <ul class="space-y-2 mb-6">
            <li class="check-item reveal-child">Install Time: Most installs completed in under 2 hours</li>
            <li class="check-item reveal-child">Cost Range: $300-$700 depending on fan type and accessibility</li>
            <li class="check-item reveal-child">Emergency Service Available: Need it before inspection? We can help</li>
          </ul>
          <button type="button" class="btn-primary popup-trigger reveal-child">Request Service Online</button>
        </div>
        <div class="reveal-child">
          <img
            src="/images/services/hinge-kit-split.webp"
            alt="exhaust fan hinge kit installation detail - DDAN Hood Cleaning and Repair"
            class="w-full rounded"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <ServiceAreaGrid
    headline="Service Area"
    intro="We provide exhaust fan hinge kit installation across Middle Tennessee."
  />

  <TruckCTA />
</BaseLayout>
