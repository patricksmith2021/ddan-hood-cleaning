---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import ServiceSidebar from '../components/ServiceSidebar.astro';
import InlineCTA from '../components/InlineCTA.astro';
import ServiceAreaGrid from '../components/ServiceAreaGrid.astro';
import BottomCTA from '../components/BottomCTA.astro';
import business from '../data/business.json';
---

<BaseLayout
  title="Commercial Hood Repair - Restaurant Exhaust Fan Repair"
  description="Expert hood repair and commercial exhaust fan service. Fast diagnosis and 24/7 repair for restaurant ventilation systems across Middle Tennessee."
>
  <HeroBanner
    headline="Commercial Kitchen Exhaust System Hood Repair"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Hood Repair' },
    ]}
  />

  <!-- 65/35 Split -->
  <section class="bg-white">
    <div class="container-narrow">
      <div class="grid lg:grid-cols-[65%_35%]">
        <!-- Content Column -->
        <div class="p-6 md:p-10 text-body-text-light">

          <div class="reveal">
            <h2 class="section-headline reveal-child">Expert Hood & Exhaust Fan Repairs | NFPA 96-Compliant | 24/7 Emergency Service</h2>
            <img
              src="/images/services/hood-repair-hero.jpg"
              alt="commercial hood repair Nashville TN - DDAN Hood Cleaning and Repair"
              class="w-full rounded mb-6 reveal-child"
              loading="eager"
            />
            <h3 class="font-heading font-semibold text-lg text-dark-base mb-3 reveal-child">Restore Your Kitchen's Airflow and Safety with Expert Repairs</h3>
            <p class="mb-4 reveal-child">At DDAN Hood Cleaning and Repair, we provide professional commercial kitchen hood repair services across Mt. Juliet, Nashville, and all surrounding Middle Tennessee areas. We specialize in rapidly diagnosing and fixing issues throughout your entire kitchen ventilation system, from crucial rooftop exhaust fans down to the internal ductwork and access panels.</p>
            <p class="mb-6 reveal-child">If your restaurant's exhaust system is experiencing unusual noises, diminished airflow, dangerous grease leaks, or has completely ceased operation, our skilled technicians will swiftly get it diagnosed, repaired, and back in optimal working condition. All our commercial kitchen exhaust system repairs adhere strictly to NFPA 96 fire code standards, ensuring solutions that are not only effective but also durable and compliant.</p>
          </div>

          <div class="reveal mt-8">
            <h2 class="section-headline reveal-child">Comprehensive Exhaust System Repairs We Handle</h2>
            <p class="mb-6 reveal-child">We are equipped to service and repair all major components of your commercial kitchen exhaust system, addressing critical issues to prevent downtime and maintain safety.</p>

            <h4 class="font-heading font-semibold text-base text-dark-base mb-3 reveal-child">Exhaust Fan Motor Repair & Replacement</h4>
            <ul class="space-y-2 mb-6">
              <li class="check-item reveal-child">Problems Addressed: Exhaust fan not turning on, excessive noise (grinding, squealing, buzzing), noticeable vibration, or loss of power.</li>
              <li class="check-item reveal-child">Our Solution: Our technicians expertly diagnose electrical issues, replace worn bearings, rewind motors, or perform complete motor replacements as needed to restore full functionality.</li>
            </ul>

            <h4 class="font-heading font-semibold text-base text-dark-base mb-3 reveal-child">Exhaust Fan Belt Replacement & Adjustment</h4>
            <ul class="space-y-2 mb-6">
              <li class="check-item reveal-child">Problems Addressed: High-pitched squealing sounds, significantly reduced airflow, or a completely stopped exhaust fan.</li>
              <li class="check-item reveal-child">Our Solution: We meticulously inspect belt tension, replace worn or broken fan belts, and precisely realign pulleys to ensure optimal performance.</li>
            </ul>
          </div>

          <InlineCTA headline="Schedule Your Expert Hood Cleaning Today" />

          <div class="reveal mt-8">
            <h4 class="font-heading font-semibold text-base text-dark-base mb-3 reveal-child">Exhaust Fan Hinge Kit Installation & Repair</h4>
            <ul class="space-y-2 mb-6">
              <li class="check-item reveal-child">Problems Addressed: Rooftop exhaust fan not properly hinged for safe cleaning and maintenance, or an existing hinge system is damaged.</li>
              <li class="check-item reveal-child">Our Solution: We expertly install new NFPA 96-compliant hinge kits on your rooftop exhaust fans, or repair existing ones.</li>
            </ul>

            <h4 class="font-heading font-semibold text-base text-dark-base mb-3 reveal-child">Access Panel Installation & Repair</h4>
            <ul class="space-y-2 mb-6">
              <li class="check-item reveal-child">Problems Addressed: Lack of code-required access panels in your ductwork, or existing panels that are damaged, ill-fitting, or leaking grease.</li>
              <li class="check-item reveal-child">Our Solution: We install NFPA 96-compliant access doors every 12 feet and at every direction change in your grease ducts.</li>
            </ul>

            <h4 class="font-heading font-semibold text-base text-dark-base mb-3 reveal-child">Grease Ductwork Repair & Sealing</h4>
            <ul class="space-y-2 mb-6">
              <li class="check-item reveal-child">Problems Addressed: Leaky or damaged commercial kitchen grease ducts, improper slope leading to grease pooling within the system.</li>
              <li class="check-item reveal-child">Our Solution: We meticulously patch holes, professionally seal seams, replace deteriorated sections, and can re-grade duct runs.</li>
            </ul>

            <h4 class="font-heading font-semibold text-base text-dark-base mb-3 reveal-child">Grease Containment System Repair & Maintenance</h4>
            <ul class="space-y-2 mb-6">
              <li class="check-item reveal-child">Problems Addressed: Overflowing rooftop grease traps, deteriorated liners, clogged drain kits, or damaged containment units.</li>
              <li class="check-item reveal-child">Our Solution: We replace worn trays and liners, clear clogged drainage systems, and repair or install durable rooftop grease containment systems.</li>
            </ul>

            <h3 class="font-heading font-semibold text-lg text-dark-base mb-3 reveal-child">Electrical & Control Panel Troubleshooting</h3>
            <ul class="space-y-2 mb-6">
              <li class="check-item reveal-child">Problems Addressed: Exhaust fans failing to power on, malfunctioning control panels, tripped circuit breakers, or erratic system behavior.</li>
              <li class="check-item reveal-child">Our Solution: Our technicians proficiently inspect power supplies, switches, and electrical connections. We replace faulty wiring and defective control units.</li>
            </ul>
          </div>

          <div class="reveal mt-8">
            <h3 class="font-heading font-semibold text-lg text-dark-base mb-3 reveal-child">Typical Repair Details:</h3>
            <ul class="space-y-2 mb-6">
              <li class="check-item reveal-child">Repair Cost Range: Most common repairs typically range from $125-$450.</li>
              <li class="check-item reveal-child">Emergency Service Available: We offer 24/7 emergency repair services for urgent system failures.</li>
              <li class="check-item reveal-child">Average Service Time: Most individual repair issues can be resolved within 1-2 hours onsite.</li>
            </ul>
          </div>

          <div class="reveal mt-8">
            <h2 class="section-headline reveal-child">Rapid Repairs Prevent Costly Downtime and Compliance Shutdowns</h2>
            <p class="mb-6 reveal-child">When your commercial kitchen ventilation system fails, your restaurant's operations are severely compromised, often leading to potential health code violations or even immediate shutdown by inspectors. DDAN Hood Cleaning and Repair provides fast, expert repairs that rapidly restore optimal airflow, eliminate dangerous fire hazards, and ensure your business is back in full compliance.</p>
          </div>

          <div class="reveal mt-8">
            <h2 class="section-headline reveal-child">All Work Complies with NFPA 96 Standards</h2>
            <p class="mb-6 reveal-child">DDAN performs every repair to the stringent requirements of NFPA 96. Our commitment to these industry-leading fire safety standards means we not only get your system working again, but we also ensure it's safe, up to code, and built for lasting performance.</p>
          </div>

        </div>
        <!-- Sidebar -->
        <ServiceSidebar />
      </div>
    </div>
  </section>

  <!-- Split text/image section -->
  <section class="bg-secondary section-padding">
    <div class="container-narrow reveal">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="section-headline reveal-child">Fast Scheduling, Minimal Operational Interruption</h2>
          <p class="text-body-text mb-4 reveal-child">We understand the demands of a busy commercial kitchen. DDAN offers flexible scheduling, including convenient off-hours, early mornings, and overnight appointments.</p>
          <p class="text-body-text mb-6 reveal-child">For urgent repair needs, we provide same-day service whenever possible.</p>
          <a href="/contact/" class="btn-primary reveal-child">Request Service Online</a>
        </div>
        <div class="reveal-child">
          <img
            src="/images/services/rooftop-hinge-kit.jpg"
            alt="rooftop exhaust fan hinge kit installation - DDAN Hood Cleaning and Repair"
            class="w-full rounded"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <ServiceAreaGrid
    headline="Areas We Provide Hood & Exhaust Fan Repair Services"
    intro="Based strategically in Mt. Juliet, TN (37122), our expert repair team services commercial kitchens across the entire Middle Tennessee region."
    outro="We also provide dedicated repair support and multi-location service plans for restaurant chains, franchises, and large facility management companies."
  />

  <BottomCTA
    headline="Request Your Hood Repair Service Quote Today!"
    body="Don't let a failing commercial kitchen exhaust system compromise your operations, safety, or compliance. Call DDAN Hood Cleaning and Repair for fast, professional, and reliable repair service you can trust."
    subtext="Free Estimates Within 15 Miles of Mt. Juliet | Emergency Repair Available 24/7"
  />
</BaseLayout>
