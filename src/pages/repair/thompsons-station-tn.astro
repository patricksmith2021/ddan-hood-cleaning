---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'Why do new restaurant exhaust fans in Thompson\'s Station fail so quickly?',
    a: 'Builders install the cheapest OEM fan belts and motors to pass initial inspection. These factory parts aren\'t rated for the continuous heat and load of real commercial cooking. Most fail within 1 to 3 years of opening. We upgrade to commercial-grade components — heavy-duty notched V-belts, high-capacity motors, and sealed bearings — that last 5 to 10 times longer than the factory originals.',
  },
  {
    q: 'How quickly can DDAN respond to an emergency fan failure in Thompson\'s Station?',
    a: `Thompson's Station is within our standard Middle Tennessee service area near Franklin and Spring Hill. We provide 24/7 emergency dispatch and carry common fan motors, belts, and bearings on every truck. Most Thompson's Station emergency calls receive same-day response. Call ${business.phone} any time — we understand that a dead fan in a new restaurant threatens both your operation and your lease.`,
  },
  {
    q: 'Can you prevent grease damage to new TPO roofs in Thompson\'s Station?',
    a: 'Yes. Thompson\'s Station\'s new commercial developments feature pristine white TPO roof membranes that are extremely susceptible to grease staining. Property managers in master-planned communities enforce strict roof maintenance clauses with severe penalties for grease damage. We install and service heavy-duty grease containment systems that protect roof surfaces and provide photo documentation proving compliance with lease requirements.',
  },
  {
    q: 'Do you provide photo documentation for landlord compliance?',
    a: 'Yes. Every Thompson\'s Station repair includes comprehensive photo documentation showing the condition of your exhaust system before and after service. This documentation is critical for proving compliance with lease roof-maintenance clauses, NFPA 96 fire code requirements, and property management inspections. We provide digital copies you can forward directly to your landlord or property manager.',
  },
];

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev',
      "image": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/images/logo.png`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": "Mt. Juliet",
        "addressRegion": "TN",
        "postalCode": "37122",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Thompson's Station",
        "addressRegion": "TN"
      },
      "priceRange": "$$"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev' },
        { "@type": "ListItem", "position": 2, "name": "Hood Repair", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/repair/` },
        { "@type": "ListItem", "position": 3, "name": "Thompson's Station, TN", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/repair/thompsons-station-tn/` }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="Thompson's Station New-Build Fan Repair | DDAN"
  description="OEM exhaust fans fail fast in Thompson's Station's new restaurants. Tollgate Village and Columbia Pike repair experts. (615) 881-6968."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/hero-1.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/repair/" class="hover:text-[#FF5E15] transition-all duration-300">Hood Repair</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Thompson's Station, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Thompson's Station Exhaust Fan Repair — <span class="text-[#FF5E15]">New-Build Kitchens</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Tollgate Village and Columbia Pike — new kitchens with factory parts that fail first
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Why Thompson's Station's New Restaurants Are Already Failing Exhaust Fans
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Thompson's Station is one of Williamson County's wealthiest master-planned communities, and Tollgate Village and Columbia Pike are attracting premium dining concepts in brand-new buildings with pristine white TPO roofs. But new construction means cheap OEM exhaust equipment installed by builders — belts and motors that weren't designed for real commercial cooking loads. These factory parts pass initial inspection, then fail within 1 to 3 years under the sustained heat and grease output of actual restaurant operations.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Property managers in Thompson's Station's upscale developments issue severe penalties for any grease staining on roof surfaces. When cheap factory grease catchers overflow or fan housing seals vibrate loose, grease pools on pristine TPO membranes — voiding manufacturer warranties and triggering lease violations that can cost thousands. Restaurant owners discover too late that the exhaust equipment their builder installed was the cheapest option available, not the right option for commercial cooking. DDAN upgrades factory components to commercial-grade equipment that actually handles the load, protects the roof, and keeps property managers satisfied.
        </p>
      </div>
    </div>
  </section>

  <!-- WHAT WE REPAIR — FANS FIRST -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        What We Repair — Fans First
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-8 max-w-4xl reveal-child">
        Thompson's Station's new-build kitchens generate a unique pattern of premature equipment failure:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        {[
          { title: 'Motor Replacement', desc: 'Builder-installed motors fail within 1-3 years under real commercial cooking loads. We upgrade to properly rated commercial units that match actual kitchen demand.' },
          { title: 'Belt Replacement & Tensioning', desc: 'Cheap OEM belts stretch and snap under sustained heat. Commercial-grade notched V-belts with proper tensioning prevent premature failure.' },
          { title: 'Impeller & Fan Wheel Service', desc: 'Even new impellers accumulate grease quickly in high-output kitchens. We clean, rebalance, and prevent the vibration that damages bearings and housings.' },
          { title: 'Bearing Replacement', desc: 'Factory bearings in new-build fans aren\'t sealed for commercial grease environments. Upgraded sealed high-heat units extend service life dramatically.' },
          { title: 'Grease Containment Upgrade', desc: 'Factory grease catchers overflow and stain new TPO roofs. We install heavy-duty containment systems that protect your roof investment.' },
          { title: 'Full Fan Replacement', desc: 'When builder-grade equipment can\'t be economically upgraded, we install commercial-rated replacements properly sized for your kitchen\'s actual CFM requirements.' },
        ].map((card) => (
          <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-xl p-6 transition-all duration-300 reveal-child">
            <h3 class="font-heading text-white text-lg font-semibold mb-2">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-sm leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
      <h3 class="font-heading text-[#FF5E15] text-xl font-semibold mb-4 reveal-child">Beyond Fans — Full Exhaust System Repair</h3>
      <ul class="space-y-3 max-w-3xl">
        <li class="check-item reveal-child">Ductwork damage, disconnections, and failed seams</li>
        <li class="check-item reveal-child">Hood canopy structural repair and hinge replacement</li>
        <li class="check-item reveal-child"><a href="/exhaust-fan-hinge-kit-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hinge kit installation</a> for fans without proper service access</li>
        <li class="check-item reveal-child"><a href="/restaurant-fire-suppression-systems/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Fire suppression system</a> link and nozzle replacement</li>
        <li class="check-item reveal-child"><a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Belt and motor repair</a> — our most-requested Thompson's Station service</li>
      </ul>
    </div>
  </section>

  <!-- EMERGENCY CALLOUT -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="bg-black border-2 border-[#FF5E15] rounded-2xl p-8 md:p-12 text-center reveal-child">
        <h2 class="font-heading text-white text-2xl md:text-3xl font-bold mb-3">Fan Died? Kitchen Shut Down? We're On It.</h2>
        <p class="text-[#FF5E15] font-heading text-lg font-semibold mb-6">24/7 Emergency Dispatch for Thompson's Station</p>
        <a href={`tel:${business.phoneRaw}`} class="inline-block text-white font-display text-3xl md:text-5xl font-bold tracking-wide hover:text-[#FF5E15] transition-all duration-300">
          {business.phone}
        </a>
        <p class="text-[#D4D4D4] font-body text-base mt-4">Same-day motor and belt replacement. We carry common parts on every truck.</p>
      </div>
    </div>
  </section>

  <!-- COMMON FAILURES IN THOMPSON'S STATION -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Exhaust Fan Failures in Thompson's Station
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Cheap builder-installed OEM belts and motors are the primary cause of premature exhaust fan failure in Thompson's Station. Builders install the minimum-spec components needed to pass the initial inspection — factory belts that aren't rated for continuous commercial cooking heat, motors sized for light-duty applications, and basic grease catchers that overflow within months. These components fail within 1 to 3 years of opening, leaving restaurant owners scrambling for emergency repairs and facing lease violations from grease-stained roofs. DDAN provides emergency <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">belt and motor repair</a> with commercial-grade replacements that actually handle real cooking loads.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          TPO roof lease violations from grease containment failures are the second most common issue we address in Thompson's Station. Factory-installed grease catchers are undersized for commercial cooking output. When they overflow, grease runs across pristine white TPO membranes, causing permanent staining that property managers in upscale Williamson County developments do not tolerate. The penalties are severe — and the roof membrane damage can void manufacturer warranties worth tens of thousands of dollars. Upgrading the fan, replacing the containment system, and providing photo documentation is the only way to resolve the violation and prevent recurrence.
        </p>
      </div>
    </div>
  </section>

  <!-- COMPLIANCE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Thompson's Station Fire Code Compliance
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Williamson County Fire/Rescue (WCFR) enforces NFPA 96 standards for all commercial kitchen exhaust systems in Thompson's Station. New restaurant openings receive heightened scrutiny, and inspectors verify that exhaust equipment meets code requirements for the actual cooking operations being performed — not just the minimal specs the builder installed. Non-functional fans, improperly tensioned belts, and inadequate grease containment all trigger citations. Every DDAN repair includes photo documentation and a service report to demonstrate compliance. Read our full guide to <a href="/nfpa-code-96-standards/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">NFPA 96 compliance standards</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- PROOF POINT -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="border-l-4 border-[#FF5E15] bg-[#111111] p-6 rounded-r-xl max-w-3xl reveal-child">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed italic">
          "A brand-new premium casual restaurant in a major Thompson's Station development received a warning from their landlord after cheap factory grease catchers allowed oil to stain the pristine TPO roof. DDAN installed a heavy-duty containment system, upgraded the factory fan belt, and provided photo documentation proving compliance — resolving the lease violation and preventing future roof damage."
        </p>
      </div>
    </div>
  </section>

  <!-- BRANDS WE SERVICE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Exhaust Fan Brands We Service
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-6 max-w-4xl reveal-child">
        We repair and replace components for every major commercial exhaust fan manufacturer installed in Thompson's Station kitchens:
      </p>
      <div class="flex flex-wrap gap-4 reveal-child">
        {['CaptiveAire', 'Loren Cook', 'Canarm', 'NAKS', 'EconAir', 'Greenheck', 'Accurex', 'PennBarry', 'Dayton', 'Fantech'].map((brand) => (
          <span class="bg-[#1A1A1A] border border-[#333] text-[#D4D4D4] font-body text-sm px-4 py-2 rounded-lg">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Thompson's Station Exhaust Fan Repair Service Area
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN provides 24/7 exhaust fan repair across all of Thompson's Station, including Tollgate Village, Columbia Pike commercial areas, and surrounding Williamson County developments. Whether your restaurant is in a new mixed-use center or an established strip, we respond to emergency fan failures day and night with common parts on every truck.
        </p>
        <div class="space-y-3 reveal-child">
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also in Thompson's Station:</span>
            <a href="/cleaning/thompsons-station-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hood Cleaning</a> &middot;
            <a href="/parts/thompsons-station-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Parts & Installation</a>
          </p>
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also serving nearby:</span>
            <a href="/repair/spring-hill-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Spring Hill</a> and
            <a href="/repair/franklin-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Franklin</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Thompson's Station Exhaust Fan Repair FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-[#111111] border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-[#111111] rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed" set:html={faq.a}></p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CITY-SPECIFIC URGENCY + TRUCK CTA -->
  <section class="bg-[#111111] py-12 md:py-16 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <p class="text-[#D4D4D4] font-body text-lg leading-relaxed text-center max-w-3xl mx-auto reveal-child">
        Thompson's Station's new restaurants are discovering that builder-grade equipment doesn't survive real commercial cooking. Don't wait for a lease violation or a mid-service shutdown. Call now.
      </p>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
