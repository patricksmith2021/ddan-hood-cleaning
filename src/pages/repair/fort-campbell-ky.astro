---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'Can DDAN service exhaust systems inside Fort Campbell?',
    a: 'Yes. Our technicians are experienced with Fort Campbell\'s base access protocols. We coordinate with installation management to obtain proper credentialing and schedule work windows that align with DFAC operations and base security requirements. On-base service is part of our standard capability for military facilities.',
  },
  {
    q: 'Are DFAC exhaust systems different from civilian restaurant systems?',
    a: 'Yes — significantly. Dining Facility (DFAC) exhaust systems typically run heavy-duty 3-phase commercial motors at punishing duty cycles far beyond what civilian restaurants demand. DFACs serve hundreds to thousands of meals per shift, multiple shifts per day, with minimal downtime between services. The motors, belts, and bearings must be rated for continuous industrial operation. Standard restaurant-grade replacement parts will fail quickly in a DFAC environment.',
  },
  {
    q: 'Does Fort Campbell require different fire code compliance than civilian kitchens?',
    a: `Fort Campbell operates under dual fire authority — Department of Defense (DoD) Fire Marshals AND the Fort Campbell Fire Department. DoD fire standards often exceed civilian NFPA 96 requirements, with stricter inspection schedules and more rigorous documentation demands. Every DDAN repair includes comprehensive photo documentation and service reports that satisfy both military and civilian compliance requirements. Read our <a href="/nfpa-code-96-standards/" class="text-[#FF5E15] underline hover:text-white">NFPA 96 guide</a> for civilian baseline standards.`,
  },
  {
    q: 'Do you handle security clearance requirements for military installations?',
    a: 'Yes. Our technicians are experienced with Fort Campbell\'s base access protocols. We coordinate with installation management to ensure proper credentialing and scheduling for on-base work. Security compliance is part of our standard process for military facilities.',
  },
];

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev',
      "image": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/images/logo.png`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": "Mt. Juliet",
        "addressRegion": "TN",
        "postalCode": "37122",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Fort Campbell",
        "addressRegion": "KY"
      },
      "priceRange": "$$"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev' },
        { "@type": "ListItem", "position": 2, "name": "Hood Repair", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/repair/` },
        { "@type": "ListItem", "position": 3, "name": "Fort Campbell, KY", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/repair/fort-campbell-ky/` }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="Fort Campbell Military Kitchen Fan Repair | DDAN"
  description="DFAC exhaust fan repair at Fort Campbell. DoD fire code compliant. Heavy-duty 3-phase motors for military dining facilities. (615) 881-6968."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/rooftop-exhaust-fan.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/repair/" class="hover:text-[#FF5E15] transition-all duration-300">Hood Repair</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Fort Campbell, KY</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Fort Campbell Military Kitchen <span class="text-[#FF5E15]">Exhaust Fan Repair</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        101st Airborne DFAC systems demand heavy-duty repair. We're credentialed for on-base service.
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Why Fort Campbell's DFAC Systems Demand Heavy-Duty Exhaust Fan Repair
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Fort Campbell is home to the 101st Airborne Division — one of the largest continuous dining populations in the region. Dining Facility (DFAC) exhaust systems run at punishing duty cycles that dwarf anything in the civilian restaurant world, serving hundreds to thousands of meals per shift across multiple daily services. These systems require heavy-duty 3-phase commercial motors and constant belt monitoring to keep pace with the relentless output of military-scale food preparation.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Navigating DoD security protocols and on-base access requirements adds complexity that most commercial repair companies can't handle. Scheduling windows are tight, credentialing takes coordination, and the work itself must meet standards that exceed civilian NFPA 96 requirements. DDAN is experienced with Fort Campbell's base access procedures and provides the heavy-duty repair and documentation that military dining facilities demand. When a DFAC exhaust fan goes down before a meal service for hundreds of troops, there is zero margin for delay.
        </p>
      </div>
    </div>
  </section>

  <!-- WHAT WE REPAIR — FANS FIRST -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        What We Repair — Fans First
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-8 max-w-4xl reveal-child">
        DFAC exhaust systems run heavier, hotter, and longer than civilian kitchens. These are the components that fail first:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        {[
          { title: '3-Phase Motor Replacement', desc: 'DFAC motors run continuous duty cycles that destroy standard units. We install heavy-duty 3-phase motors rated for military-scale food service.' },
          { title: 'Belt Replacement & Tensioning', desc: 'Sustained high-volume operation stretches belts fast. Heavy-duty notched V-belts with precision tensioning handle DFAC loads.' },
          { title: 'Impeller & Fan Wheel Service', desc: 'Mass food preparation coats impellers with grease rapidly. We clean, rebalance, or replace to restore full airflow capacity.' },
          { title: 'Bearing Replacement', desc: 'Continuous operation generates extreme heat and vibration. Military-grade sealed bearings resist the thermal stress of DFAC environments.' },
          { title: 'VFD & Speed Control Repair', desc: 'Variable frequency drives optimize fan performance. Base power grid fluctuations can damage sensitive VFD electronics.' },
          { title: 'Full Fan Replacement', desc: 'When a unit can\'t sustain the duty cycle a DFAC demands, we install a properly sized replacement with the correct 3-phase motor and housing.' },
        ].map((card) => (
          <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-xl p-6 transition-all duration-300 reveal-child">
            <h3 class="font-heading text-white text-lg font-semibold mb-2">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-sm leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
      <h3 class="font-heading text-[#FF5E15] text-xl font-semibold mb-4 reveal-child">Beyond Fans — Full Exhaust System Repair</h3>
      <ul class="space-y-3 max-w-3xl">
        <li class="check-item reveal-child">Ductwork damage, disconnections, and failed seams</li>
        <li class="check-item reveal-child">Hood canopy structural repair and hinge replacement</li>
        <li class="check-item reveal-child"><a href="/exhaust-fan-hinge-kit-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hinge kit installation</a> for fans without proper service access</li>
        <li class="check-item reveal-child"><a href="/restaurant-fire-suppression-systems/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Fire suppression system</a> link and nozzle replacement</li>
        <li class="check-item reveal-child"><a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Belt and motor repair</a> — critical for DFAC continuous operation</li>
      </ul>
    </div>
  </section>

  <!-- EMERGENCY CALLOUT -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="bg-black border-2 border-[#FF5E15] rounded-2xl p-8 md:p-12 text-center reveal-child">
        <h2 class="font-heading text-white text-2xl md:text-3xl font-bold mb-3">DFAC Fan Down? Troops Need to Eat. We're On It.</h2>
        <p class="text-[#FF5E15] font-heading text-lg font-semibold mb-6">Emergency Dispatch for Fort Campbell</p>
        <a href={`tel:${business.phoneRaw}`} class="inline-block text-white font-display text-3xl md:text-5xl font-bold tracking-wide hover:text-[#FF5E15] transition-all duration-300">
          {business.phone}
        </a>
        <p class="text-[#D4D4D4] font-body text-base mt-4">Heavy-duty 3-phase motor and belt replacement. We coordinate base access for rapid response.</p>
      </div>
    </div>
  </section>

  <!-- COMMON FAILURES AT FORT CAMPBELL -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common DFAC Exhaust Fan Failures at Fort Campbell
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Continuous DFAC duty cycles destroy motors designed for standard 8-hour restaurant shifts. Fort Campbell dining facilities serve multiple meal periods daily with minimal downtime between services — breakfast transitions directly into lunch preparation, which transitions into dinner. Exhaust fans run at or near full capacity for 14 to 18 hours straight. Motors not rated for this continuous industrial duty overheat, windings degrade, and bearings seize under sustained thermal stress. Deployment returns create massive dining surges that push already-stressed systems past their limits. DDAN provides emergency <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">motor and belt repair</a> with 3-phase units rated for the actual duty cycle DFAC systems demand.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DoD fire marshals maintain standards that exceed civilian NFPA 96 requirements. Inspection schedules are more frequent, documentation demands are more rigorous, and the consequences of non-compliance are more severe. A failed exhaust fan in a DFAC doesn't just create a kitchen problem — it can affect the readiness and welfare of the installation's entire dining operation.
        </p>
      </div>
    </div>
  </section>

  <!-- COMPLIANCE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Fort Campbell Fire Code Compliance — Dual Authority
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Fort Campbell operates under dual fire authority — Department of Defense (DoD) Fire Marshals AND the Fort Campbell Fire Department. DoD fire standards often exceed civilian NFPA 96 requirements, with stricter inspection frequencies, more detailed documentation demands, and zero tolerance for deferred maintenance. Every DDAN repair includes comprehensive photo documentation and detailed service reports that satisfy both military and civilian compliance requirements. Our technicians understand the dual-authority inspection framework and ensure every repair meets the higher of the two standards. Read our guide to <a href="/nfpa-code-96-standards/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">NFPA 96 compliance standards</a> for the civilian baseline.
        </p>
      </div>
    </div>
  </section>

  <!-- PROOF POINT -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="border-l-4 border-[#FF5E15] bg-[#111111] p-6 rounded-r-xl max-w-3xl reveal-child">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed italic">
          "When an aging, heavy-duty exhaust fan motor at a major Fort Campbell DFAC began seizing just before the dinner rush for hundreds of troops, DDAN's team swiftly navigated base security protocols, sourced the exact 3-phase motor, and completed the installation, ensuring uninterrupted service for the 101st Airborne."
        </p>
      </div>
    </div>
  </section>

  <!-- BRANDS WE SERVICE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Exhaust Fan Brands We Service
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-6 max-w-4xl reveal-child">
        We repair and replace components for every major commercial and military-spec exhaust fan manufacturer:
      </p>
      <div class="flex flex-wrap gap-4 reveal-child">
        {['CaptiveAire', 'Loren Cook', 'Canarm', 'NAKS', 'EconAir', 'Greenheck', 'Accurex', 'PennBarry', 'Dayton', 'Fantech'].map((brand) => (
          <span class="bg-[#1A1A1A] border border-[#333] text-[#D4D4D4] font-body text-sm px-4 py-2 rounded-lg">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Fort Campbell Exhaust Fan Repair Service Area
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN provides exhaust fan repair for Fort Campbell's dining facilities and the surrounding Clarksville-area commercial kitchens. We coordinate with installation management for on-base access and maintain the credentialing required for military facility service.
        </p>
        <div class="space-y-3 reveal-child">
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also at Fort Campbell:</span>
            <a href="/cleaning/fort-campbell-ky/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hood Cleaning</a> &middot;
            <a href="/parts-installation/fort-campbell-ky/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Parts & Installation</a>
          </p>
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also serving nearby:</span>
            <a href="/repair/clarksville-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Clarksville</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Fort Campbell Exhaust Fan Repair FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-[#111111] border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-[#111111] rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed" set:html={faq.a}></p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CITY-SPECIFIC URGENCY + TRUCK CTA -->
  <section class="bg-[#111111] py-12 md:py-16 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <p class="text-[#D4D4D4] font-body text-lg leading-relaxed text-center max-w-3xl mx-auto reveal-child">
        Fort Campbell's DFACs feed the 101st Airborne — and those kitchens can't afford downtime. Don't wait for a motor to seize before a meal service. Call now.
      </p>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
