---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'My restaurant in Spring Hill is brand new. Do I really need hood cleaning yet?',
    a: 'Yes. Even new kitchens accumulate grease in the exhaust system within the first few weeks of operation. NFPA 96 requires cleaning based on cooking volume, not building age. High-volume operations like fast-casual restaurants need quarterly cleaning from day one. Waiting until the system looks dirty means you\'ve already exceeded safe grease accumulation levels.',
  },
  {
    q: 'Can you protect the white TPO roof on my Spring Hill restaurant from grease?',
    a: `Absolutely. We install high-capacity <a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white">grease containment systems</a> specifically designed to prevent rooftop grease staining. TPO roofs at The Crossings and other Spring Hill developments are especially vulnerable because corporate landlords enforce strict property appearance standards. A single grease stain can trigger a lease violation. We install containment during fan repair visits to address both problems at once.`,
  },
  {
    q: 'Do you repair broken commercial exhaust fans?',
    a: `Yes — it's our core service. We repair exhaust fan motors, belts, bearings, impellers, VFDs, and housings for every major commercial brand. If the unit is beyond repair, we install a properly sized replacement. Call ${business.phone} for same-day diagnosis.`,
  },
  {
    q: 'How often should fan belts be inspected?',
    a: 'We recommend quarterly belt inspections for most restaurants. In Spring Hill\'s new builds, factory-installed belts should be inspected within the first 6 months — cheap OEM belts often stretch or crack much sooner than expected under real cooking loads. A snapped belt means a dead fan and a kitchen shutdown. Quarterly inspection catches degradation before it becomes an emergency.',
  },
];

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev',
      "image": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/images/logo.png`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": "Mt. Juliet",
        "addressRegion": "TN",
        "postalCode": "37122",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Spring Hill",
        "addressRegion": "TN"
      },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "serviceType": "Commercial Exhaust Fan Repair",
      "provider": { "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business` },
      "areaServed": {
        "@type": "City",
        "name": "Spring Hill",
        "addressRegion": "TN"
      },
      "description": "Emergency exhaust fan motor, belt, and bearing repair for Spring Hill commercial kitchens. New-build specialists for The Crossings and Port Royal Road corridors."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev' },
        { "@type": "ListItem", "position": 2, "name": "Hood Repair", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/repair/` },
        { "@type": "ListItem", "position": 3, "name": "Spring Hill, TN", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/repair/spring-hill-tn/` }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="Spring Hill Exhaust Fan Repair — New Build Experts | DDAN"
  description="Factory-installed fan belts fail fast in Spring Hill's new restaurants. Emergency repair and upgrades for The Crossings corridor. (615) 881-6968."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/hero-1.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/repair/" class="hover:text-[#FF5E15] transition-all duration-300">Hood Repair</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Spring Hill, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Spring Hill Exhaust Fan Repair — <span class="text-[#FF5E15]">New Build Specialists</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Factory-installed belts and motors fail first. We upgrade Spring Hill's new kitchens to commercial-grade.
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Why Spring Hill's New Restaurants Are Already Calling for Exhaust Fan Repair
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Spring Hill is exploding with new restaurant construction, fueled by the GM Spring Hill Manufacturing Plant workforce and the steady stream of families relocating to Maury and Williamson counties. The Crossings and Port Royal Road corridors are packed with fast-casual chains, pizza joints, and Mexican restaurants — all in buildings under 10 years old with pristine white TPO roofs and exhaust systems that look brand new from the outside. But "new" doesn't mean "reliable." Builders and general contractors cut costs by installing the cheapest OEM fan belts and motors that meet minimum spec. These factory parts aren't rated for the relentless grease loads and extended runtimes of a real commercial kitchen.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          The result is predictable: factory-installed fan belts and motors fail within 1 to 3 years, catching restaurant owners completely off guard. They assumed that new equipment means reliable equipment. It doesn't — not when the builder installed the cheapest components available to hit a price point on the construction bid. These OEM belts stretch, crack, and snap under loads they were never designed to sustain. OEM motors overheat because they're sized for minimum code compliance, not for the actual CFM demands of a high-volume kitchen running 14 hours a day. Spring Hill restaurant owners are discovering this the hard way, and DDAN is the company they call when it happens.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Spring Hill's rapid growth means repair demand is climbing every quarter as more restaurants open and more factory-installed components reach the end of their abbreviated service life. The GM plant's three-shift operation means nearby restaurants serve breakfast, lunch, and dinner crowds — their exhaust systems never get a break. We upgrade these failing factory components to commercial-grade parts rated for the actual cooking loads Spring Hill kitchens generate, eliminating the premature failure cycle and giving owners equipment they can rely on.
        </p>
      </div>
    </div>
  </section>

  <!-- WHAT WE REPAIR — FANS FIRST -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        What We Repair — Fans First
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-8 max-w-4xl reveal-child">
        Factory-installed exhaust fan components are the most common failure we see in Spring Hill's new restaurant buildings:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        {[
          { title: 'Motor Replacement', desc: 'Upgrade from undersized OEM motors to commercial-grade units rated for your actual cooking volume and runtime.' },
          { title: 'Belt Replacement & Tensioning', desc: 'Factory belts stretch and snap fast. We install heavy-duty notched V-belts with proper tensioning for lasting performance.' },
          { title: 'Impeller & Fan Wheel Service', desc: 'Grease-caked impellers cleaned, rebalanced, or replaced. Even new fans accumulate grease faster than owners expect.' },
          { title: 'Bearing Replacement', desc: 'Shaft bearings and pillow blocks. Cheap OEM bearings run hot under real loads and seize prematurely.' },
          { title: 'VFD & Speed Control Repair', desc: 'Variable frequency drives that control fan speed. Electrical surges in new construction areas can damage VFDs.' },
          { title: 'Full Fan Replacement', desc: 'When the builder installed the wrong unit entirely, we replace with a properly sized fan for your system.' },
        ].map((card) => (
          <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-xl p-6 transition-all duration-300 reveal-child">
            <h3 class="font-heading text-white text-lg font-semibold mb-2">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-sm leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
      <h3 class="font-heading text-[#FF5E15] text-xl font-semibold mb-4 reveal-child">Beyond Fans — Full Exhaust System Repair</h3>
      <ul class="space-y-3 max-w-3xl">
        <li class="check-item reveal-child">Ductwork damage, disconnections, and failed seams</li>
        <li class="check-item reveal-child">Hood canopy structural repair and hinge replacement</li>
        <li class="check-item reveal-child"><a href="/exhaust-fan-hinge-kit-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hinge kit installation</a> for fans without proper service access</li>
        <li class="check-item reveal-child"><a href="/restaurant-fire-suppression-systems/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Fire suppression system</a> link and nozzle replacement</li>
        <li class="check-item reveal-child"><a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Belt and motor repair</a> — our most-requested Spring Hill service</li>
      </ul>
    </div>
  </section>

  <!-- EMERGENCY CALLOUT -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="bg-black border-2 border-[#FF5E15] rounded-2xl p-8 md:p-12 text-center reveal-child">
        <h2 class="font-heading text-white text-2xl md:text-3xl font-bold mb-3">Fan Died? Kitchen Shut Down? We're On It.</h2>
        <p class="text-[#FF5E15] font-heading text-lg font-semibold mb-6">24/7 Emergency Dispatch for Spring Hill</p>
        <a href={`tel:${business.phoneRaw}`} class="inline-block text-white font-display text-3xl md:text-5xl font-bold tracking-wide hover:text-[#FF5E15] transition-all duration-300">
          {business.phone}
        </a>
        <p class="text-[#D4D4D4] font-body text-base mt-4">Same-day motor and belt replacement. We carry common parts on every truck.</p>
      </div>
    </div>
  </section>

  <!-- COMMON FAILURES IN SPRING HILL -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Exhaust Fan Failures in Spring Hill
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Cheap OEM fan belts and motors installed by builders snap and burn out far earlier than restaurant owners expect. These factory components are selected by general contractors who prioritize construction budget over long-term kitchen performance. The belts are standard smooth V-belts instead of the heavy-duty notched belts that commercial cooking loads demand. The motors are sized to minimum code — just enough to pass the initial inspection — not for the actual grease volume and runtime hours a busy kitchen generates. When these components fail at 18 months instead of the 5 years the owner expected, the result is a dead fan, a hot kitchen, and an emergency call to DDAN for <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">belt and motor repair</a>.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Rapid grease saturation on pristine TPO roofs at The Crossings is Spring Hill's second major failure pattern. Corporate landlords who own these new shopping centers enforce strict property appearance standards — any grease staining on the white TPO membrane triggers lease violation notices and penalty charges. When a fan seal degrades or a grease containment pad saturates (which happens fast in high-volume kitchens), grease escapes onto that bright white roof and becomes immediately visible. A single failed fan component can cascade into a containment failure, a roof staining incident, and a lease dispute that costs the restaurant owner far more than the original repair would have.
        </p>
      </div>
    </div>
  </section>

  <!-- COMPLIANCE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Spring Hill Exhaust Repair Compliance — Fire Department & Water
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          The Spring Hill Fire Department is rigorous on new-build inspections. Because the majority of Spring Hill's commercial kitchens are in recently constructed buildings, inspectors expect every system to be in near-perfect condition. A non-functional exhaust fan in a building that's only a few years old raises immediate red flags — it signals deferred maintenance in a system that shouldn't need it yet. Inspectors check fan operation, belt condition, hinge kit functionality, access panel presence, and fire suppression integrity. Failing any of these in a new building can trigger accelerated re-inspection schedules.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Spring Hill Water enforces strict F.O.G. (Fats, Oils, and Grease) regulations to protect the city's growing water infrastructure. Grease discharge from failing rooftop containment systems enters storm drains and creates downstream treatment problems. In a rapidly growing city investing heavily in water infrastructure, grease violations are taken seriously and carry significant penalties.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Read our complete guide to <a href="/nfpa-code-96-standards/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">NFPA 96 compliance standards</a> to understand the full scope of what inspectors evaluate.
        </p>
      </div>
    </div>
  </section>

  <!-- PROOF POINT -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="border-l-4 border-[#FF5E15] bg-[#111111] p-6 rounded-r-xl max-w-3xl reveal-child">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed italic">
          "A brand-new fast-casual franchise in Spring Hill had their cheap, factory-installed exhaust fan belt snap right before the Friday dinner rush. DDAN arrived within the hour, upgraded the unit to a heavy-duty notched V-belt, and calibrated the motor tension, allowing the kitchen to reopen safely with minimal downtime."
        </p>
      </div>
    </div>
  </section>

  <!-- BRANDS WE SERVICE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Exhaust Fan Brands We Service
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-6 max-w-4xl reveal-child">
        We repair and replace components for every major commercial exhaust fan manufacturer installed in Spring Hill kitchens:
      </p>
      <div class="flex flex-wrap gap-4 reveal-child">
        {['CaptiveAire', 'Loren Cook', 'Canarm', 'NAKS', 'EconAir', 'Greenheck', 'Accurex', 'PennBarry', 'Dayton', 'Fantech'].map((brand) => (
          <span class="bg-[#1A1A1A] border border-[#333] text-[#D4D4D4] font-body text-sm px-4 py-2 rounded-lg">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Spring Hill Exhaust Fan Repair Service Area
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN provides 24/7 exhaust fan repair across all of Spring Hill, including The Crossings, Port Royal Road, Main Street, and the commercial corridors along US-31. Whether your restaurant is in a brand-new shopping center or an established location, we respond to emergency fan failures day and night with common parts on every truck.
        </p>
        <div class="space-y-3 reveal-child">
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also in Spring Hill:</span>
            <a href="/cleaning/spring-hill-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hood Cleaning</a> &middot;
            <a href="/parts-installation/spring-hill-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Parts & Installation</a>
          </p>
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also serving nearby:</span>
            <a href="/repair/brentwood-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Brentwood</a>,
            <a href="/repair/columbia-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Columbia</a>, and
            <a href="/repair/thompsons-station-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Thompsons Station</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Spring Hill Exhaust Fan Repair FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-[#111111] border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-[#111111] rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed" set:html={faq.a}></p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CITY-SPECIFIC URGENCY + TRUCK CTA -->
  <section class="bg-[#111111] py-12 md:py-16 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <p class="text-[#D4D4D4] font-body text-lg leading-relaxed text-center max-w-3xl mx-auto reveal-child">
        Steady year-round demand as new restaurant owners discover the limitations of factory-installed exhaust equipment. Don't wait for a belt to snap during the dinner rush — call now and let us upgrade your system before it fails.
      </p>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
