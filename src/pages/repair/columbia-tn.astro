---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: "Can you clean the exhaust systems in historic Columbia buildings?",
    a: "Yes. Columbia's revitalized downtown square features historic buildings with winding, non-standard grease ductwork hidden behind drop ceilings and original walls. Our crews are trained to navigate these complex systems — accessing concealed duct runs, cleaning to bare metal, and repairing any deficiencies we find along the way. We work carefully in preservation-sensitive environments without damaging historic materials.",
  },
  {
    q: "Do you repair broken restaurant exhaust fans in Columbia?",
    a: "Absolutely. Exhaust fan repair is our most common service call in Columbia. We handle motor replacements, belt swaps, bearing repairs, impeller rebalancing, hinge kit installations, and wiring diagnostics. We stock parts for all major brands and resolve most fan problems on the first visit — including the older, non-standard units found along Carmack Boulevard.",
  },
  {
    q: "Why do I need a rooftop grease containment system?",
    a: "NFPA 96 requires rooftop grease containment to prevent grease discharge from exhaust fans onto your roof and into storm drains. Without proper containment, grease damages roofing materials, creates fire hazards, and can trigger environmental citations from local authorities. Columbia's growing inspection focus on new restaurant builds makes proper containment essential from day one.",
  },
  {
    q: "How long does a typical exhaust fan repair take?",
    a: "Most common repairs — belt replacement, motor swap, bearing change — take 1-2 hours on-site. For Columbia's historic buildings with difficult access, repairs may take longer due to non-standard mounting configurations. We always provide a time estimate before starting work.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
      "name": business.name,
      "image": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/images/hero/hero-3.jpg`,
      "telephone": business.phone,
      "email": business.email,
      "url": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev',
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": "Mt. Juliet",
        "addressRegion": "TN",
        "postalCode": "37122",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Columbia, TN"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": business.googleReviewRating,
        "reviewCount": "51"
      }
    },
    {
      "@type": "Service",
      "name": "Commercial Exhaust Fan Repair",
      "provider": { "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business` },
      "areaServed": {
        "@type": "City",
        "name": "Columbia, TN"
      },
      "description": "Exhaust fan repair for Columbia's revitalized downtown restaurants and Carmack Blvd diners. Maury County compliant. 24/7 service."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev' },
        { "@type": "ListItem", "position": 2, "name": "Hood Repair", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/repair/` },
        { "@type": "ListItem", "position": 3, "name": "Columbia, TN" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Columbia Muletown Kitchen Exhaust Fan Repair | DDAN"
  description="Exhaust fan repair for Columbia's revitalized downtown restaurants and Carmack Blvd diners. Maury County compliant. 24/7 service. (615) 881-6968."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/hero-3.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/repair/" class="hover:text-[#FF5E15] transition-all duration-300">Hood Repair</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Columbia, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Columbia, TN Kitchen Exhaust Fan Repair — <span class="text-[#FF5E15]">Muletown's Trusted Team</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Muletown's revitalized downtown and Carmack Boulevard — repairing every fan system in Maury County
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Why Columbia's Growing Food Scene Needs Expert Repair
      </h2>
      <div class="grid md:grid-cols-2 gap-10 items-start">
        <div>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Columbia — known as Muletown — is experiencing a culinary renaissance. The revitalized downtown square is attracting craft breweries, artisan cafes, and Southern comfort food restaurants that are transforming this Maury County seat into a dining destination. But behind the charming storefronts lie historic buildings with winding, non-standard grease ductwork hidden behind drop ceilings. These aren't modern, purpose-built restaurant spaces — they're 100-year-old commercial buildings retrofitted for food service, and every exhaust system tells a different story of improvised routing and creative problem-solving.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Carmack Boulevard's older diners run upblast fans that haven't been upgraded in decades — motors that are past their useful life, belts that snap without warning, bearings grinding toward seizure. These aren't modern, easily replaceable units — they're mounted on non-standard curbs with improvised wiring that requires careful assessment before any repair. A wrong move on one of these legacy systems can cause more damage than the original failure.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Maury Regional Medical Center adds a massive institutional kitchen to the local repair demand — a high-volume operation that runs exhaust systems around the clock and cannot tolerate extended downtime. The cuisine across Columbia leans heavily into Southern comfort food, craft breweries, BBQ, and classic diners — high solid-fuel and heavy-fryer operations that produce intense grease and carbon buildup, wearing fan components faster than standard cooking styles. Motors overheat sooner. Belts degrade faster. Bearings fail earlier. Columbia's kitchens need a repair provider who understands this accelerated wear cycle.
          </p>
          <p class="text-[#FF5E15] font-heading font-semibold text-base reveal-child">
            DDAN provides 24/7 emergency exhaust fan repair across Columbia and all of Maury County — experienced crews for every system, every building, every challenge.
          </p>
        </div>
        <div class="reveal-child">
          <img
            src={`${HP}/grease-hood-cleaning-near-me-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-768x1024.jpg`}
            alt="Commercial exhaust fan repair in Columbia TN - DDAN Hood Cleaning and Repair"
            class="w-full rounded-2xl border-[3px] border-[#FF5E15]"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE REPAIR — FANS FIRST -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        What We Repair — Fans First
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Exhaust fan failures are the most common emergency call we receive from Columbia restaurants. We stock parts for all major brands and resolve most fan problems on the first visit — even the older, non-standard units found along Carmack Boulevard.
      </p>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-6 reveal-child">
        Fan repair services:
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        {[
          { title: 'Motor Replacement', desc: 'Burned-out or overheating motors replaced same-day with OEM-spec units' },
          { title: 'Belt Replacement', desc: 'Worn, cracked, or slipping belts that reduce airflow and cause squealing' },
          { title: 'Bearing Repair', desc: 'Failed bearings that cause grinding, vibration, and eventual motor seizure' },
          { title: 'Impeller Rebalancing', desc: 'Grease-clogged or damaged impeller wheels that cause dangerous vibration' },
          { title: 'Hinge Kit Installation', desc: 'Heavy-duty hinge kits for safe rooftop fan access during cleaning and maintenance' },
          { title: 'Wiring & Controls', desc: 'Damaged wiring, failed contactors, speed controllers, and relay replacements' },
        ].map((card) => (
          <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-5 transition-all duration-300 reveal-child">
            <h3 class="font-heading font-semibold text-white text-lg mb-2">{card.title}</h3>
            <p class="text-[#D4D4D4] text-sm leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Beyond fans, we also repair:
      </p>
      <ul class="space-y-3 mb-6">
        <li class="check-item reveal-child">Hood canopy damage — dented plenums, broken hinges, warped drip trays</li>
        <li class="check-item reveal-child">Ductwork issues — loose joints, failed dampers, missing <a href="/access-panel-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">access panels</a></li>
        <li class="check-item reveal-child"><a href="/restaurant-fire-suppression-systems/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Fire suppression systems</a> — nozzle replacement, line re-routing, Ansul system service</li>
        <li class="check-item reveal-child"><a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Grease containment</a> — rooftop grease box replacement, drain line repair, custom containment installation</li>
        <li class="check-item reveal-child">Make-up air units — damper repair, heating element replacement, filter service, control diagnostics</li>
      </ul>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
        Need a deeper dive into belt and motor service? See our dedicated <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">belt & motor repair</a> page. For hinge kit details: <a href="/exhaust-fan-hinge-kit-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">hinge kit installation</a>.
      </p>
    </div>
  </section>

  <!-- EMERGENCY CALLOUT -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="bg-black border-2 border-[#FF5E15] rounded-2xl p-8 md:p-12 text-center reveal-child">
        <h2 class="font-heading text-[#FF5E15] text-2xl md:text-3xl font-bold mb-4">
          24/7 Emergency Dispatch for Columbia
        </h2>
        <p class="text-[#D4D4D4] font-body text-base md:text-lg leading-relaxed mb-6 max-w-2xl mx-auto">
          Exhaust fan down during the Saturday rush? Kitchen filling with smoke in the middle of a packed lunch service? We dispatch emergency repair crews to Columbia and all of Maury County around the clock. No answering service — you get a real technician on the line.
        </p>
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-10 py-4 bg-[#FF5E15] text-white font-heading text-xl font-bold rounded hover:bg-[#E54F0D] hover:scale-95 transition-all duration-300">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          {business.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- COMMON FAILURES IN COLUMBIA -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Equipment Failures in Columbia
      </h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
          <div class="w-12 h-12 flex items-center justify-center bg-[#FF5E15] rounded-full mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.962-.833-2.732 0L4.072 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          </div>
          <h3 class="font-heading font-semibold text-white text-lg mb-3">Historic Building Access Challenges</h3>
          <p class="text-[#D4D4D4] text-sm leading-relaxed">
            Revitalized historic buildings on Columbia's downtown square often hide winding, non-standard grease ductwork behind drop ceilings. When fans fail in these systems, the repair is complicated by difficult access — you can't just open a standard curb and swap a motor when the ductwork routes through a 100-year-old ceiling. DDAN installs custom fire-rated <a href="/access-panel-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">access panels</a> throughout concealed duct runs, making both repair and future maintenance possible without tearing into the building.
          </p>
        </div>
        <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
          <div class="w-12 h-12 flex items-center justify-center bg-[#FF5E15] rounded-full mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h3 class="font-heading font-semibold text-white text-lg mb-3">Legacy Fan Systems on Carmack Blvd</h3>
          <p class="text-[#D4D4D4] text-sm leading-relaxed">
            Older diners along Carmack Boulevard frequently run upblast fans well past their rated service life. These aren't modern, easily replaceable units — they're mounted on non-standard curbs with improvised wiring that requires careful assessment before any repair. A wrong assumption about wiring configuration or curb dimensions can turn a simple <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">motor swap</a> into a much larger project. DDAN's experienced technicians assess every legacy system thoroughly before starting work.
          </p>
        </div>
        <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
          <div class="w-12 h-12 flex items-center justify-center bg-[#FF5E15] rounded-full mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 10 10-12h-9l1-10z"/></svg>
          </div>
          <h3 class="font-heading font-semibold text-white text-lg mb-3">Summer Heat & Motor Burnout</h3>
          <p class="text-[#D4D4D4] text-sm leading-relaxed">
            Humid summer months push overworked motors past their thermal limits. Columbia's combination of high-grease Southern cooking and Tennessee summer heat creates the worst-case scenario for fan motor longevity. Heavy-fryer operations and solid-fuel cooking produce intense grease and carbon buildup that insulates motor housings, trapping heat. When ambient rooftop temperatures hit 140&deg;F in July, motors that would last years in cooler climates burn out in months. DDAN's preventative <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">belt and motor service</a> catches failing components before they seize.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- LOCAL COMPLIANCE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Columbia Compliance — Maury County Fire & Growing Enforcement
      </h2>
      <div class="grid md:grid-cols-2 gap-10 items-start">
        <div>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Columbia Fire & Rescue enforces NFPA 96 standards across all commercial kitchens in Maury County. As Columbia's dining scene grows, fire inspectors are increasingly focused on ensuring new restaurant builds meet code from day one — not just during annual inspections, but during the initial build-out and every modification afterward. A failed exhaust fan, a disconnected fire suppression line, or missing access panels are violations that can delay openings and shut down operating kitchens.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Columbia's growing industrial parks are adding commercial kitchen demand from corporate cafeterias and institutional food service. These facilities face the same NFPA 96 requirements as restaurants but often lack the maintenance relationships that established operators have built. Maury Regional Medical Center's massive kitchen operation sets the standard for institutional compliance in the county — and inspectors hold every commercial kitchen to similar standards.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            The revitalization of downtown Columbia creates a unique compliance challenge: historic buildings that were never designed for commercial kitchen exhaust. Retrofitted systems in these structures require creative solutions that satisfy both fire code and historic preservation requirements. DDAN has the experience to navigate both — repairing and upgrading exhaust systems in Columbia's oldest buildings while keeping them fully NFPA 96 compliant.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
            Learn more about the standards we follow: <a href="/nfpa-code-96-standards/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">NFPA 96 Code Standards</a>
          </p>
        </div>
        <div class="bg-[#1A1A1A] border border-[#333] rounded-2xl p-6 reveal-child">
          <h3 class="font-heading text-[#FF5E15] text-xl font-bold mb-4">Columbia Enforcement Summary</h3>
          <ul class="space-y-3">
            <li class="check-item">Columbia Fire & Rescue — NFPA 96 enforcement across Maury County</li>
            <li class="check-item">Growing focus on new restaurant builds meeting code from day one</li>
            <li class="check-item">Historic downtown retrofits require creative compliance solutions</li>
            <li class="check-item">Industrial park growth adding institutional kitchen demand</li>
            <li class="check-item">Failed equipment triggers code violations and potential kitchen shutdowns</li>
            <li class="check-item">DDAN documentation satisfies fire inspectors and health department requirements</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PROOF POINT -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="border-l-4 border-[#FF5E15] bg-[#111111] p-6 rounded-r-xl reveal-child">
        <p class="text-[#D4D4D4] font-body text-base md:text-lg leading-relaxed italic">
          "A popular new restaurant opening on the historic Columbia square failed their initial fire inspection because their concealed ductwork lacked access points. DDAN installed custom fire-rated access panels throughout the hidden duct runs, brought the entire system up to bare-metal cleanliness, and got the restaurant their compliance certificate in time for opening day."
        </p>
        <p class="text-[#FF5E15] font-heading font-semibold text-sm mt-4">— DDAN Hood Cleaning and Repair, Columbia Service Area</p>
      </div>
    </div>
  </section>

  <!-- BRANDS WE SERVICE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto text-center">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Brands We Service
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-8 reveal-child">
        We carry parts and have direct experience repairing exhaust systems from every major commercial kitchen ventilation manufacturer.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        {['CaptiveAire', 'Loren Cook', 'Canarm', 'NAKS', 'EconAir', 'Greenheck', 'Accurex', 'PennBarry', 'Dayton', 'Fantech'].map((brand) => (
          <span class="bg-[#1A1A1A] border border-[#333] rounded-xl px-5 py-3 text-[#D4D4D4] font-heading font-medium text-sm reveal-child">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto text-center">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Columbia Service Area
