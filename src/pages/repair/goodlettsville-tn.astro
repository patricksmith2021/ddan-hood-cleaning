  <!-- SECTION 5: FAN REPAIRS — 6 CARDS -->
  <section id="fan-motors" class="bg-[#111111] py-16 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] font-bold text-2xl md:text-3xl text-center mb-4 reveal-child">Exhaust Fan Repairs for Goodlettsville Restaurants</h2>
      <div class="bg-[#FF5E15] text-white text-center text-sm md:text-base font-heading font-bold uppercase tracking-wide py-3 px-4 rounded-lg mb-10 reveal-child">GOODLETTSVILLE'S EXHAUST FAN REPAIR SERVICE — ALL BRANDS, ALL SIZES</div>
