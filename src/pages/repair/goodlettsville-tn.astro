---
import BaseLayout from '../../layouts/BaseLayout.astro';
import business from '../../data/business.json';

const faqs = [
  { q: "Why do Goodlettsville fast-food exhaust fans fail so often?", a: "Goodlettsville sits at the I-65 interchange with one of Middle Tennessee's densest concentrations of fast-food restaurants. Many operate 24/7 to serve interstate travelers, meaning exhaust fans never get a rest cycle. Continuous operation shreds OEM belts and burns through motor windings far faster than typical schedules." },
  { q: "How quickly can DDAN respond to an emergency fan failure in Goodlettsville?", a: "Goodlettsville is one of our closest service areas from our Mt. Juliet base. We provide 24/7 emergency dispatch and carry common fan motors, belts, and bearings on every truck. Most Goodlettsville emergency calls receive same-day response — often within 30-40 minutes." },
  { q: "Can you protect white TPO roofs from grease during repairs?", a: "Yes. Many of Goodlettsville's newer commercial buildings around Rivergate have white TPO roof membranes. Corporate landlords issue massive fines for grease staining. During every fan repair, we inspect and service grease containment to prevent runoff." },
  { q: "Do you service restaurants in both Davidson and Sumner County?", a: "Yes. Goodlettsville straddles both counties. We provide documentation that satisfies either county's fire marshal — no confusion, no gaps in compliance." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/repair/goodlettsville-tn/`,
      "address": { "@type": "PostalAddress", "streetAddress": business.address.street, "addressLocality": business.address.city, "addressRegion": business.address.state, "postalCode": business.address.zip, "addressCountry": "US" },
      "areaServed": { "@type": "City", "name": "Goodlettsville, TN" },
      "priceRange": "$$"
    },
    { "@type": "Service", "name": "Commercial Kitchen Exhaust Fan Repair", "provider": { "@type": "LocalBusiness", "name": business.name }, "areaServed": { "@type": "City", "name": "Goodlettsville, TN" }, "description": "24/7 emergency exhaust fan motor and belt repair for Goodlettsville commercial kitchens. I-65 corridor fast-food specialists." },
    { "@type": "BreadcrumbList", "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/` },
      { "@type": "ListItem", "position": 2, "name": "Hood Repair", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/repair/` },
      { "@type": "ListItem", "position": 3, "name": "Goodlettsville, TN" }
    ]},
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Fast Hood Repair Near Goodlettsville | DDAN"
  description="24/7 emergency exhaust fan repair in Goodlettsville. I-65 corridor specialists. Same-day motor and belt replacement. Call (615) 881-6968."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- SECTION 1: HERO -->
  <section class="min-h-[400px] md:min-h-[550px] flex items-center justify-center" style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.3) 100%), url('/images/hero/rooftop-exhaust-fan.jpg') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <p class="text-[#FF5E15] font-heading font-bold text-xs md:text-sm tracking-widest uppercase mb-4">DDAN HOOD CLEANING AND REPAIR</p>
      <h1 class="font-display text-white text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">Emergency Exhaust Fan Repair in <span class="text-[#FF5E15]">Goodlettsville, TN</span></h1>
      <p class="text-gray-200 font-body text-lg md:text-xl max-w-2xl mx-auto mb-6">I-65 corridor fans run 24/7. When they fail, we are there — same-day motor and belt replacement from local stock.</p>
      <p class="text-white font-heading font-bold text-base md:text-lg mb-2">24/7 Emergency Dispatch — I-65 Corridor Exhaust Fan Specialists</p>
      <div class="w-20 h-1 bg-[#FF5E15] mx-auto mt-3 mb-8"></div>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5E15] text-white font-heading font-bold text-lg rounded-lg hover:scale-95 transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
