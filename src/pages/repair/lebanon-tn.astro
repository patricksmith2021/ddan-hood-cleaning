---
import BaseLayout from '../../layouts/BaseLayout.astro';
import business from '../../data/business.json';

const faqs = [
  { q: 'Can you clean exhaust systems for Lebanon BBQ restaurants and smokers?', a: 'Yes. Wood-fired smokers and heavy BBQ operations produce a tough carbon creosote that standard pressure washing cannot remove. Our crews use specialized heavy-duty scrapers and chemical treatments to strip your entire exhaust system down to bare metal, drastically reducing your fire risk.' },
  { q: 'My Lebanon restaurant\'s exhaust fan is vibrating loudly. What is wrong?', a: 'Severe vibration is usually caused by heavy grease buildup throwing the fan impeller off balance, or a failing motor bearing. Left unchecked, this will destroy the fan. DDAN will immediately diagnose the issue, scrape the fan blades clean, and replace any worn belts or bearings.' },
  { q: 'Do you install hinge kits on commercial exhaust fans in Lebanon?', a: 'Absolutely. NFPA 96 code requires that upblast exhaust fans be equipped with hinge kits so they can be safely tilted open for cleaning without damaging the roof or the fan wiring. We install heavy-duty hinge kits on rooftops across Lebanon.' },
  { q: 'What is the typical cost of an exhaust fan motor replacement?', a: 'Most common motor replacements range from $250 to $600 depending on horsepower, phase type, and motor enclosure. We provide upfront pricing after diagnosis — no surprises.' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/repair/lebanon-tn/`,
      "address": { "@type": "PostalAddress", "streetAddress": business.address.street, "addressLocality": business.address.city, "addressRegion": business.address.state, "postalCode": business.address.zip, "addressCountry": "US" },
      "areaServed": { "@type": "City", "name": "Lebanon, TN" },
      "priceRange": "$$"
    },
    { "@type": "Service", "name": "Commercial Kitchen Exhaust Fan Repair", "provider": { "@type": "LocalBusiness", "name": business.name }, "areaServed": { "@type": "City", "name": "Lebanon, TN" }, "description": "24/7 emergency exhaust fan motor and belt repair for Lebanon commercial kitchens. Same-day service from local parts stock." },
    { "@type": "BreadcrumbList", "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/` },
      { "@type": "ListItem", "position": 2, "name": "Hood Repair", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/repair/` },
      { "@type": "ListItem", "position": 3, "name": "Lebanon, TN" }
    ]},
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Professional Exhaust Fan Repair Lebanon TN | DDAN"
  description="24/7 emergency exhaust fan repair in Lebanon TN. Same-day motor and belt replacement. All brands serviced. Call (615) 881-6968."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section class="min-h-[400px] md:min-h-[550px] flex items-center justify-center" role="img" aria-label="Kitchen exhaust fan repair in Lebanon, TN — DDAN Hood Cleaning and Repair" style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.3) 100%), url('/images/city/hood-repair-lebanon.webp') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <p class="text-[#FF5E15] font-heading font-bold text-xs md:text-sm tracking-widest uppercase mb-4">DDAN HOOD CLEANING AND REPAIR</p>
      <h1 class="font-display text-white text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">Emergency Exhaust Fan Repair in <span class="text-[#FF5E15]">Lebanon, TN</span></h1>
      <p class="text-gray-200 font-body text-lg md:text-xl max-w-2xl mx-auto mb-6">Need fan repair in Lebanon? BBQ smokers and wood-fired kitchens produce carbon that seizes bearings and shreds belts. We carry the heavy-duty replacements for same-day service.</p>
      <p class="text-white font-heading font-bold text-base md:text-lg mb-2">24/7 Emergency Dispatch — Same-Day Motor and Belt Replacement</p>
      <div class="w-20 h-1 bg-[#FF5E15] mx-auto mt-3 mb-8"></div>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5E15] text-white font-heading font-bold text-lg rounded-lg hover:scale-95 transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
