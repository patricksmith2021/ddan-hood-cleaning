---
import BaseLayout from '../layouts/BaseLayout.astro';
import business from '../data/business.json';
import InlineCTA from '../components/InlineCTA.astro';
import TruckCTA from '../components/TruckCTA.astro';

const siteUrl = import.meta.env.SITE || 'https://ddanhoodservices.com';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${siteUrl}/access-panel-installation/`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": business.address.city,
        "addressRegion": business.address.state,
        "postalCode": business.address.zip,
        "addressCountry": "US"
      },
      "areaServed": { "@type": "State", "name": "Tennessee" },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "serviceType": "Grease Duct Access Panel Installation",
      "provider": { "@type": "LocalBusiness", "name": business.name },
      "areaServed": { "@type": "State", "name": "Tennessee" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Access Panel Installation" }
      ]
    }
  ]
};
---

<BaseLayout
  title="Access Panel Installation - DDAN Hood Cleaning and Repair"
  description="NFPA 96 access panel installation for safe duct cleaning and inspection. Stay compliant with UL-listed, fire-rated access doors from DDAN."
>
<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <!-- SECTION 1: HERO -->
  <section role="img" aria-label="Commercial grease duct access panel installation — DDAN Hood Cleaning and Repair" class="min-h-[400px] md:min-h-[550px] flex items-center justify-center" style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.3) 100%), url('/images/services/access-panel-installation-service.webp') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <p class="text-[#FF5E15] font-heading font-bold text-xs md:text-sm tracking-widest uppercase mb-4">DDAN HOOD CLEANING AND REPAIR</p>
      <h1 class="font-display text-white text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">Kitchen Ventilation <span class="text-[#FF5E15]">Access Panel</span> Installation</h1>
      <p class="text-gray-200 font-body text-lg md:text-xl max-w-2xl mx-auto mb-6">NFPA 96 requires access panels for safe, code-compliant duct cleaning. We install and upgrade panels for all duct sizes and types.</p>
      <p class="text-white font-heading font-bold text-base md:text-lg mb-2">Code-Compliant Access • Clean Ducts Safely • Prevent Fires and Fines</p>
      <div class="w-20 h-1 bg-[#FF5E15] mx-auto mt-3 mb-8"></div>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5E15] text-white font-heading font-bold text-lg rounded-lg transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
          Call Now: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-[#FF5E15] text-[#FF5E15] font-heading font-bold text-lg rounded-lg hover:bg-[#FF5E15] hover:text-white transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 320 512"><path d="M272 0H48C21.5 0 0 21.5 0 48v416c0 26.5 21.5 48 48 48h224c26.5 0 48-21.5 48-48V48c0-26.5-21.5-48-48-48zM160 480c-17.7 0-32-14.3-32-32s14.3-32 32-32 32 14.3 32 32-14.3 32-32 32zm112-108c0 6.6-5.4 12-12 12H60c-6.6 0-12-5.4-12-12V60c0-6.6 5.4-12 12-12h200c6.6 0 12 5.4 12 12v312z"/></svg>
          Request Service Online
        </button>
      </div>
      <div class="flex justify-center items-center gap-6 mt-8">
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/google-white-logo-1024x337.png" alt="Google" width="1024" height="337" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/facebook-logo-white-full-transparent-1024x341.png" alt="Facebook" width="1024" height="341" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/YELP_BIG.D-5a67c069-1024x392.png" alt="Yelp" width="1024" height="392" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BREADCRUMB STRIP -->
  <div class="bg-[#0A0A0A] py-2 px-5">
    <div class="max-w-[1200px] mx-auto">
      <nav class="flex items-center gap-2 text-sm font-heading text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF5E15] transition-colors">Home</a>
        <span class="text-[#FF5E15]">/</span>
        <span class="text-gray-300">Access Panel Installation</span>
      </nav>
    </div>
  </div>

  <!-- Main Content -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">

      <div class="reveal">
        <p class="font-heading font-semibold text-lg text-white mb-4 reveal-child">Code-Compliant Access. Clean Ducts Safely. Prevent Fires or Fines.</p>
        <h2 class="section-headline reveal-child">What Access Panels Do for Your Kitchen</h2>
        <p class="text-[#D4D4D4] mb-4 reveal-child">Access panels aren't optional — they're required for safe, code-compliant duct cleaning. These panels are installed directly into your grease ductwork and provide safe entry points for cleaning crews to reach interior sections. Without them, your system can't be fully cleaned, and grease buildup becomes a major fire hazard.</p>
        <p class="text-[#D4D4D4] mb-4 reveal-child">NFPA 96 requires access panels:</p>
        <ul class="space-y-2 mb-4">
          <li class="check-item reveal-child">No more than 12 feet on horizontal duct runs</li>
          <li class="check-item reveal-child">At every change of direction</li>
          <li class="check-item reveal-child">Near duct-mounted fans or bends</li>
        </ul>
        <p class="text-[#D4D4D4] mb-6 reveal-child">If your kitchen exhaust ducts lack proper access, DDAN Hood Cleaning and Repair can fix that. We install and upgrade access panels that meet all code and fire safety requirements.</p>
      </div>

      <div class="reveal mt-8">
        <h2 class="section-headline reveal-child">Signs You Need Access Panel Installation or Repair</h2>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Your ducts have no visible access panels or only one at the base of the hood</li>
          <li class="check-item reveal-child">Cleaning crews can't reach interior duct sections and skip full cleanings</li>
          <li class="check-item reveal-child">Grease streaks or buildup along the exterior of ducts</li>
          <li class="check-item reveal-child">You recently failed or nearly failed inspection due to access or cleaning limitations</li>
          <li class="check-item reveal-child">Your panels are damaged, leaking, or missing seals</li>
        </ul>
        <p class="text-[#D4D4D4] mb-6 reveal-child">Poor access is one of the biggest causes of dangerous grease buildup inside kitchen exhaust systems.</p>
      </div>

      <InlineCTA headline="Request a Quote for Access Panel Installation" />

      <div class="reveal mt-8">
        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Commercial Grease Duct Access Panel Installation</h3>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">NFPA 96-compliant placement and spacing for full cleaning access</li>
          <li class="check-item reveal-child">Liquid-tight installation to prevent grease leaks and fire hazards</li>
          <li class="check-item reveal-child">Fire-rated panels that withstand high temps and resist warping</li>
          <li class="check-item reveal-child">Low-profile and custom-fit options for tight duct spaces</li>
          <li class="check-item reveal-child">Sealed with fire-safe gaskets and riveted hardware for long-term performance</li>
        </ul>
        <p class="text-[#D4D4D4] mb-6 reveal-child">We install access panels for all duct sizes and types — including welded, spiral, and single-wall ducts.</p>
      </div>

      <div class="reveal mt-8">
        <h2 class="section-headline reveal-child">Why It Matters: Grease Fire Prevention</h2>
        <p class="text-[#D4D4D4] mb-4 reveal-child">Without access panels, grease-laden vapor builds up where you can't reach it. Over time, this layer of flammable residue becomes a major fire risk.</p>
        <p class="text-[#D4D4D4] mb-4 reveal-child">Code-compliant access means:</p>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Cleaner ducts with full access to interior walls</li>
          <li class="check-item reveal-child">Lower fire risk and insurance liability</li>
          <li class="check-item reveal-child">Easier, faster, and cheaper cleaning over time</li>
          <li class="check-item reveal-child">Higher chance of passing inspections without delays or shutdowns</li>
        </ul>
        <p class="text-[#D4D4D4] mb-6 reveal-child">A few small access doors can prevent thousands in fines, shutdowns, or fire damage.</p>
      </div>

    </div>
  </section>

  <!-- Split text/image section -->
  <section class="bg-[#1A1A1A] py-12 md:py-16 lg:py-20 px-5">
    <div class="max-w-[1200px] mx-auto reveal">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="section-headline reveal-child">Installation Timeline, Cost & Availability</h2>
          <ul class="space-y-2 mb-6">
            <li class="check-item reveal-child">Install Time: 1-2 hours per panel</li>
            <li class="check-item reveal-child">Typical Cost: $250-$600 per panel installed</li>
            <li class="check-item reveal-child">Emergency and after-hours installation available to avoid downtime</li>
          </ul>
          <p class="text-[#D4D4D4] mb-6 reveal-child">We provide free quotes and code reviews to assess exactly what you need.</p>
          <button type="button" class="btn-primary popup-trigger reveal-child">Request Service Online</button>
        </div>
        <div class="reveal-child">
          <img
            src="/images/services/access-panel-split.jpg"
            alt="access panel installation on grease duct - DDAN Hood Cleaning and Repair"
            class="w-full rounded"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>
