---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'What exhaust fan parts do Portland industrial kitchens need most?',
    a: 'Portland\'s manufacturing workforce drives massive lunch rushes that push aging exhaust systems past their limits. The most frequently replaced parts are fan motors (burned out from continuous peak-load operation), fan belts (shredded from high-RPM duty cycles), and bearings (seized from heat accumulation during non-stop summer operation). Industrial commissaries also need heavy-duty 3-phase motors and oversized impellers that generic suppliers don\'t stock.',
  },
  {
    q: 'How quickly can DDAN deliver and install parts in Portland?',
    a: `We carry common fan motors, belts, bearings, hinge kits, and grease containment components on every truck. Most Portland emergency parts installations are completed same-day. For specialty industrial-grade components, we source and install within 48 hours. Call ${business.phone} any time — 24/7 emergency dispatch for Sumner County.`,
  },
  {
    q: 'Why is my exhaust fan rattling so loudly?',
    a: 'Severe rattling typically means the fan blades are coated in hardened grease, throwing the impeller out of balance, or the motor bearings are failing from heavy use. Left unchecked, the vibration destroys the fan housing and can damage roofing materials. We scrape the impeller clean, replace worn bearings, and rebalance the entire assembly.',
  },
  {
    q: 'Can you deliver parts near the Kentucky border?',
    a: 'Yes. Portland sits near the Tennessee-Kentucky state line, and we service the entire area. Whether your restaurant or industrial commissary is on Highway 109, near the manufacturing parks, or right at the border, DDAN delivers and installs exhaust parts with the same response time as any other Sumner County location.',
  },
];

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev',
      "image": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/images/logo.png`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": "Mt. Juliet",
        "addressRegion": "TN",
        "postalCode": "37122",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Portland",
        "addressRegion": "TN"
      },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "serviceType": "Commercial Kitchen Exhaust Parts & Installation",
      "provider": { "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business` },
      "areaServed": {
        "@type": "City",
        "name": "Portland",
        "addressRegion": "TN"
      },
      "description": "Industrial kitchen exhaust parts and installation for Portland's manufacturing corridor. Heavy-duty motors, belts, and bearings for high-volume operations near the Kentucky border."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev' },
        { "@type": "ListItem", "position": 2, "name": "Parts & Installation", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/parts/` },
        { "@type": "ListItem", "position": 3, "name": "Portland, TN", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/parts/portland-tn/` }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="Restaurant Exhaust Parts Near Portland | DDAN"
  description="Industrial kitchen exhaust parts for Portland's manufacturing corridor. Heavy-duty motors, belts, bearings, hinge kits. Same-day installation. (615) 881-6968."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/hero-3.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/parts/" class="hover:text-[#FF5E15] transition-all duration-300">Parts & Installation</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Portland, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Portland Industrial Kitchen <span class="text-[#FF5E15]">Exhaust Parts</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Heavy-duty motors, belts, and bearings for the kitchens feeding Portland's manufacturing workforce
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUE PROP BANNER -->
  <section class="bg-[#111111] py-8 px-5 border-b border-[#333] reveal">
    <div class="max-w-[1280px] mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { icon: '⚡', label: 'Same-Day Parts' },
        { icon: '🔧', label: 'Expert Installation' },
        { icon: '📋', label: 'NFPA 96 Compliant' },
        { icon: '🕐', label: '24/7 Emergency' },
      ].map((item) => (
        <div class="flex flex-col items-center gap-2 reveal-child">
          <span class="text-2xl">{item.icon}</span>
          <span class="text-[#D4D4D4] font-heading text-sm font-semibold">{item.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Why Portland's Manufacturing Kitchens Destroy Exhaust Parts
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Portland's dining scene is built to feed an industrial workforce. Massive manufacturing and logistics hubs near the Kentucky border drive concentrated, high-volume lunch rushes that push aging exhaust fan motors to their breaking point. Restaurants and industrial commissaries along Highway 109 run their fryers and grills relentlessly during peak hours, producing massive amounts of vaporized grease and demanding maximum airflow from equipment that was never sized for this kind of punishment.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Traditional Southern diners — the backbone of Portland's food scene — present a different parts challenge. Years of heavy frying produce thick, hardened grease deposits that coat impellers and throw fans out of balance. Older buildings often have outdated ductwork with no access points, making it impossible to service the system without installing fire-rated access panels first. When the Portland Fire Department shows up for an NFPA 96 inspection and finds inaccessible ductwork, the remediation order follows immediately.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN sources and installs the heavy-duty commercial parts that actually survive Portland's demanding environment — heat-rated 3-phase motors, commercial-grade notched V-belts, sealed high-heat bearings, and the fire-rated access panels that bring older systems into compliance. Every installation includes full documentation for the Portland Fire Department.
        </p>
      </div>
    </div>
  </section>

  <!-- EXHAUST FANS (MAIN SECTION) -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Exhaust Fan Parts — Heavy-Duty Components for Portland's Volume
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-8 max-w-4xl reveal-child">
        Portland's industrial lunch rushes and aging diner infrastructure create constant demand for robust replacement parts:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        {[
          { title: 'Heavy-Duty Fan Motors', desc: 'Heat-rated 3-phase motors that survive Portland\'s punishing lunch-rush duty cycles. Industrial commissaries need motors rated for higher CFM than standard restaurant equipment.' },
          { title: 'Commercial Fan Belts', desc: 'Notched V-belts that resist the rapid stretching and snapping caused by concentrated peak-hour operation. Proper tensioning included with every installation.' },
          { title: 'Bearings & Pillow Blocks', desc: 'Sealed high-heat bearings that resist seizure during summer rooftop temperatures. Portland\'s hottest months are when overworked motors and bearings finally fail.' },
          { title: 'Impellers & Fan Wheels', desc: 'Years of heavy Southern frying coat impellers with hardened grease, destroying balance. We clean or replace and rebalance the entire assembly.' },
          { title: 'Hinge Kits', desc: 'Many older Portland rooftop fans lack the NFPA 96 required hinge kits. We retrofit to standard curbs so technicians can safely access the fan without damaging the roof.' },
          { title: 'Fire-Rated Access Panels', desc: 'Older Portland diners have concealed ductwork with no inspection access. Fire-rated panels bring the system into compliance without altering the building structure.' },
        ].map((card) => (
          <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-xl p-6 transition-all duration-300 reveal-child">
            <h3 class="font-heading text-white text-lg font-semibold mb-2">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-sm leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OTHER PARTS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Beyond Fans — Complete Exhaust System Parts
      </h2>
      <ul class="space-y-3 max-w-3xl">
        <li class="check-item reveal-child"><a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Grease containment systems</a> — rooftop pads, boxes, and high-capacity catchers</li>
        <li class="check-item reveal-child">Fire-rated <a href="/access-panel-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">duct access panels</a> — essential for Portland's older diner ductwork</li>
        <li class="check-item reveal-child">Baffle filters, mesh filters, and spark arrestor screens</li>
        <li class="check-item reveal-child"><a href="/restaurant-fire-suppression-systems/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Fire suppression</a> links, nozzles, and fusible elements</li>
        <li class="check-item reveal-child">Duct clamps, transitions, and cleanout ports</li>
        <li class="check-item reveal-child">Speed controllers and VFD units for industrial applications</li>
        <li class="check-item reveal-child">Hood light fixtures and make-up air dampers</li>
      </ul>
    </div>
  </section>

  <!-- INSTALLATION UPSELL -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="bg-[#111111] border-2 border-[#FF5E15] rounded-2xl p-8 md:p-12 reveal-child">
        <h2 class="font-heading text-white text-2xl md:text-3xl font-bold mb-3">Parts Without Installation Is Just a Box on Your Roof</h2>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 max-w-3xl">
          Incorrect installation voids warranties, fails Portland Fire Department inspections, and causes premature failure. Every DDAN parts order includes professional installation with full NFPA 96 documentation. Need diagnostics or repair instead?
        </p>
        <a href="/repair/portland-tn/" class="inline-flex items-center gap-2 text-[#FF5E15] font-heading font-semibold hover:text-white transition-all duration-300">
          Portland Exhaust Repair Services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- COMMON EQUIPMENT ISSUES -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Equipment Issues in Portland Kitchens
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          The immense, rapid lunch rushes catering to Portland's manufacturing workforce push aging exhaust fan motors to their breaking point, causing frequent bearing failures and snapped belts. When ambient rooftop temperatures hit triple digits in summer, motors that have been accumulating thermal fatigue all year finally seize. The entire kitchen fills with smoke, service stops, and the lunch crowd walks out. Emergency motor replacement during summer is Portland's single most common exhaust parts call.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Older diners throughout Portland often have significant carbon and grease buildup on fan impellers from years of heavy Southern frying. A grease-coated impeller throws the fan out of balance, which accelerates bearing destruction and causes the entire housing to vibrate against the roof curb. Left unchecked, the vibration damages the roof flashing and allows water infiltration. DDAN scrapes impellers clean, replaces damaged bearings, and rebalances the assembly — preventing the cascade of damage that starts with a dirty fan wheel.
        </p>
      </div>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Who Needs Exhaust Parts in Portland?
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { title: 'Industrial Commissaries', desc: 'Manufacturing park cafeterias running heavy-duty exhaust systems with 3-phase motors and higher CFM than typical restaurants. Specialty parts are our stock in trade.' },
          { title: 'Hwy 109 Fast-Food Chains', desc: 'High-volume operations that burn through OEM belts and motors during concentrated lunch-rush cycles. Commercial-grade parts are essential for survival.' },
          { title: 'Southern Diners & BBQ', desc: 'Heavy frying and smoking produce aggressive grease loads that coat impellers, overwhelm filters, and demand upgraded containment systems.' },
          { title: 'Corporate Cafeterias', desc: 'Manufacturing campus dining operations with strict uptime requirements. Parts failures during the lunch window are unacceptable — proactive replacement prevents them.' },
          { title: 'Restaurants Near the KY Border', desc: 'Portland\'s proximity to Kentucky means some operators are underserved by Tennessee-based suppliers. DDAN covers the entire border corridor.' },
          { title: 'Aging Building Operators', desc: 'Older Portland buildings need fire-rated access panels, custom ductwork transitions, and hinge kit retrofits to meet current NFPA 96 standards.' },
        ].map((card) => (
          <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-xl p-6 transition-all duration-300 reveal-child">
            <h3 class="font-heading text-white text-lg font-semibold mb-2">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-sm leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Portland Parts & Installation Service Area
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN delivers and installs commercial kitchen exhaust parts across all of Portland and the surrounding Sumner County industrial corridor. From the Highway 109 franchise strip to the manufacturing park commissaries near the Kentucky border, we carry common parts on every truck for same-day emergency installation.
        </p>
        <div class="space-y-3 reveal-child">
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also serving nearby:</span>
            <a href="/repair/gallatin-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Gallatin</a> and
            <a href="/parts/white-house-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">White House</a>
          </p>
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">All DDAN services in Portland:</span>
            <a href="/repair/portland-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hood Repair</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Portland Exhaust Parts FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-black rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed" set:html={faq.a}></p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
