---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import TruckCTA from '../components/TruckCTA.astro';
import business from '../data/business.json';

const siteUrl = import.meta.env.SITE || 'https://ddanhoodservices.com';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${siteUrl}/gallery/`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": business.address.city,
        "addressRegion": business.address.state,
        "postalCode": business.address.zip,
        "addressCountry": "US"
      },
      "areaServed": { "@type": "State", "name": "Tennessee" },
      "priceRange": "$$"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Gallery" }
      ]
    }
  ]
};
---

<BaseLayout
  title="Project Gallery | DDAN Hood Cleaning and Repair"
  description="View photos of our commercial kitchen hood cleaning, repair, and installation work across Nashville and Middle Tennessee."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <HeroBanner
    headline="Gallery"
    subheadline="Real work from real kitchens across Middle Tennessee"
    backgroundImage="/images/gallery/gallery-1.jpg"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Gallery' },
    ]}
  />

  <section class="py-12 md:py-16 lg:py-20 px-5 bg-[#111111] reveal">
    <div class="max-w-[1200px] mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {Array.from({length: 12}, (_, i) => `/images/gallery/gallery-${i+1}.jpg`).map((img, i) => (
          <div class="overflow-hidden rounded reveal-child">
            <img
              src={img}
              alt={`DDAN Hood Cleaning work photo ${i+1}`}
              class="w-full h-48 object-cover border-[3px] border-primary hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>
