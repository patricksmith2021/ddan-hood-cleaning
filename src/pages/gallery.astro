---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import TruckCTA from '../components/TruckCTA.astro';
import business from '../data/business.json';

const siteUrl = import.meta.env.SITE || 'https://ddanhoodservices.com';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${siteUrl}/gallery/`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": business.address.city,
        "addressRegion": business.address.state,
        "postalCode": business.address.zip,
        "addressCountry": "US"
      },
      "areaServed": { "@type": "State", "name": "Tennessee" },
      "priceRange": "$$",
      "openingHours": "Mo-Su 00:00-23:59",
      "description": "Commercial kitchen exhaust cleaning, fan repair, installation, and parts for restaurants across Middle Tennessee. Licensed, bonded, insured. NFPA 96 compliant since 2006.",
      "hasCredential": [{"@type": "EducationalOccupationalCredential","credentialCategory": "Professional Certification","name": "NFPA 96 Compliant","recognizedBy": {"@type": "Organization","name": "National Fire Protection Association"}}]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Gallery" }
      ]
    }
  ]
};
---

<BaseLayout
  title="Project Gallery | DDAN Hood Services"
  description="Photos of commercial kitchen hood cleaning, exhaust fan repair, and installation work across Nashville and Middle Tennessee by DDAN Hood Services."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <HeroBanner
    headline="Gallery"
    subheadline="Real work from real kitchens across Middle Tennessee"
    backgroundImage="/images/gallery/gallery-1.webp"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Gallery' },
    ]}
  />

  <section class="py-12 md:py-16 lg:py-20 px-5 bg-[#111111] reveal">
    <div class="max-w-[1200px] mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {[
          {w:720,h:960},{w:334,h:334},{w:2048,h:1536},{w:2048,h:1536},
          {w:1536,h:2048},{w:2048,h:1536},{w:1536,h:2048},{w:2048,h:1536},
          {w:2048,h:1536},{w:1170,h:881},{w:1536,h:2048},{w:2048,h:1536}
        ].map(({w,h}, i) => (
          <div class="overflow-hidden rounded reveal-child">
            <img
              src={`/images/gallery/gallery-${i+1}.webp`}
              alt={`DDAN Hood Services work photo ${i+1}`}
              width={w} height={h}
              class="w-full h-48 object-cover border-[3px] border-primary hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>
