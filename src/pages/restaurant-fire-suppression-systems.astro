---
import BaseLayout from '../layouts/BaseLayout.astro';
import business from '../data/business.json';
import InlineCTA from '../components/InlineCTA.astro';
import ServiceAreaGrid from '../components/ServiceAreaGrid.astro';
import TruckCTA from '../components/TruckCTA.astro';
---

<BaseLayout
  title="Restaurant Fire Suppression Systems | DDAN Hood Services"
  description="UL 300-compliant fire suppression system installation for commercial kitchens. Protect your staff and pass inspection with DDAN Hood Services."
>
  <!-- SECTION 1: HERO -->
  <section role="img" aria-label="Restaurant fire suppression system installation and service — DDAN Hood Cleaning and Repair" class="min-h-[400px] md:min-h-[550px] flex items-center justify-center" style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.3) 100%), url('/images/services/restaurant-fire-suppression-systems-service.webp') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <p class="text-[#FF5E15] font-heading font-bold text-xs md:text-sm tracking-widest uppercase mb-4">DDAN HOOD CLEANING AND REPAIR</p>
      <h1 class="font-display text-white text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">Restaurant <span class="text-[#FF5E15]">Fire Suppression</span> Systems</h1>
      <p class="text-gray-200 font-body text-lg md:text-xl max-w-2xl mx-auto mb-6">UL 300-compliant fire suppression systems for commercial kitchens. Installation, inspection, recharging, and upgrades coordinated with licensed contractors.</p>
      <p class="text-white font-heading font-bold text-base md:text-lg mb-2">UL 300 Compliant • NFPA 96 • Full Installation &amp; Service</p>
      <div class="w-20 h-1 bg-[#FF5E15] mx-auto mt-3 mb-8"></div>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5E15] text-white font-heading font-bold text-lg rounded-lg transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
          Call Now: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-[#FF5E15] text-[#FF5E15] font-heading font-bold text-lg rounded-lg hover:bg-[#FF5E15] hover:text-white transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 320 512"><path d="M272 0H48C21.5 0 0 21.5 0 48v416c0 26.5 21.5 48 48 48h224c26.5 0 48-21.5 48-48V48c0-26.5-21.5-48-48-48zM160 480c-17.7 0-32-14.3-32-32s14.3-32 32-32 32 14.3 32 32-14.3 32-32 32zm112-108c0 6.6-5.4 12-12 12H60c-6.6 0-12-5.4-12-12V60c0-6.6 5.4-12 12-12h200c6.6 0 12 5.4 12 12v312z"/></svg>
          Request Service Online
        </button>
      </div>
      <div class="flex justify-center items-center gap-6 mt-8">
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/google-white-logo-1024x337.png" alt="Google" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/facebook-logo-white-full-transparent-1024x341.png" alt="Facebook" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/YELP_BIG.D-5a67c069-1024x392.png" alt="Yelp" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BREADCRUMB STRIP -->
  <div class="bg-[#0A0A0A] py-2 px-5">
    <div class="max-w-[1200px] mx-auto">
      <nav class="flex items-center gap-2 text-sm font-heading text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF5E15] transition-colors">Home</a>
        <span class="text-[#FF5E15]">/</span>
        <span class="text-gray-300">Fire Suppression Systems</span>
      </nav>
    </div>
  </div>

  <!-- Main Content -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">

      <div class="reveal">
        <h2 class="section-headline reveal-child">What a Fire Suppression System Does for Your Kitchen</h2>
        <p class="text-[#D4D4D4] mb-4 reveal-child">A fire suppression system is your kitchen's last line of defense against a grease fire. Installed directly above your cooking equipment and inside your exhaust hood, these systems detect dangerous temperatures and automatically discharge fire-suppressing agents to contain and extinguish flames before they spread.</p>
        <p class="text-[#D4D4D4] mb-6 reveal-child">DDAN Hood Cleaning and Repair installs UL 300-compliant fire suppression systems that integrate with your entire kitchen exhaust setup. We coordinate with your contractor to ensure full code compliance and seamless system integration.</p>
      </div>

      <div class="reveal mt-8">
        <h2 class="section-headline reveal-child">What's Included in a Fire Suppression System</h2>
        <p class="text-[#D4D4D4] mb-6 reveal-child">A complete commercial kitchen fire suppression system includes:</p>

        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Detection & Activation</h3>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Fusible links that detect heat and trigger the system</li>
          <li class="check-item reveal-child">Manual pull stations for emergency activation</li>
          <li class="check-item reveal-child">Automatic gas shut-off interlocks</li>
        </ul>

        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Suppression Components</h3>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">UL 300-listed wet chemical agent tanks</li>
          <li class="check-item reveal-child">Nozzles positioned over each appliance</li>
          <li class="check-item reveal-child">Distribution piping routed through the hood plenum</li>
        </ul>

        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">System Integration</h3>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Interlocks with exhaust fans and gas lines</li>
          <li class="check-item reveal-child">Coordination with your fire alarm system</li>
          <li class="check-item reveal-child">Compliant with NFPA 96 and local fire codes</li>
        </ul>
      </div>

      <InlineCTA headline="Get a Fire Suppression Quote" />

      <div class="reveal mt-8">
        <h2 class="section-headline reveal-child">Installation & Coordination</h2>
        <p class="text-[#D4D4D4] mb-4 reveal-child">Fire suppression installation requires coordination with licensed contractors. DDAN handles:</p>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Pre-installation system design and layout</li>
          <li class="check-item reveal-child">Nozzle placement based on your equipment configuration</li>
          <li class="check-item reveal-child">Agent tank installation and pressurization</li>
          <li class="check-item reveal-child">Detection line routing and fusible link placement</li>
          <li class="check-item reveal-child">System testing and certification</li>
          <li class="check-item reveal-child">Post-installation documentation for inspectors</li>
        </ul>
      </div>

      <div class="reveal mt-8">
        <h2 class="section-headline reveal-child">Repair, Maintenance & Upgrades</h2>
        <p class="text-[#D4D4D4] mb-4 reveal-child">Already have a system? We provide ongoing service:</p>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Semi-annual inspections per NFPA 96 requirements</li>
          <li class="check-item reveal-child">Agent recharge after system discharge</li>
          <li class="check-item reveal-child">Fusible link replacement</li>
          <li class="check-item reveal-child">Nozzle repositioning after equipment changes</li>
          <li class="check-item reveal-child">System upgrades from dry chemical to wet chemical (UL 300)</li>
        </ul>
      </div>

      <div class="reveal mt-8">
        <h2 class="section-headline reveal-child">Who Needs a Fire Suppression System?</h2>
        <p class="text-[#D4D4D4] mb-4 reveal-child">NFPA 96 requires fire suppression systems in all commercial kitchens with cooking equipment that produces grease-laden vapors:</p>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Restaurants and fast-food operations</li>
          <li class="check-item reveal-child">Hotel and resort kitchens</li>
          <li class="check-item reveal-child">School and hospital cafeterias</li>
          <li class="check-item reveal-child">Food trucks and mobile kitchens</li>
          <li class="check-item reveal-child">Ghost kitchens and commissaries</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Split text/image section -->
  <section class="bg-[#1A1A1A] py-12 md:py-16 lg:py-20 px-5">
    <div class="max-w-[1200px] mx-auto reveal">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="section-headline reveal-child">Timeline, Cost & Availability</h2>
          <p class="text-[#D4D4D4] mb-4 reveal-child">Every installation is custom, but here's what to expect:</p>
          <ul class="space-y-2 mb-4">
            <li class="check-item reveal-child">Timeline: 1-3 days typical for most installations</li>
            <li class="check-item reveal-child">Cost: $2,500-$6,000+ depending on system size and complexity</li>
            <li class="check-item reveal-child">Coordination: DDAN works with your fire contractor for seamless installation</li>
          </ul>
          <p class="text-[#D4D4D4] mb-6 reveal-child">Need a system before your next inspection? We can fast-track the process.</p>
          <button type="button" class="btn-primary popup-trigger reveal-child">Request Service Online</button>
        </div>
        <div class="reveal-child">
          <img
            src="/images/services/fire-suppression.jpg"
            alt="fire suppression system installation for commercial kitchens - DDAN Hood Cleaning and Repair"
            class="w-full rounded"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <ServiceAreaGrid
    headline="Service Area"
    intro="We install and service fire suppression systems across Middle Tennessee."
  />

  <TruckCTA />
</BaseLayout>
