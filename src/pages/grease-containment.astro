---
import BaseLayout from '../layouts/BaseLayout.astro';
import InlineCTA from '../components/InlineCTA.astro';
import ServiceAreaGrid from '../components/ServiceAreaGrid.astro';
import TruckCTA from '../components/TruckCTA.astro';
import business from '../data/business.json';
---

<BaseLayout
  title="Grease Containment Solutions for Restaurants & Commercial Kitchens"
  description="Rooftop grease containment installation, service, and replacement. Protect your roof and stay fire-code compliant with DDAN Hood Services."
>
  <!-- SECTION 1: HERO -->
  <section role="img" aria-label="Rooftop grease containment system installation — DDAN Hood Cleaning and Repair" class="min-h-[400px] md:min-h-[550px] flex items-center justify-center" style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.3) 100%), url('/images/services/rooftop-grease-containment-installation.webp') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <p class="text-[#FF5E15] font-heading font-bold text-xs md:text-sm tracking-widest uppercase mb-4">DDAN HOOD CLEANING AND REPAIR</p>
      <h1 class="font-display text-white text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">Rooftop <span class="text-[#FF5E15]">Grease Containment</span> Installation</h1>
      <p class="text-gray-200 font-body text-lg md:text-xl max-w-2xl mx-auto mb-6">Protect your roof, stay fire code compliant, and prevent costly damage with high-performance grease containment systems built for Tennessee weather.</p>
      <p class="text-white font-heading font-bold text-base md:text-lg mb-2">NFPA 96 Compliant &bull; All Roof Types &bull; Same-Day Install Available</p>
      <div class="w-20 h-1 bg-[#FF5E15] mx-auto mt-3 mb-8"></div>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5E15] text-white font-heading font-bold text-lg rounded-lg transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
          Call Now: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-[#FF5E15] text-[#FF5E15] font-heading font-bold text-lg rounded-lg hover:bg-[#FF5E15] hover:text-white transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 320 512"><path d="M272 0H48C21.5 0 0 21.5 0 48v416c0 26.5 21.5 48 48 48h224c26.5 0 48-21.5 48-48V48c0-26.5-21.5-48-48-48zM160 480c-17.7 0-32-14.3-32-32s14.3-32 32-32 32 14.3 32 32-14.3 32-32 32zm112-108c0 6.6-5.4 12-12 12H60c-6.6 0-12-5.4-12-12V60c0-6.6 5.4-12 12-12h200c6.6 0 12 5.4 12 12v312z"/></svg>
          Request Service Online
        </button>
      </div>
      <div class="flex justify-center items-center gap-6 mt-8">
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/google-white-logo-1024x337.png" alt="Google" width="1024" height="337" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/facebook-logo-white-full-transparent-1024x341.png" alt="Facebook" width="1024" height="341" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/YELP_BIG.D-5a67c069-1024x392.png" alt="Yelp" width="1024" height="392" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BREADCRUMB STRIP -->
  <div class="bg-[#0A0A0A] py-2 px-5">
    <div class="max-w-[1200px] mx-auto">
      <nav class="flex items-center gap-2 text-sm font-heading text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF5E15] transition-colors">Home</a>
        <span class="text-[#FF5E15]">/</span>
        <span class="text-gray-300">Grease Containment</span>
      </nav>
    </div>
  </div>

  <!-- What Your Rooftop Grease Containment Does -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="section-headline reveal-child">What Your Rooftop Grease Containment Does</h2>
      <p class="text-[#D4D4D4] mb-4 reveal-child">Grease doesn't just disappear. Every time your exhaust fan kicks on, it pulls out hot air, smoke — and vaporized grease. That grease condenses and lands somewhere, and without proper containment, it ends up on your roof. That's a recipe for roof damage, fire hazards, and code violations.</p>
      <p class="text-[#D4D4D4] mb-6 reveal-child">DDAN Hood Cleaning and Repair installs high-performance rooftop grease containment systems that catch expelled grease before it becomes a problem. We make sure your system is safe, up to NFPA 96 standards, and easy to maintain.</p>
    </div>
  </section>

  <!-- Full Grease Containment System Installation -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="section-headline reveal-child">Full Grease Containment System Installation</h2>
      <p class="text-[#D4D4D4] mb-4 reveal-child">We provide complete containment system setups for all commercial kitchens:</p>
      <ul class="space-y-2 mb-4">
        <li class="check-item reveal-child">Rooftop grease boxes and trays for capturing grease runoff from upblast fans</li>
        <li class="check-item reveal-child">Absorbent pad systems that trap grease before it reaches your roof membrane</li>
        <li class="check-item reveal-child">Mounting brackets to elevate and secure containment trays</li>
        <li class="check-item reveal-child">Custom-fit installation for restaurants, schools, food trucks, ghost kitchens, and more</li>
        <li class="check-item reveal-child">Weather-resistant materials that hold up year-round in Tennessee conditions</li>
      </ul>
      <p class="text-[#D4D4D4] mb-6 reveal-child">Our systems work on all major roof types: EPDM, TPO, PVC, metal, and more.</p>
    </div>
  </section>

  <!-- Grease Pad Replacement & Maintenance -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="section-headline reveal-child">Grease Pad Replacement & Maintenance</h2>
      <p class="text-[#D4D4D4] mb-4 reveal-child">Containment systems only work when they're maintained. A saturated pad or overflowing tray is just as bad as having no protection at all.</p>
      <ul class="space-y-2 mb-4">
        <li class="check-item reveal-child">High-absorbency pads designed for commercial cooking volumes</li>
        <li class="check-item reveal-child">Custom maintenance schedules based on your kitchen's exhaust output</li>
        <li class="check-item reveal-child">Fast service turnaround to keep your system performing without interruption</li>
        <li class="check-item reveal-child">On-site grease containment cleaning as part of your hood cleaning or maintenance plan</li>
      </ul>
      <p class="text-[#D4D4D4] mb-6 reveal-child">We recommend checking your grease pads monthly — especially for high-volume kitchens.</p>
    </div>
  </section>

  <InlineCTA headline="Get a Grease Containment Quote Today" />

  <!-- Common Rooftop Grease Problems We Solve -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="section-headline reveal-child">Common Rooftop Grease Problems We Solve</h2>
      <p class="text-[#D4D4D4] mb-4 reveal-child">Many kitchens aren't even aware of the issues until an inspector, roofer, or fire marshal points it out:</p>
      <ul class="space-y-2 mb-4">
        <li class="check-item reveal-child">Grease-stained rooftops and corroded roof membranes</li>
        <li class="check-item reveal-child">Fire marshal citations for non-compliance with NFPA 96</li>
        <li class="check-item reveal-child">Insurance claim denials due to grease-related fire damage</li>
        <li class="check-item reveal-child">Failed inspections due to overflowing or missing grease containment</li>
        <li class="check-item reveal-child">Roof leaks caused by long-term grease saturation</li>
      </ul>
      <p class="text-[#D4D4D4] mb-6 reveal-child">Don't wait until you're hit with a fine or shutdown — solve the issue before it gets expensive.</p>
    </div>
  </section>

  <!-- Split text/image section -->
  <section class="bg-[#1A1A1A] py-12 md:py-16 lg:py-20 px-5">
    <div class="max-w-[1200px] mx-auto reveal">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="section-headline reveal-child">Installation Time, Cost & Availability</h2>
          <p class="text-[#D4D4D4] mb-4 reveal-child">Grease containment system installs are fast, affordable, and a smart long-term investment.</p>
          <ul class="space-y-2 mb-4">
            <li class="check-item reveal-child">Install Time: Most systems can be installed in under 3 hours</li>
            <li class="check-item reveal-child">Cost Range: $2,500-$5,000 depending on system size and roof type</li>
            <li class="check-item reveal-child">Availability: Local to Mt. Juliet? We can often install same-day or next-day</li>
          </ul>
          <p class="text-[#D4D4D4] mb-6 reveal-child">Emergency installs available for failing systems or post-inspection corrections.</p>
          <button type="button" class="btn-primary popup-trigger reveal-child">Request Service Online</button>
        </div>
        <div class="reveal-child">
          <img
            src="/images/services/commercial-hood-repair-split.jpeg"
            alt="commercial hood repair and grease containment - DDAN Hood Cleaning and Repair"
            class="w-full rounded"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <ServiceAreaGrid
    headline="Service Area"
    intro="We install rooftop grease containment systems across Middle Tennessee."
  />

  <TruckCTA />
</BaseLayout>
