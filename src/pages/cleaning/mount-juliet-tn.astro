---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'My Mount Juliet landlord is demanding a rooftop grease containment system. Can you install one?',
    a: 'Yes. Providence and North Mt. Juliet Road property managers are increasingly strict about roof protection. We install high-capacity containment systems that capture expelled grease, and we provide photo documentation to prove compliance after every service visit.',
  },
  {
    q: 'How fast can you repair a broken exhaust fan in Mount Juliet?',
    a: "Because Mount Juliet is our home base, we can typically arrive in under 20 minutes for emergencies. We carry common motors, belts, and bearings in stock for same-day repair — no waiting for parts shipments.",
  },
  {
    q: "Are you familiar with the Fire Department of Mt. Juliet's inspection requirements?",
    a: "Absolutely — FDMJ is our local fire department. We know exactly what their inspectors look for: bare-metal cleanliness, proper access panels, functional hinge kits, up-to-date fire suppression, and documented service history with before-and-after photos.",
  },
  {
    q: 'Do you offer preventative maintenance contracts for Mount Juliet restaurants?',
    a: "Yes. Many Mt. Juliet restaurants on quarterly or semi-annual cleaning schedules use our maintenance contracts for automated scheduling, priority emergency response, and consistent documentation. As our home-base clients, Mt. Juliet businesses get first-priority scheduling.",
  },
];
---

<BaseLayout
  title="Mt. Juliet Hood Cleaning — Our Home Base | DDAN"
  description="DDAN is headquartered in Mt. Juliet. Fastest response times, no travel fees. Providence Marketplace to N. Mt. Juliet Rd. Call (615) 881-6968."
>
  <!-- Schema: LocalBusiness + Service + BreadcrumbList + FAQPage -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
        "name": business.name,
        "telephone": business.phone,
        "email": business.email,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": business.address.street,
          "addressLocality": business.address.city,
          "addressRegion": business.address.state,
          "postalCode": business.address.zip,
          "addressCountry": "US"
        },
        "areaServed": {
          "@type": "City",
          "name": "Mount Juliet, TN"
        },
        "url": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/cleaning/mount-juliet-tn/`
      },
      {
        "@type": "Service",
        "name": "Commercial Kitchen Hood Cleaning",
        "provider": { "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business` },
        "areaServed": { "@type": "City", "name": "Mount Juliet, TN" },
        "description": "NFPA 96 compliant commercial kitchen hood cleaning from DDAN's home base in Mount Juliet — fastest response times and zero travel fees."
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/` },
          { "@type": "ListItem", "position": 2, "name": "Hood Cleaning", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/cleaning/` },
          { "@type": "ListItem", "position": 3, "name": "Mount Juliet, TN" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": faqs.map(faq => ({
          "@type": "Question",
          "name": faq.q,
          "acceptedAnswer": { "@type": "Answer", "text": faq.a }
        }))
      }
    ]
  })} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/hero-3.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/cleaning/" class="hover:text-[#FF5E15] transition-all duration-300">Hood Cleaning</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Mount Juliet, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Hood Cleaning in <span class="text-[#FF5E15]">Mount Juliet</span> — DDAN's Home Base
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Our home base — fastest response times, zero travel fees, and 18+ years of serving Mt. Juliet's commercial kitchens
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL INTRO — HOME BASE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="grid md:grid-cols-2 gap-10 items-start">
        <div>
          <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
            DDAN's Home Base — Mt. Juliet's Own Hood Cleaning Team
          </h2>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Mount Juliet is where DDAN Hood Cleaning and Repair was founded, and it remains our home base. Providence Marketplace — one of the largest retail centers in Middle Tennessee — anchors the local restaurant scene with dozens of high-volume corporate chains, sports bars, and fast-casual concepts. The North Mt. Juliet Road corridor adds even more commercial kitchens serving the city's explosive population growth.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Because we're headquartered here, Mt. Juliet businesses get the fastest response times in our entire service area — often under 20 minutes for emergencies. No travel surcharges, no scheduling delays, just professional service from the team that built its reputation in this city. We know every shopping center, every strip mall kitchen, and every corporate property manager in town.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Nearly all commercial roofing in Mt. Juliet's newer developments uses white TPO and PVC single-ply membranes, and landlords in Providence are aggressive about protecting their investment. Grease staining on these roofs leads to immediate lease violations and remediation charges that far exceed the cost of proper containment.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
            When you hire DDAN in Mount Juliet, you're hiring your neighbor. We've been cleaning hoods in this city for over 18 years — longer than many of the restaurants we serve have been open. That history means we understand what local inspectors expect, what local landlords demand, and exactly how Mt. Juliet's commercial kitchen landscape has evolved.
          </p>
        </div>
        <div class="reveal-child">
          <img
            src={`${HP}/grease-hood-cleaning-near-me-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-768x1024.jpg`}
            alt="Commercial hood cleaning in Mount Juliet TN - DDAN home base fastest response"
            class="w-full rounded-2xl border-[3px] border-[#FF5E15]"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- LOCAL COMPLIANCE -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Mt. Juliet Fire Code & Compliance Requirements
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Fire Department of Mt. Juliet (FDMJ) Fire Marshal's Office is highly proactive and modern — closely monitoring the city's explosive growth areas and strictly enforcing <a href="/nfpa-code-96-standards/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">NFPA 96</a> on all new builds and routine inspections. With dozens of new restaurants opening in Providence and along North Mt. Juliet Road, the fire marshal's office has ramped up commercial kitchen inspections significantly. They expect bare-metal cleanliness, proper access panels, functional fire suppression, and complete documented service history.
      </p>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        West Wilson Utility District is incredibly strict regarding FOG (Fats, Oils, and Grease) management to protect the infrastructure of the "City Between the Lakes." Grease runoff violations carry serious fines and can trigger mandatory additional inspections. Providence and North Mt. Juliet Road landlords enforce their own rooftop containment mandates through lease agreements, adding a third layer of compliance pressure.
      </p>
      <ul class="space-y-3 mb-6">
        <li class="check-item reveal-child">Fire Department of Mt. Juliet (FDMJ) — proactive NFPA 96 enforcement on new and existing builds</li>
        <li class="check-item reveal-child">West Wilson Utility District — strict FOG management enforcement</li>
        <li class="check-item reveal-child">Providence Marketplace landlord rooftop containment mandates</li>
        <li class="check-item reveal-child">Timestamped before-and-after photo documentation for every visit</li>
        <li class="check-item reveal-child">Service tag placed on hood after each cleaning</li>
      </ul>
    </div>
  </section>

  <!-- COMMON PROBLEMS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Exhaust System Problems in Mount Juliet
      </h2>
      <div class="space-y-6">
        <div class="reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-2">High-Volume Motor & Belt Wear</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
            High-volume corporate kitchens in Providence run exhaust systems 16+ hours daily, leading to burned-out fan motors and the need for frequent preventive <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">belt replacements</a>. These aren't emergencies when you stay on schedule — but they become emergencies fast when you don't. DDAN inspects belts, bearings, and motors during every scheduled cleaning visit and flags components approaching failure, so replacements happen during planned maintenance windows instead of during the Saturday night rush.
          </p>
        </div>
        <div class="reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-2">Aggressive Landlord Rooftop Standards</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
            Providence and North Mt. Juliet Road landlords are ruthless regarding grease stains on their new TPO roofs. Proper rooftop <a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">grease containment</a> isn't a suggestion — it's enforced in lease agreements with financial penalties that can run into thousands of dollars per incident. Property managers conduct regular roof inspections and hold tenants fully accountable for any contamination from exhaust systems. DDAN installs high-capacity containment systems and provides the photographic proof your landlord requires after every service visit.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROOF POINT -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="border-l-4 border-[#FF5E15] bg-[#111111] p-6 rounded-r-xl reveal-child">
        <p class="text-[#FF5E15] font-heading font-semibold text-lg mb-3">Real Job — Mount Juliet, TN</p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
          On a busy Saturday night, a major sports bar in Providence Marketplace had their exhaust fan belt snap, filling the kitchen with smoke and threatening to shut down service. Because DDAN is based right here in Mount Juliet, our emergency crew arrived in under 20 minutes, installed a heavy-duty commercial replacement belt, and had the kitchen safely pulling air before the dinner rush was lost.
        </p>
      </div>
    </div>
  </section>

  <!-- 3-STEP PROCESS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Our Cleaning Process
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-10 reveal-child">
        Three steps to a safe, compliant, fully documented kitchen exhaust system.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {[
          { num: '01', title: 'Inspection & Quote', desc: 'We assess your entire exhaust system — hood, ducts, fans, filters, and containment. As Mt. Juliet locals, we already know Providence and N. Mt. Juliet Rd property requirements. Free estimate.' },
          { num: '02', title: 'Overnight Deep Clean', desc: 'Our crew works around your schedule — typically 10 PM to 6 AM. Every component cleaned to bare metal per NFPA 96. Because we\'re local, our response time from our shop to your kitchen is unmatched.' },
          { num: '03', title: 'Documentation & Report', desc: 'Before-and-after photos, written service report, deficiency notes, compliance confirmation, and a service tag on your hood. Ready for FDMJ inspectors and your property manager.' },
        ].map((card) => (
          <div class="relative bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl pt-12 pb-6 px-6 flex flex-col min-h-[240px] hover:border-white hover:-translate-y-2 transition-all duration-300 reveal-child">
            <span class="absolute -top-6 left-1/2 -translate-x-1/2 w-[50px] h-[50px] bg-[#FF5E15] rounded-lg flex items-center justify-center text-white font-heading font-bold text-2xl shadow-lg">{card.num}</span>
            <h3 class="font-heading text-[#FF5E15] text-xl font-bold mb-3 text-center md:text-left">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 flex-grow text-center md:text-left">{card.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <button type="button" class="popup-trigger inline-flex items-center gap-2 px-12 md:px-[100px] py-5 w-full md:w-auto bg-transparent text-white font-body text-[1.2rem] font-medium border-2 border-[#FF5E15] rounded-full hover:bg-[#FF5E15] transition-all duration-300 reveal-child">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Schedule Your Cleaning
        </button>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE DDAN — MT. JULIET SPECIFIC -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Why Mount Juliet Restaurants Choose DDAN
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-10 reveal-child">
        Mt. Juliet is home. Our neighbors trust us because we've been here since the beginning — and we're not going anywhere.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: 'home', label: 'Local Home Base', desc: 'DDAN is headquartered in Mt. Juliet. Fastest response times in our entire service area — often under 20 minutes for emergencies.' },
          { icon: 'clock', label: 'Zero Travel Fees', desc: 'No travel surcharges for Mt. Juliet restaurants. You\'re our neighbors — you get priority scheduling and local pricing.' },
          { icon: 'camera', label: 'Photo Documentation', desc: 'Timestamped before-and-after photos satisfy FDMJ inspectors, insurance requirements, and Providence property managers.' },
          { icon: 'shield', label: 'NFPA 96 Compliant', desc: 'Every cleaning meets or exceeds NFPA 96 bare-metal standards. Full compliance with FDMJ Fire Marshal enforcement.' },
          { icon: 'roof', label: 'Providence Roof Protection', desc: 'High-capacity grease containment systems that satisfy the strictest Providence Marketplace and N. Mt. Juliet Rd landlords.' },
          { icon: 'bolt', label: '18+ Years Local', desc: 'We\'ve been cleaning hoods in Mt. Juliet since 2007. We know every property manager, every inspector, every kitchen in town.' },
        ].map((card) => (
          <div class="bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
            <div class="w-12 h-12 flex items-center justify-center bg-[#FF5E15] rounded-full mb-4">
              {card.icon === 'home' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>}
              {card.icon === 'clock' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>}
              {card.icon === 'camera' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>}
              {card.icon === 'shield' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {card.icon === 'roof' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>}
              {card.icon === 'bolt' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 10 10-12h-9l1-10z"/></svg>}
            </div>
            <h3 class="font-heading font-semibold text-white text-lg mb-2">{card.label}</h3>
            <p class="text-[#D4D4D4] text-sm">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREA LINKS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Mount Juliet Service Area & Nearby Cities
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Year-round high demand. Because Mount Juliet is our home base, we handle an immense volume of scheduled maintenance and rapid-response emergency calls locally. Schedule now before our calendar fills up.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Other Services in Mt. Juliet</p>
          <ul class="space-y-2">
            <li><a href="/repair/mt-juliet-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hood Repair — Mt. Juliet, TN</a></li>
            <li><a href="/parts-installation/mt-juliet-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Exhaust Fan Parts — Mt. Juliet, TN</a></li>
          </ul>
        </div>
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Nearby Cities</p>
          <ul class="space-y-2">
            <li><a href="/cleaning/lebanon-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Lebanon, TN</a></li>
            <li><a href="/cleaning/hermitage-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hermitage, TN</a></li>
            <li><a href="/cleaning/nashville-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Nashville, TN</a></li>
          </ul>
        </div>
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Service Hub</p>
          <ul class="space-y-2">
            <li><a href="/cleaning/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">All Hood Cleaning Service Areas</a></li>
            <li><a href="/kitchen-hood-cleaning-services/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hood Cleaning Services Overview</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Mount Juliet Hood Cleaning FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-black rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
