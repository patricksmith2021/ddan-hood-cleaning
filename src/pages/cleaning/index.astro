---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';

const HP = '/images/homepage';

const cleaningAreas = [
  { city: 'Nashville', state: 'TN', zips: '37201–37250', slug: 'nashville-tn' },
  { city: 'Murfreesboro', state: 'TN', zips: '37127–37130', slug: 'murfreesboro-tn' },
  { city: 'Antioch', state: 'TN', zips: '37013', slug: 'antioch-tn' },
  { city: 'Hendersonville', state: 'TN', zips: '37075, 37077', slug: 'hendersonville-tn' },
  { city: 'Spring Hill', state: 'TN', zips: '37174', slug: 'spring-hill-tn' },
  { city: 'Smyrna', state: 'TN', zips: '37167', slug: 'smyrna-tn' },
  { city: 'Gallatin', state: 'TN', zips: '37066', slug: 'gallatin-tn' },
  { city: 'Lebanon', state: 'TN', zips: '37087, 37090', slug: 'lebanon-tn' },
  { city: 'Goodlettsville', state: 'TN', zips: '37072', slug: 'goodlettsville-tn' },
  { city: 'Brentwood', state: 'TN', zips: '37027, 37024', slug: 'brentwood-tn' },
  { city: 'Mount Juliet', state: 'TN', zips: '37122, 37121', slug: 'mt-juliet-tn' },
  { city: 'Hermitage', state: 'TN', zips: '37076', slug: 'hermitage-tn' },
  { city: 'Madison', state: 'TN', zips: '37115', slug: 'madison-tn' },
  { city: 'La Vergne', state: 'TN', zips: '37086', slug: 'la-vergne-tn' },
];

const faqs = [
  {
    q: 'How often does my commercial kitchen hood need to be cleaned?',
    a: 'It depends on your cooking volume and type. NFPA 96 Table 11.4 sets the standard: monthly for 24-hour or high-grease operations (charbroiling, wok cooking), quarterly for most restaurants and fast food, semi-annually for moderate-volume kitchens (churches, schools), and annually for low-volume operations. DDAN helps you determine the right schedule based on your specific kitchen.',
  },
  {
    q: 'What does NFPA 96 require for hood cleaning?',
    a: 'NFPA 96 requires that all grease-laden surfaces be cleaned to bare metal — hoods, plenums, ductwork, exhaust fans, and filters. The cleaning must be performed by a trained, qualified person and documented with before-and-after evidence. DDAN provides full NFPA 96-compliant cleaning with photographic documentation on every visit.',
  },
  {
    q: 'Do you clean overnight so we don\'t lose business hours?',
    a: 'Yes. Most of our clients schedule cleaning between 10 PM and 6 AM to avoid any disruption to their operations. We also offer early-morning, weekend, and holiday scheduling. Your kitchen stays open during its busiest hours.',
  },
  {
    q: 'What\'s included in the documentation report?',
    a: 'Every cleaning visit includes time-stamped before-and-after photos of all cleaned components, a written service report noting the condition of your system, deficiency recommendations, compliance confirmation, and a service tag placed on the hood. This documentation satisfies fire marshal inspections and insurance requirements.',
  },
  {
    q: 'Do you handle emergency hood cleanings?',
    a: `Yes. If you have an urgent inspection, a grease fire scare, or a compliance emergency, DDAN provides 24/7 emergency hood cleaning service. Call ${business.phone} and we'll prioritize your kitchen.`,
  },
  {
    q: 'How much does commercial hood cleaning cost?',
    a: 'Pricing depends on system size, grease buildup level, and number of components. Small systems (1-2 hoods) typically run $350–$500, mid-size systems (2-4 hoods) $500–$850, and large multi-hood systems $850–$1,500+. We provide free, no-obligation estimates.',
  },
];

const clientTypes = [
  { label: 'Restaurants', icon: '🍽️' },
  { label: 'Fast Food', icon: '🍔' },
  { label: 'Hotels & Resorts', icon: '🏨' },
  { label: 'Churches', icon: '⛪' },
  { label: 'Schools & Universities', icon: '🏫' },
  { label: 'Hospitals', icon: '🏥' },
  { label: 'Catering & Events', icon: '🎪' },
  { label: 'Food Trucks', icon: '🚚' },
];
---

<BaseLayout
  title="Commercial Kitchen Hood Cleaning Services | DDAN Hood Cleaning Nashville"
  description="NFPA 96 compliant commercial hood cleaning for restaurants, churches, schools across 14 Middle Tennessee cities. 24/7 emergency service. Call (615) 881-6968."
>
  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/services/hood-cleaning-hero.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Hood Cleaning</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Commercial Kitchen Hood Cleaning Services in <span class="text-[#FF5E15]">Middle Tennessee</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        NFPA 96 Compliant | Bare-Metal Clean | Photo Documentation Every Time
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%', alt: 'Google Reviews - 5 Stars' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%', alt: 'Facebook Reviews - 5 Stars' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%', alt: 'Yelp Reviews - 5 Stars' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt={badge.alt} class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT WE CLEAN -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="grid md:grid-cols-2 gap-10 items-start">
        <div>
          <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
            What We Clean — Hood to Rooftop
          </h2>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            DDAN's hood cleaning service covers every grease-bearing component of your commercial kitchen exhaust system. We clean to bare metal per NFPA 96 — not just the visible surfaces.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-6 reveal-child">
            Every cleaning visit includes:
          </p>
          <ul class="space-y-3 mb-6">
            <li class="check-item reveal-child">Hood canopies and plenums — where grease vapors collect and create the highest fire risk</li>
            <li class="check-item reveal-child">Exhaust ductwork — hard-to-reach sections where grease accumulates invisibly</li>
            <li class="check-item reveal-child">Exhaust fans and motors — grease on fan blades restricts airflow and strains motors</li>
            <li class="check-item reveal-child">Grease filters and baffles — first line of defense against grease entering your duct system</li>
            <li class="check-item reveal-child">Rooftop grease containment — prevents runoff from damaging your roof membrane</li>
            <li class="check-item reveal-child">Before-and-after photo documentation for compliance, insurance, and inspection records</li>
          </ul>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
            Your kitchen's ventilation system does more than remove smoke — it protects your staff, customers, and business from fire hazards. We've spent 20 years perfecting our process.
          </p>
        </div>
        <div class="reveal-child">
          <img
            src={`${HP}/grease-hood-cleaning-near-me-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-768x1024.jpg`}
            alt="Commercial kitchen hood cleaning in Nashville - DDAN Hood Cleaning and Repair"
            class="w-full rounded-2xl border-[3px] border-[#FF5E15]"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- OUR CLEANING PROCESS — 3 step cards -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Our Cleaning Process
      </h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-10 reveal-child">
        Three steps to a safe, compliant, fully documented kitchen exhaust system.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {[
          { num: '01', title: 'Inspection & Quote', desc: 'We assess your entire exhaust system — hood, ducts, fans, filters, and containment. You get a free, no-obligation estimate. Free within 15 miles of Mt. Juliet.' },
          { num: '02', title: 'Overnight Deep Clean', desc: 'Our crew works around your schedule — typically 10 PM to 6 AM. Every component cleaned to bare metal per NFPA 96. Eco-friendly degreasers, no shortcuts.' },
          { num: '03', title: 'Documentation & Report', desc: 'Before-and-after photos, written service report, deficiency notes, compliance confirmation, and a service tag on your hood. Ready for any inspector.' },
        ].map((card) => (
          <div class="relative bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl pt-12 pb-6 px-6 flex flex-col min-h-[240px] hover:border-white hover:-translate-y-2 transition-all duration-300 reveal-child">
            <span class="absolute -top-6 left-1/2 -translate-x-1/2 w-[50px] h-[50px] bg-[#FF5E15] rounded-lg flex items-center justify-center text-white font-heading font-bold text-2xl shadow-lg">{card.num}</span>
            <h3 class="font-heading text-[#FF5E15] text-xl font-bold mb-3 text-center md:text-left">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 flex-grow text-center md:text-left">{card.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <button type="button" class="popup-trigger inline-flex items-center gap-2 px-12 md:px-[100px] py-5 w-full md:w-auto bg-transparent text-white font-body text-[1.2rem] font-medium border-2 border-[#FF5E15] rounded-full hover:bg-[#FF5E15] transition-all duration-300 reveal-child">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Schedule Your Cleaning
        </button>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE DDAN — Icon Cards -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Why Choose DDAN for Hood Cleaning
      </h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-10 reveal-child">
        Middle Tennessee's commercial kitchens choose DDAN for reliability, thoroughness, and complete documentation.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: 'clock', label: '24/7 Emergency Service', desc: 'Failed inspection? Grease fire scare? We provide emergency hood cleaning around the clock.' },
          { icon: 'camera', label: 'Photo Documentation', desc: 'Every job includes timestamped before-and-after photos for compliance, insurance, and inspection records.' },
          { icon: 'shield', label: 'NFPA 96 Compliant', desc: 'Every cleaning meets or exceeds NFPA 96 bare-metal standards. Pass every fire marshal inspection.' },
          { icon: 'tools', label: '20 Years Experience', desc: 'Serving Middle Tennessee commercial kitchens since 2006. We know every hood system inside and out.' },
          { icon: 'star', label: 'Licensed & Insured', desc: 'Fully licensed, bonded, and insured. Your kitchen is protected from start to finish.' },
          { icon: 'bolt', label: 'Overnight Scheduling', desc: 'We work 10 PM–6 AM so your kitchen stays open during peak hours. Zero disruption to your business.' },
        ].map((card) => (
          <div class="bg-[#111111] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
            <div class="w-12 h-12 flex items-center justify-center bg-[#FF5E15] rounded-full mb-4">
              {card.icon === 'clock' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>}
              {card.icon === 'camera' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>}
              {card.icon === 'shield' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {card.icon === 'tools' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>}
              {card.icon === 'star' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>}
              {card.icon === 'bolt' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 10 10-12h-9l1-10z"/></svg>}
            </div>
            <h3 class="font-heading font-semibold text-white text-lg mb-2">{card.label}</h3>
            <p class="text-[#D4D4D4] text-sm">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO WE SERVE -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Who We Serve
      </h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-10 reveal-child">
        Any facility with a commercial kitchen exhaust system needs regular hood cleaning. We serve them all.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
        {clientTypes.map((client) => (
          <div class="bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl p-5 text-center transition-all duration-300 reveal-child">
            <p class="text-3xl mb-2">{client.icon}</p>
            <p class="text-white font-heading font-semibold text-sm">{client.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CLEANING FREQUENCY GUIDE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Hood Cleaning Frequency Guide
      </h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-10 reveal-child">
        Per NFPA 96 Table 11.4, cleaning frequency depends on your cooking volume and type.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { freq: 'Monthly', types: '24-hour cooking, charbroiling, wok cooking, wood/coal-fired', color: 'border-red-500', note: 'Highest grease output' },
          { freq: 'Quarterly', types: 'High-volume restaurants, fast food, hotel kitchens, hospital cafeterias', color: 'border-[#FF5E15]', note: 'Most common schedule' },
          { freq: 'Semi-Annually', types: 'Churches, schools, seasonal kitchens, moderate-volume operations', color: 'border-yellow-500', note: 'Moderate grease output' },
          { freq: 'Annually', types: 'Low-volume operations, senior centers, day camps, seasonal facilities', color: 'border-green-500', note: 'Lowest grease output' },
        ].map((item) => (
          <div class={`bg-[#111111] border-t-4 ${item.color} border border-[#333] rounded-xl p-6 reveal-child`}>
            <h3 class="font-heading font-bold text-white text-xl mb-1">{item.freq}</h3>
            <p class="text-[#FF5E15] font-heading text-xs font-semibold uppercase tracking-wide mb-3">{item.note}</p>
            <p class="text-[#D4D4D4] text-sm">{item.types}</p>
          </div>
        ))}
      </div>
      <p class="text-[#999] text-sm mt-6 reveal-child">Reference: NFPA 96 Table 11.4 — Schedule of Inspection for Grease Buildup</p>
    </div>
  </section>

  <!-- SERVICE AREA INDEX — 14 CITIES -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Hood Cleaning Service Areas
      </h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-10 reveal-child">
        DDAN provides commercial hood cleaning across 14 Middle Tennessee cities. Select your city for local service details.
      </p>
      <div class="flex flex-wrap gap-5">
        {cleaningAreas.map((area) => (
          <a href={`/cleaning/${area.slug}/`} class="block w-full sm:w-[31%] border border-[#FF5E15] rounded-2xl p-5 hover:border-white transition-all duration-300 reveal-child group">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center bg-[#FF5E15] rounded-full">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 384 512"><path d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 110 128 64 64 0 010-128z"/></svg>
              </div>
              <div>
                <p class="text-white font-heading font-medium group-hover:text-[#FF5E15] transition-all duration-300">{area.city}, {area.state}</p>
                <p class="text-[#DDDDDD] text-sm">({area.zips})</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Hood Cleaning FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-[#111111] border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-[#111111] rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- TRUCK CTA -->
  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
