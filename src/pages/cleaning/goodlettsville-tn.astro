---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'Can you protect my Goodlettsville restaurant\'s white TPO roof from grease stains?',
    a: 'Absolutely. Corporate landlords in the Rivergate and I-65 corridor demand pristine rooftops. We install high-capacity rooftop grease containment systems that capture expelled grease before it touches your membrane, and we provide photo documentation to prove compliance to your property manager.',
  },
  {
    q: 'How fast can you fix a broken exhaust fan near the Goodlettsville I-65 exit?',
    a: 'We provide 24/7 emergency service across Goodlettsville. For I-65 corridor restaurants, our Mt. Juliet-based team can typically arrive within 30-40 minutes with common replacement parts in stock for same-day repair.',
  },
  {
    q: 'What is required to pass a Goodlettsville Fire Department hood inspection?',
    a: 'Goodlettsville Fire inspectors look for bare-metal cleanliness throughout the entire system, functional fire suppression, proper access panels, and documented service history. DDAN provides all of this with every cleaning visit.',
  },
  {
    q: 'Do you handle grease trap cleaning too?',
    a: 'Our specialty is the exhaust system — hoods, ducts, fans, and rooftop containment. For interior grease trap and interceptor cleaning, we can coordinate with a licensed plumbing partner. However, the rooftop grease containment that prevents grease from reaching your roof and storm drains is absolutely our domain.',
  },
];
---

<BaseLayout
  title="Goodlettsville Hood Cleaning | I-65 Corridor | DDAN"
  description="24/7 hood cleaning for Goodlettsville's I-65 fast-food corridor and Rivergate restaurants. Dollar General HQ area. Call (615) 881-6968."
>
  <!-- Schema: LocalBusiness + Service + BreadcrumbList + FAQPage -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
        "name": business.name,
        "telephone": business.phone,
        "email": business.email,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": business.address.street,
          "addressLocality": business.address.city,
          "addressRegion": business.address.state,
          "postalCode": business.address.zip,
          "addressCountry": "US"
        },
        "areaServed": {
          "@type": "City",
          "name": "Goodlettsville, TN"
        },
        "url": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/cleaning/goodlettsville-tn/`
      },
      {
        "@type": "Service",
        "name": "Commercial Kitchen Hood Cleaning",
        "provider": { "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business` },
        "areaServed": { "@type": "City", "name": "Goodlettsville, TN" },
        "description": "NFPA 96 compliant commercial kitchen hood cleaning for Goodlettsville's I-65 fast-food corridor and Rivergate dining establishments."
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/` },
          { "@type": "ListItem", "position": 2, "name": "Hood Cleaning", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/cleaning/` },
          { "@type": "ListItem", "position": 3, "name": "Goodlettsville, TN" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": faqs.map(faq => ({
          "@type": "Question",
          "name": faq.q,
          "acceptedAnswer": { "@type": "Answer", "text": faq.a }
        }))
      }
    ]
  })} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/rooftop-exhaust-fan.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/cleaning/" class="hover:text-[#FF5E15] transition-all duration-300">Hood Cleaning</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Goodlettsville, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Hood Cleaning for <span class="text-[#FF5E15]">Goodlettsville's</span> I-65 Restaurant Corridor
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Serving the I-65 fast-food corridor, Rivergate dining, and Dollar General HQ — where exhaust fans never stop
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL INTRO — I-65 CORRIDOR -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="grid md:grid-cols-2 gap-10 items-start">
        <div>
          <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
            The I-65 Corridor's Relentless Kitchen Exhaust Demands
          </h2>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Goodlettsville sits at the I-65 interchange, making it one of the highest-traffic restaurant corridors in Middle Tennessee. The steady stream of interstate travelers fuels a massive concentration of fast-food franchises, corporate chain restaurants, and hotel-adjacent dining that runs 24/7. Dollar General's corporate headquarters anchors the local commercial landscape, and the Rivergate Mall area adds dozens more restaurants to an already dense dining market.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            The cuisine here is dominated by high-volume fast-food and casual dining — fryers run relentlessly from open to close, every single day. Rooftop construction is predominantly white TPO and PVC on newer corporate builds, which means any grease contamination is immediately visible and immediately a problem. Corporate property managers in the Rivergate area and along the I-65 corridor enforce aggressive rooftop maintenance standards through lease agreements, and violations carry real financial penalties.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Goodlettsville straddles both Davidson and Sumner Counties, meaning businesses here may face compliance requirements from two different jurisdictions. DDAN understands the regulatory landscape on both sides of the county line and ensures your system meets every applicable standard regardless of which jurisdiction your address falls under.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
            With exhaust fans running nearly around the clock to serve interstate traffic, the systems in Goodlettsville restaurants endure significantly more wear than typical commercial kitchens. That accelerated usage demands a more aggressive cleaning and maintenance schedule — and a service provider who understands why.
          </p>
        </div>
        <div class="reveal-child">
          <img
            src={`${HP}/grease-hood-cleaning-near-me-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-768x1024.jpg`}
            alt="Commercial hood cleaning for Goodlettsville TN I-65 corridor restaurants - DDAN"
            class="w-full rounded-2xl border-[3px] border-[#FF5E15]"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- LOCAL COMPLIANCE -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Goodlettsville Fire Code & Compliance Requirements
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Goodlettsville Fire Department is extremely proactive — surprise <a href="/nfpa-code-96-standards/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">NFPA 96</a> checks are common along the I-65 corridor due to high commercial density and hotel adjacency. The concentration of restaurants, fast-food operations, and hotel kitchens near the interstate makes this area a priority for fire inspectors. If your cleaning records aren't current when they walk through the door, you're getting a violation.
      </p>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Goodlettsville Sewer Department maintains strict FOG (Fats, Oils, and Grease) policies to protect municipal infrastructure. Corporate property managers around Dollar General HQ and the Rivergate area self-enforce aggressive rooftop containment mandates, issuing penalties for any grease staining on their white membrane roofs. Between fire code, environmental regulations, and landlord requirements, Goodlettsville restaurants face compliance pressure from multiple directions simultaneously.
      </p>
      <ul class="space-y-3 mb-6">
        <li class="check-item reveal-child">Goodlettsville Fire Department — surprise NFPA 96 inspections on I-65 corridor</li>
        <li class="check-item reveal-child">Goodlettsville Sewer Department — strict FOG enforcement</li>
        <li class="check-item reveal-child">Corporate landlord rooftop containment mandates with financial penalties</li>
        <li class="check-item reveal-child">Dual-county compliance (Davidson & Sumner) for businesses on the border</li>
        <li class="check-item reveal-child">Timestamped before-and-after photo documentation for every visit</li>
      </ul>
    </div>
  </section>

  <!-- COMMON PROBLEMS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Exhaust System Problems in Goodlettsville
      </h2>
      <div class="space-y-6">
        <div class="reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-2">24/7 Fan Belt & Motor Burnout</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
            Interstate fast-food exhaust fans run 24/7, shredding standard OEM fan belts and burning out motors rapidly. These systems don't get the overnight rest that normal restaurant fans get — they run through breakfast, lunch, dinner, and late-night drive-through without a break. The result is dramatically shortened component life and unexpected failures during peak service hours. DDAN inspects <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">belts, motors, and bearings</a> during every cleaning visit, replacing worn components proactively before they strand your kitchen.
          </p>
        </div>
        <div class="reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-2">Corporate Rooftop Grease Violations</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
            Corporate landlords around the Rivergate area are incredibly strict — massive fines if exhaust grease stains their white TPO roofs. Proper <a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">grease containment</a> isn't optional here; it's a lease requirement. Property management companies conduct regular roof inspections, and tenants who fail to maintain grease containment systems face penalties that can exceed the cost of the containment system itself many times over. DDAN installs high-capacity rooftop containment and provides the photo documentation your landlord demands.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROOF POINT -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="border-l-4 border-[#FF5E15] bg-[#111111] p-6 rounded-r-xl reveal-child">
        <p class="text-[#FF5E15] font-heading font-semibold text-lg mb-3">Real Job — Goodlettsville, TN</p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
          A high-volume fast-food franchise right off I-65 in Goodlettsville had a factory-installed fan belt snap during the peak Friday lunch rush, filling the kitchen with smoke. DDAN arrived within 30 minutes, upgraded the unit to a commercial-grade notched V-belt, and verified the motor tension, saving the restaurant from a disastrous shutdown.
        </p>
      </div>
    </div>
  </section>

  <!-- 3-STEP PROCESS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Our Cleaning Process
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-10 reveal-child">
        Three steps to a safe, compliant, fully documented kitchen exhaust system.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {[
          { num: '01', title: 'Inspection & Quote', desc: 'We assess your entire exhaust system — hood, ducts, fans, filters, and containment. We evaluate 24/7 operational wear patterns specific to I-65 corridor restaurants. Free estimate.' },
          { num: '02', title: 'Overnight Deep Clean', desc: 'Our crew works around your schedule — even for 24-hour operations, we coordinate low-traffic windows. Every component cleaned to bare metal per NFPA 96. Special attention to high-volume grease buildup from continuous frying.' },
          { num: '03', title: 'Documentation & Report', desc: 'Before-and-after photos, written service report, deficiency notes, compliance confirmation, and a service tag on your hood. Ready for Goodlettsville Fire Department inspectors and your corporate landlord.' },
        ].map((card) => (
          <div class="relative bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl pt-12 pb-6 px-6 flex flex-col min-h-[240px] hover:border-white hover:-translate-y-2 transition-all duration-300 reveal-child">
            <span class="absolute -top-6 left-1/2 -translate-x-1/2 w-[50px] h-[50px] bg-[#FF5E15] rounded-lg flex items-center justify-center text-white font-heading font-bold text-2xl shadow-lg">{card.num}</span>
            <h3 class="font-heading text-[#FF5E15] text-xl font-bold mb-3 text-center md:text-left">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 flex-grow text-center md:text-left">{card.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <button type="button" class="popup-trigger inline-flex items-center gap-2 px-12 md:px-[100px] py-5 w-full md:w-auto bg-transparent text-white font-body text-[1.2rem] font-medium border-2 border-[#FF5E15] rounded-full hover:bg-[#FF5E15] transition-all duration-300 reveal-child">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Schedule Your Cleaning
        </button>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE DDAN — GOODLETTSVILLE SPECIFIC -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Why Goodlettsville Restaurants Choose DDAN
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-10 reveal-child">
        I-65 corridor kitchens trust DDAN because we understand the demands of 24/7 high-volume operations and corporate compliance.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: 'highway', label: 'I-65 Corridor Experts', desc: 'We service the highest-traffic restaurant corridor in Middle Tennessee. We understand 24/7 operational demands and accelerated equipment wear.' },
          { icon: 'clock', label: '24/7 Emergency Service', desc: 'Fan belt snap during the Friday rush? We provide emergency response around the clock for Goodlettsville kitchens — 30-40 minute response times.' },
          { icon: 'camera', label: 'Landlord-Ready Documentation', desc: 'Timestamped before-and-after photos satisfy fire inspectors, insurance adjusters, and the strictest corporate property managers.' },
          { icon: 'shield', label: 'NFPA 96 Compliant', desc: 'Every cleaning meets or exceeds NFPA 96 bare-metal standards. Full compliance for surprise Goodlettsville Fire Department inspections.' },
          { icon: 'roof', label: 'Rooftop Containment', desc: 'High-capacity grease containment systems protect white TPO roofs and satisfy corporate landlord mandates in the Rivergate area.' },
          { icon: 'bolt', label: 'Dual-County Knowledge', desc: 'Goodlettsville straddles Davidson and Sumner Counties. We know the compliance requirements for both jurisdictions.' },
        ].map((card) => (
          <div class="bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
            <div class="w-12 h-12 flex items-center justify-center bg-[#FF5E15] rounded-full mb-4">
              {card.icon === 'highway' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 20L8 4M16 20l4-16M6 12h12"/></svg>}
              {card.icon === 'clock' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>}
              {card.icon === 'camera' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>}
              {card.icon === 'shield' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {card.icon === 'roof' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>}
              {card.icon === 'bolt' && <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 10 10-12h-9l1-10z"/></svg>}
            </div>
            <h3 class="font-heading font-semibold text-white text-lg mb-2">{card.label}</h3>
            <p class="text-[#D4D4D4] text-sm">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREA LINKS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Goodlettsville Service Area & Nearby Cities
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Consistently heavy demand year-round, driven by steady I-65 interstate travel and corporate lunch volume. Your fans never rest — neither should your maintenance schedule.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Other Services in Goodlettsville</p>
          <ul class="space-y-2">
            <li><a href="/repair/goodlettsville-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hood Repair — Goodlettsville, TN</a></li>
            <li><a href="/parts-installation/goodlettsville-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Exhaust Fan Parts — Goodlettsville, TN</a></li>
          </ul>
        </div>
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Nearby Cities</p>
          <ul class="space-y-2">
            <li><a href="/cleaning/hendersonville-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hendersonville, TN</a></li>
            <li><a href="/cleaning/madison-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Madison, TN</a></li>
            <li><a href="/cleaning/nashville-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Nashville, TN</a></li>
          </ul>
        </div>
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Service Hub</p>
          <ul class="space-y-2">
            <li><a href="/cleaning/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">All Hood Cleaning Service Areas</a></li>
            <li><a href="/kitchen-hood-cleaning-services/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hood Cleaning Services Overview</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Goodlettsville Hood Cleaning FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-black rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- TRUCK CTA -->
  <TruckCTA />
</BaseLayout>

