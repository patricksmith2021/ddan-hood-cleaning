---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'Can you bring my historic Gallatin restaurant\'s exhaust system up to fire code?',
    a: 'Yes. Many older buildings in downtown Gallatin have concealed ductwork without proper access panels. We carefully install fire-rated access doors without damaging the historic structure, then clean the entire system to bare metal for NFPA 96 compliance.',
  },
  {
    q: 'My upblast exhaust fan in Gallatin is leaking grease onto the roof. Can you fix this?',
    a: 'Absolutely. Leaking grease is a severe fire hazard and will quickly destroy your roofing membrane. We install high-capacity rooftop grease containment systems and clean the fan to eliminate the source of the leak.',
  },
  {
    q: 'Do you offer emergency exhaust fan motor repair in Gallatin?',
    a: 'Yes, we provide 24/7 emergency service. If your exhaust fan motor burns out or a belt snaps, we dispatch immediately and carry common replacement parts for same-day repair.',
  },
  {
    q: "What's the difference between monthly and quarterly cleaning?",
    a: "Monthly cleaning is required for 24-hour operations, charbroiling, and solid-fuel cooking that produce extreme grease. Quarterly is the standard for most restaurants. Gallatin's mix of Southern cooking and fast food typically falls in the quarterly range, though high-volume operations may need monthly service per NFPA 96 Table 11.4.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
      "name": business.name,
      "image": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/images/hero/hero-3.jpg`,
      "telephone": business.phone,
      "email": business.email,
      "url": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev',
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": "Mt. Juliet",
        "addressRegion": "TN",
        "postalCode": "37122",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Gallatin, TN"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": business.googleReviewRating,
        "reviewCount": "51"
      }
    },
    {
      "@type": "Service",
      "name": "Commercial Kitchen Hood Cleaning",
      "provider": { "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business` },
      "areaServed": {
        "@type": "City",
        "name": "Gallatin, TN"
      },
      "description": "NFPA 96 compliant commercial kitchen hood cleaning for Gallatin restaurants, serving the historic square and Nashville Pike corridor in Sumner County."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev' },
        { "@type": "ListItem", "position": 2, "name": "Hood Cleaning", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/cleaning/` },
        { "@type": "ListItem", "position": 3, "name": "Gallatin, TN" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Professional Hood Cleaning Near Gallatin, TN | DDAN"
  description="Bare-metal hood cleaning for Gallatin's historic square and Nashville Pike restaurants. Sumner County fire code compliant. (615) 881-6968."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/hero-3.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/cleaning/" class="hover:text-[#FF5E15] transition-all duration-300">Hood Cleaning</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Gallatin, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Professional Hood Cleaning Near <span class="text-[#FF5E15]">Gallatin, Tennessee</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Serving the historic square and Nashville Pike — from Vol State campus kitchens to Sumner County's best restaurants
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Gallatin's Growing Restaurant Scene Demands Expert Hood Cleaning
      </h2>
      <div class="grid md:grid-cols-2 gap-10 items-start">
        <div>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Gallatin's historic downtown square and the expanding Nashville Pike commercial corridor make this Sumner County seat a growing hub for restaurants and food service. Volunteer State Community College (Vol State) and Sumner Regional Medical Center add institutional kitchen demand that keeps exhaust systems running at high capacity year-round. The cuisine is a blend of traditional Southern meat-and-threes, emerging upscale casual dining, and fast-food franchises — fryers and flat-top grills see heavy daily use across the board.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Downtown Gallatin has complex historic roofing with shared brick walls, while Nashville Pike features newer white TPO and EPDM membranes on modern strip center construction. The contrast creates very different hood cleaning challenges — historic buildings need careful access panel retrofits that don't compromise the building's character, while new builds need aggressive grease containment to protect their roofing investment from chemical degradation caused by exhaust fan grease runoff.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            DDAN understands both sides of the Gallatin restaurant landscape. Whether you're operating a heritage diner on the square or a national franchise on Nashville Pike, we deliver bare-metal cleaning that meets NFPA 96 standards and satisfies Sumner County fire inspectors. Our technicians know the specific roofing, ductwork, and access challenges that Gallatin properties present — and we solve them without shortcuts.
          </p>
          <p class="text-[#FF5E15] font-heading font-semibold text-base reveal-child">
            DDAN delivers thorough, NFPA 96-compliant hood cleaning across all of Gallatin and Sumner County.
          </p>
        </div>
        <div class="reveal-child">
          <img
            src={`${HP}/grease-hood-cleaning-near-me-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-768x1024.jpg`}
            alt="Commercial hood cleaning for Gallatin TN restaurants - DDAN Hood Cleaning and Repair"
            class="w-full rounded-2xl border-[3px] border-[#FF5E15]"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- LOCAL COMPLIANCE -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Gallatin Fire Code & Environmental Compliance
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Gallatin Fire Department Fire Prevention Division is strict, particularly in the historic downtown overlay where shared brick walls present catastrophic fire risk if exhaust systems aren't maintained. A grease fire in one kitchen can spread through shared wall cavities to neighboring businesses in minutes. Full <a href="/nfpa-code-96-standards/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">NFPA 96 compliance</a> — bare-metal cleaning of all grease-laden surfaces, proper access panel installation, and documented cleaning schedules — is actively enforced.
      </p>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Gallatin Public Utilities enforces wastewater codes for grease traps and rooftop containment. Restaurants that allow grease runoff to reach storm drains face fines and potential business license consequences. Along Nashville Pike, where newer commercial construction uses single-ply roof membranes, grease runoff doesn't just violate code — it chemically destroys the roofing material. DDAN's cleaning and containment services address both fire code and environmental compliance.
      </p>
      <ul class="space-y-3 mb-6">
        <li class="check-item reveal-child">Gallatin Fire Department Fire Prevention Division — full NFPA 96 enforcement</li>
        <li class="check-item reveal-child">Historic downtown overlay — shared wall fire risk requires strict exhaust maintenance</li>
        <li class="check-item reveal-child">Gallatin Public Utilities — grease trap and rooftop runoff monitoring</li>
        <li class="check-item reveal-child">Timestamped before-and-after photo documentation for every visit</li>
        <li class="check-item reveal-child">Service tag placed on hood after each cleaning</li>
      </ul>
    </div>
  </section>

  <!-- COMMON PROBLEMS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Exhaust System Problems in Gallatin
      </h2>
      <div class="space-y-6">
        <div class="reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-2">Historic Square: Inaccessible Ductwork</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
            Restaurants in the historic square often operate with older, non-standard ductwork that lacks fire-rated access panels required for NFPA 96 bare-metal cleaning. Without panels, technicians can't reach hidden grease deposits that accumulate behind historic ceilings and inside wall cavities. These concealed grease loads are invisible but represent extreme fire risk — especially in buildings with shared brick walls. DDAN carefully installs <a href="/access-panel-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">fire-rated access panels</a> that provide full cleaning access without altering the building's historic character.
          </p>
        </div>
        <div class="reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-2">Nashville Pike: Premature Belt & Motor Failure</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
            Newer corporate franchises along Nashville Pike frequently suffer from premature exhaust fan belt failure due to high daily volumes. Factory-installed belts weren't built for the relentless demands of a real commercial kitchen running 14-16 hours a day. When a belt snaps during peak service, your kitchen fills with smoke and grease vapors within minutes. DDAN inspects belts and motors during every cleaning visit and proactively replaces worn components before they fail. When emergency <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">belt and motor repair</a> is needed, we respond 24/7 with common replacement parts on the truck.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROOF POINT -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="border-l-4 border-[#FF5E15] bg-[#111111] p-6 rounded-r-xl reveal-child">
        <p class="text-[#FF5E15] font-heading font-semibold text-lg mb-3">Real Job — Gallatin, TN</p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
          A popular Southern cooking restaurant near the Gallatin square repeatedly failed health inspections due to inaccessible, grease-laden ductwork hidden behind a historic ceiling. DDAN technicians carefully installed specialized fire-rated access panels, completed a bare-metal deep clean, and secured the restaurant's NFPA 96 compliance without altering the building's historic aesthetic.
        </p>
      </div>
    </div>
  </section>

  <!-- 3-STEP PROCESS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Our Cleaning Process
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-10 reveal-child">
        Three steps to a safe, compliant, fully documented kitchen exhaust system.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {[
          { num: '01', title: 'Inspection & Quote', desc: 'We assess your entire exhaust system — hood, ducts, fans, filters, and containment. We check for historic-building access challenges and Nashville Pike roofing concerns. Free estimate.' },
          { num: '02', title: 'Overnight Deep Clean', desc: 'Our crew works around your schedule — typically 10 PM to 6 AM. Every component cleaned to bare metal per NFPA 96. Special attention to concealed ductwork in historic downtown properties.' },
          { num: '03', title: 'Documentation & Report', desc: 'Before-and-after photos, written service report, deficiency notes, compliance confirmation, and a service tag on your hood. Ready for Gallatin Fire Department inspectors.' },
        ].map((card) => (
          <div class="relative bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl pt-12 pb-6 px-6 flex flex-col min-h-[240px] hover:border-white hover:-translate-y-2 transition-all duration-300 reveal-child">
            <span class="absolute -top-6 left-1/2 -translate-x-1/2 w-[50px] h-[50px] bg-[#FF5E15] rounded-lg flex items-center justify-center text-white font-heading font-bold text-2xl shadow-lg">{card.num}</span>
            <h3 class="font-heading text-[#FF5E15] text-xl font-bold mb-3 text-center md:text-left">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 flex-grow text-center md:text-left">{card.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <button type="button" class="popup-trigger inline-flex items-center gap-2 px-12 md:px-[100px] py-5 w-full md:w-auto bg-transparent text-white font-body text-[1.2rem] font-medium border-2 border-[#FF5E15] rounded-full hover:bg-[#FF5E15] transition-all duration-300 reveal-child">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Schedule Your Cleaning
        </button>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA LINKS -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Gallatin Service Area & Nearby Cities
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Steady demand with emergency repair spikes during the first major heatwaves of early summer, which push aging fan motors to failure. Schedule proactive cleaning before the heat hits.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Other Services in Gallatin</p>
          <ul class="space-y-2">
            <li><a href="/repair/gallatin-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hood Repair — Gallatin, TN</a></li>
            <li><a href="/parts/gallatin-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Exhaust Fan Parts — Gallatin, TN</a></li>
          </ul>
        </div>
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Nearby Cities</p>
          <ul class="space-y-2">
            <li><a href="/cleaning/hendersonville-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hendersonville, TN</a></li>
            <li><a href="/cleaning/lebanon-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Lebanon, TN</a></li>
          </ul>
        </div>
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Service Hub</p>
          <ul class="space-y-2">
            <li><a href="/cleaning/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">All Hood Cleaning Service Areas</a></li>
            <li><a href="/kitchen-hood-cleaning-services/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hood Cleaning Services Overview</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Gallatin Hood Cleaning FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-[#1A1A1A] rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- TRUCK CTA -->
  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
