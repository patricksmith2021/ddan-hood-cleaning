---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'Can you clean hoods used for high-heat wok cooking in Antioch?',
    a: 'Yes. Wok cooking and open-flame grilling create a hardened carbon scale that is much tougher than standard restaurant grease. Our technicians use aggressive scraping techniques and commercial-grade degreasers specifically designed for this type of buildup.',
  },
  {
    q: 'My Antioch restaurant is in an older building. Do I need duct access panels?',
    a: 'Most likely. Metro Nashville Fire Code dictates that any changes in duct direction must have fire-rated access panels for proper cleaning. Many older Antioch buildings were not built to current code.',
  },
  {
    q: 'How fast can you replace a broken exhaust fan belt near Hickory Hollow?',
    a: `We offer 24/7 emergency repair services for Antioch restaurants. If a snapped belt or burnt motor shuts your kitchen down, our team can typically be on-site within an hour. Call ${business.phone}.`,
  },
  {
    q: 'Do you clean overnight to avoid disrupting business?',
    a: 'Yes. Most Antioch restaurants schedule cleaning between 10 PM and 6 AM. We also accommodate early-morning and weekend scheduling.',
  },
];
---

<BaseLayout
  title="NFPA 96 Hood Cleaning for Antioch Restaurants | DDAN"
  description="Expert hood cleaning for Antioch's diverse restaurant scene — Latin, Asian, Middle Eastern cuisine. Metro Nashville compliant. Call (615) 881-6968."
>
  <!-- Schema: LocalBusiness + Service + BreadcrumbList + FAQPage -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
        "name": business.name,
        "telephone": business.phone,
        "email": business.email,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": business.address.street,
          "addressLocality": business.address.city,
          "addressRegion": business.address.state,
          "postalCode": business.address.zip,
          "addressCountry": "US"
        },
        "areaServed": {
          "@type": "City",
          "name": "Antioch, TN"
        },
        "url": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/cleaning/antioch-tn/`
      },
      {
        "@type": "Service",
        "name": "Commercial Kitchen Hood Cleaning",
        "provider": { "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business` },
        "areaServed": { "@type": "City", "name": "Antioch, TN" },
        "description": "NFPA 96 compliant commercial kitchen hood cleaning for Antioch restaurants specializing in high-heat, diverse cuisine cooking methods."
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/` },
          { "@type": "ListItem", "position": 2, "name": "Hood Cleaning", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/cleaning/` },
          { "@type": "ListItem", "position": 3, "name": "Antioch, TN" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Can you clean hoods used for high-heat wok cooking in Antioch?",
            "acceptedAnswer": { "@type": "Answer", "text": "Yes. Wok cooking and open-flame grilling create a hardened carbon scale that is much tougher than standard restaurant grease. Our technicians use aggressive scraping techniques and commercial-grade degreasers specifically designed for this type of buildup." }
          },
          {
            "@type": "Question",
            "name": "My Antioch restaurant is in an older building. Do I need duct access panels?",
            "acceptedAnswer": { "@type": "Answer", "text": "Most likely. Metro Nashville Fire Code dictates that any changes in duct direction must have fire-rated access panels for proper cleaning. Many older Antioch buildings were not built to current code." }
          },
          {
            "@type": "Question",
            "name": "How fast can you replace a broken exhaust fan belt near Hickory Hollow?",
            "acceptedAnswer": { "@type": "Answer", "text": "We offer 24/7 emergency repair services for Antioch restaurants. If a snapped belt or burnt motor shuts your kitchen down, our team can typically be on-site within an hour." }
          },
          {
            "@type": "Question",
            "name": "Do you clean overnight to avoid disrupting business?",
            "acceptedAnswer": { "@type": "Answer", "text": "Yes. Most Antioch restaurants schedule cleaning between 10 PM and 6 AM. We also accommodate early-morning and weekend scheduling." }
          }
        ]
      }
    ]
  })} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/hero-3.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/cleaning/" class="hover:text-[#FF5E15] transition-all duration-300">Hood Cleaning</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Antioch, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Antioch Commercial Kitchen <span class="text-[#FF5E15]">Hood Cleaning Experts</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Specialized cleaning for Antioch's Latin American, Asian, and Middle Eastern kitchens — where standard methods don't cut it
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL INTRO — DIVERSE CUISINE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="grid md:grid-cols-2 gap-10 items-start">
        <div>
          <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
            Hood Cleaning for Antioch's Diverse Kitchen Scene
          </h2>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Antioch has one of Nashville's most ethnically diverse restaurant scenes. Bell Road and Murfreesboro Pike are lined with authentic Latin American, Asian, and Middle Eastern restaurants serving cuisines that demand high-heat cooking techniques most hood cleaning companies are not equipped to handle. High-heat wok cooking, open-flame grills, and heavy spice use produce intense carbon buildup and thick, sticky grease that standard cleaning methods simply cannot remove.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Global Mall at the Crossings drives heavy foot traffic to the surrounding restaurant corridor, keeping kitchens running at full capacity through lunch and dinner rushes. Many of these restaurants operate in older strip center buildings with built-up roofing (BUR) and undersized exhaust systems that were never designed for the cooking volume they now handle. Newer developments around Century Farms feature TPO-roofed buildings with modern ventilation, but even those systems require specialized cleaning when running high-grease cuisines.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
            DDAN provides NFPA 96 compliant hood cleaning specifically calibrated for the type of cooking your Antioch kitchen actually does — not a one-size-fits-all service that leaves hardened carbon behind.
          </p>
        </div>
        <div class="reveal-child">
          <img
            src={`${HP}/grease-hood-cleaning-near-me-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-768x1024.jpg`}
            alt="Commercial hood cleaning for Antioch TN restaurants - DDAN Hood Cleaning"
            class="w-full rounded-2xl border-[3px] border-[#FF5E15]"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- LOCAL COMPLIANCE -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Antioch Fire Code & Compliance
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Antioch falls under the Metro Nashville Fire Marshal's Office — the same jurisdiction as downtown Nashville. Inspectors aggressively target older, repurposed restaurant spaces in Antioch to ensure ventilation systems have been brought up to current <a href="/nfpa-code-96-standards/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">NFPA 96 codes</a>. If your kitchen was converted from a retail space or inherited an exhaust system from a previous tenant, expect heightened scrutiny during inspections.
      </p>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Metro Water Services F.O.G. (Fats, Oils, and Grease) compliance is a major enforcement target in Antioch due to the high grease production from the area's restaurant density. Rooftop grease runoff that reaches storm drains carries serious fines. A proper grease containment system and regular cleaning schedule are not optional — they are required.
      </p>
      <ul class="space-y-3 mb-6">
        <li class="check-item reveal-child">Metro Nashville Fire Marshal inspections — NFPA 96 bare-metal standard</li>
        <li class="check-item reveal-child">Metro Water Services F.O.G. compliance for grease discharge</li>
        <li class="check-item reveal-child">Timestamped before-and-after photo documentation for every visit</li>
        <li class="check-item reveal-child">Service tag placed on hood after each cleaning</li>
      </ul>
    </div>
  </section>

  <!-- COMMON PROBLEMS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Hood Problems in Antioch Kitchens
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        New restaurant concepts frequently move into older Bell Road buildings without upgrading undersized exhaust systems. The previous tenant may have run a low-grease operation, but a new wok kitchen or charbroiler-heavy menu overwhelms the existing ductwork and fan capacity. This leads to overworked fan motors, heavy grease saturation on older built-up roofs, and a system that cannot pass inspection.
      </p>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        High-heat wok cooking requires aggressive, specialized scraping to remove baked-on carbon from fan impellers — standard methods leave residue that creates a serious fire risk. The carbon scale that forms inside exhaust ducts from wok and open-flame cooking is significantly harder than the grease buildup from standard American restaurant cooking. If your cleaning company is not specifically addressing this, your system is not actually clean.
      </p>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        DDAN technicians are trained to identify and remove this type of buildup. We also flag <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">failing fan motors and belts</a> before they leave your kitchen without ventilation during a dinner rush.
      </p>
    </div>
  </section>

  <!-- PROOF POINT -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="border-l-4 border-[#FF5E15] bg-[#111111] p-6 rounded-r-xl reveal-child">
        <p class="text-[#FF5E15] font-heading font-semibold text-lg mb-3">Real Job — Antioch, TN</p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
          A busy Asian fusion restaurant on Bell Road kept burning out exhaust fan motors due to heavy carbon buildup throwing the fan blades off balance. DDAN came in, scraped the entire system down to bare metal, installed a proper high-capacity motor, and fitted a new rooftop grease containment box, permanently solving their airflow and maintenance nightmare.
        </p>
      </div>
    </div>
  </section>

  <!-- 3-STEP PROCESS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Our Cleaning Process
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-10 reveal-child">
        Three steps to a safe, compliant, fully documented kitchen exhaust system.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {[
          { num: '01', title: 'Inspection & Quote', desc: 'We assess your entire exhaust system — hood, ducts, fans, filters, and containment. You get a free, no-obligation estimate. Free within 15 miles of Mt. Juliet.' },
          { num: '02', title: 'Overnight Deep Clean', desc: 'Our crew works around your schedule — typically 10 PM to 6 AM. Every component cleaned to bare metal per NFPA 96. Aggressive scraping for high-heat carbon buildup.' },
          { num: '03', title: 'Documentation & Report', desc: 'Before-and-after photos, written service report, deficiency notes, compliance confirmation, and a service tag on your hood. Ready for any Metro Nashville inspector.' },
        ].map((card) => (
          <div class="relative bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl pt-12 pb-6 px-6 flex flex-col min-h-[240px] hover:border-white hover:-translate-y-2 transition-all duration-300 reveal-child">
            <span class="absolute -top-6 left-1/2 -translate-x-1/2 w-[50px] h-[50px] bg-[#FF5E15] rounded-lg flex items-center justify-center text-white font-heading font-bold text-2xl shadow-lg">{card.num}</span>
            <h3 class="font-heading text-[#FF5E15] text-xl font-bold mb-3 text-center md:text-left">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 flex-grow text-center md:text-left">{card.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <button type="button" class="popup-trigger inline-flex items-center gap-2 px-12 md:px-[100px] py-5 w-full md:w-auto bg-transparent text-white font-body text-[1.2rem] font-medium border-2 border-[#FF5E15] rounded-full hover:bg-[#FF5E15] transition-all duration-300 reveal-child">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Schedule Your Cleaning
        </button>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA LINKS -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Antioch Service Area & Nearby Cities
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Steady year-round demand, with upticks during major summer heatwaves that push aging fan motors past their limits. Don't wait for a breakdown — schedule proactive cleaning now.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Other Services in Antioch</p>
          <ul class="space-y-2">
            <li><a href="/repair/antioch-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hood Repair — Antioch, TN</a></li>
            <li><a href="/parts-installation/antioch-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Exhaust Fan Parts — Antioch, TN</a></li>
          </ul>
        </div>
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Nearby Cities</p>
          <ul class="space-y-2">
            <li><a href="/cleaning/la-vergne-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">La Vergne, TN</a></li>
            <li><a href="/cleaning/smyrna-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Smyrna, TN</a></li>
            <li><a href="/cleaning/nashville-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Nashville, TN</a></li>
          </ul>
        </div>
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Service Hub</p>
          <ul class="space-y-2">
            <li><a href="/cleaning/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">All Hood Cleaning Service Areas</a></li>
            <li><a href="/kitchen-hood-cleaning-services/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hood Cleaning Services Overview</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Antioch Hood Cleaning FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-[#111111] border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-[#111111] rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- TRUCK CTA -->
  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
