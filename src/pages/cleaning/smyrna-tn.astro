---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'Do you offer emergency exhaust fan repair on Sam Ridley Parkway?',
    a: `Yes. We know that the Smyrna lunch rush waits for no one. If your exhaust fan motor burns out or a belt snaps, our 24/7 emergency team can be on-site within 45 minutes to get your system running again. Call ${business.phone} any time.`,
  },
  {
    q: 'What is the penalty for a dirty kitchen exhaust hood in Smyrna?',
    a: 'The Smyrna Fire Department enforces NFPA 96 fire codes. A grease-laden system is a fire hazard and code violation that can result in fines, mandatory remediation, or kitchen shutdown until compliance is achieved.',
  },
  {
    q: 'How do I stop grease from leaking onto my restaurant roof?',
    a: 'Grease leaking from the upblast fan requires a high-capacity rooftop grease containment system. We install custom-fit containment boxes with replaceable absorption pads that capture grease before it damages your roof.',
  },
  {
    q: 'Do you service food trucks?',
    a: 'Yes. Food trucks have compact exhaust systems that still fall under NFPA 96 requirements. We clean food truck hoods, ducts, and fans with the same bare-metal standard we apply to full-size restaurant systems.',
  },
];

const siteUrl = import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev';

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#business`,
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": siteUrl,
      "image": `${siteUrl}/images/logo.png`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": "Mt. Juliet",
        "addressRegion": "TN",
        "postalCode": "37122",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Smyrna",
        "addressRegion": "TN"
      },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "serviceType": "Commercial Kitchen Hood Cleaning",
      "provider": { "@id": `${siteUrl}/#business` },
      "areaServed": {
        "@type": "City",
        "name": "Smyrna",
        "addressRegion": "TN"
      },
      "description": "NFPA 96 compliant commercial kitchen hood cleaning for Smyrna restaurants and commercial kitchens. Bare-metal cleaning with full photo documentation."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Hood Cleaning", "item": `${siteUrl}/cleaning/` },
        { "@type": "ListItem", "position": 3, "name": "Smyrna, TN", "item": `${siteUrl}/cleaning/smyrna-tn/` }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="Smyrna Kitchen Exhaust Hood Cleaning Service | DDAN"
  description="Hood cleaning for Smyrna's Sam Ridley Parkway restaurants. Nissan plant lunch-rush kitchens need reliable exhaust. 24/7 service. (615) 881-6968."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/rooftop-exhaust-fan.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/cleaning/" class="hover:text-[#FF5E15] transition-all duration-300">Hood Cleaning</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Smyrna, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        <span class="text-[#FF5E15]">Smyrna, TN</span> Kitchen Exhaust Hood Cleaning Service
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Keeping Sam Ridley Parkway's busiest kitchens clean, compliant, and running through the Nissan lunch rush
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Why Smyrna's Busiest Kitchens Need Professional Hood Cleaning
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Smyrna's Sam Ridley Parkway is the commercial backbone of this Rutherford County city, and it runs hot. The Nissan Smyrna Vehicle Assembly Plant — the largest auto manufacturing plant in North America — drives a massive industrial workforce that floods local restaurants during every shift change. Quick-service lunch spots, Southern comfort food restaurants, and corporate chains along Sam Ridley are under constant high-volume pressure. When the Nissan shift lets out, every kitchen on that corridor is cooking at maximum capacity, pushing exhaust systems to their limits.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          StoneCrest Medical Center adds institutional kitchen demand on the healthcare side, with cafeteria-scale cooking operations that run throughout the day. Rooftop construction across Smyrna's commercial corridors is a mix of TPO and EPDM on retail buildings and heavy metal or built-up roofing on industrial facilities — each presenting different grease containment challenges. What ties all of Smyrna's commercial kitchens together is the relentless use of fryers. Southern cooking and quick-service menus mean fryers are running non-stop, producing aggressive grease accumulation that demands frequent, thorough cleaning.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN provides thorough, NFPA 96-compliant hood cleaning throughout Smyrna and Rutherford County. We clean every component from hood canopy to rooftop fan, document everything with before-and-after photos, and ensure your grease containment is functioning properly — keeping your kitchen compliant, safe, and running through every rush.
        </p>
      </div>
    </div>
  </section>

  <!-- WHAT WE CLEAN -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        What We Clean — Hood to Rooftop
      </h2>
      <ul class="space-y-3 max-w-3xl">
        <li class="check-item reveal-child">Hood canopies and plenums</li>
        <li class="check-item reveal-child">Exhaust ductwork — including sections accessed through <a href="/access-panel-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">fire-rated access panels</a></li>
        <li class="check-item reveal-child">Exhaust fans and motors</li>
        <li class="check-item reveal-child">Grease filters and baffles</li>
        <li class="check-item reveal-child">Rooftop <a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">grease containment systems</a> — grease boxes, pads, and drip guards</li>
        <li class="check-item reveal-child">Before-and-after photo documentation for compliance, insurance, and fire marshal inspections</li>
      </ul>
    </div>
  </section>

  <!-- LOCAL COMPLIANCE -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Smyrna Hood Cleaning Compliance
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          The Smyrna Fire Department is rigorous when it comes to commercial kitchen compliance. With such a high density of industrial operations in the area, inspectors prioritize functional fire suppression systems and clean ductwork as core safety requirements. Smyrna fire inspectors enforce NFPA 96 standards and expect documented proof that your exhaust system has been cleaned to bare metal on the schedule dictated by your cooking volume. If you cannot produce cleaning records, you are not in compliance — regardless of how the system looks.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Smyrna Utilities strictly enforces FOG (fats, oils, and grease) regulations using local ordinances that target commercial kitchens specifically. Restaurants are required to maintain grease interceptors and prevent grease from entering the sewer system. This adds another layer of compliance on top of fire code — your rooftop grease containment must be working properly to prevent runoff, and your grease traps must be maintained. DDAN handles the exhaust system side, ensuring your rooftop containment is inspected and serviced on every cleaning visit.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Read our full guide to <a href="/nfpa-code-96-standards/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">NFPA 96 compliance standards</a> to understand exactly what inspectors look for.
        </p>
      </div>
    </div>
  </section>

  <!-- COMMON PROBLEMS IN SMYRNA -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Hood Cleaning Problems in Smyrna
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          The Sam Ridley Parkway corridor sees immense, continuous lunch-rush volume driven by the Nissan plant's shift changes. This non-stop, high-heat operation causes exhaust fan motors to overheat and fail prematurely — especially during July and August when ambient rooftop temperatures push well above 130 degrees. Motors that are already working at capacity simply cannot dissipate enough heat, and bearings seize or windings burn out. DDAN sees a spike in emergency <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">exhaust fan belt and motor repair</a> calls from Smyrna every summer, and we stock the most common replacement motors to ensure same-day service.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          The second major problem is heavy grease production from relentless fryer usage. Southern cooking menus and quick-service operations in Smyrna run fryers at full capacity for hours at a time, producing volumes of grease that overwhelm standard factory grease catchers. The small, OEM grease cups that come with most upblast fans fill up within days and start overflowing onto the roof membrane. This is especially damaging on the TPO and EPDM roofs common along the Sam Ridley retail corridor. DDAN installs high-capacity <a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">rooftop grease containment systems</a> designed for the actual grease volume your kitchen produces — not the light-duty estimates from the manufacturer.
        </p>
      </div>
    </div>
  </section>

  <!-- PROOF POINT -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="border-l-4 border-[#FF5E15] bg-[#111111] p-6 rounded-r-xl max-w-3xl reveal-child">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed italic">
          "During a massive July heatwave, a high-volume Southern cooking restaurant on Sam Ridley Parkway had their main exhaust fan motor burn out right before the Nissan lunch shift. DDAN arrived within 45 minutes, installed a new, heat-rated 3-phase motor, and had the system pulling smoke perfectly before the first table was seated."
        </p>
      </div>
    </div>
  </section>

  <!-- CLEANING PROCESS -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Our Cleaning Process
      </h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-10 reveal-child">
        Three steps to a safe, compliant, fully documented kitchen exhaust system.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
        {[
          { num: '01', title: 'Inspection & Quote', desc: 'We assess your entire exhaust system — hood, ducts, fans, filters, and containment. You get a free, no-obligation estimate with a clear scope of work and pricing.' },
          { num: '02', title: 'Overnight Deep Clean', desc: 'Our crew works around your schedule — typically 10 PM to 6 AM. Every component cleaned to bare metal per NFPA 96. Eco-friendly degreasers, no shortcuts, no disruption to your business.' },
          { num: '03', title: 'Documentation & Report', desc: 'Before-and-after photos, written service report, deficiency notes, compliance confirmation, and a service tag on your hood. Ready for any fire marshal inspection.' },
        ].map((card) => (
          <div class="relative bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl pt-12 pb-6 px-6 flex flex-col min-h-[240px] hover:border-white hover:-translate-y-2 transition-all duration-300 reveal-child">
            <span class="absolute -top-6 left-1/2 -translate-x-1/2 w-[50px] h-[50px] bg-[#FF5E15] rounded-lg flex items-center justify-center text-white font-heading font-bold text-2xl shadow-lg">{card.num}</span>
            <h3 class="font-heading text-[#FF5E15] text-xl font-bold mb-3 text-center md:text-left">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 flex-grow text-center md:text-left">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Smyrna Hood Cleaning Service Area
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN serves all of Smyrna and the surrounding Rutherford County area. Whether your restaurant is on Sam Ridley Parkway, Lowry Street, near StoneCrest Medical Center, or anywhere in the Smyrna city limits, we provide the same thorough, NFPA 96-compliant hood cleaning service with full photo documentation. Our crews know the Smyrna area and schedule service around your kitchen's busiest hours.
        </p>
        <div class="space-y-3 reveal-child">
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also in Smyrna:</span>
            <a href="/repair/smyrna-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Exhaust Fan Repair</a> &middot;
            <a href="/parts-installation/smyrna-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Parts & Installation</a>
          </p>
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also serving nearby:</span>
            <a href="/cleaning/murfreesboro-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Murfreesboro</a> and
            <a href="/cleaning/la-vergne-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">La Vergne</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Smyrna Hood Cleaning FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-[#111111] border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-[#111111] rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CITY-SPECIFIC URGENCY + TRUCK CTA -->
  <section class="bg-black py-12 md:py-16 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <p class="text-[#D4D4D4] font-body text-lg leading-relaxed text-center max-w-3xl mx-auto reveal-child">
        Emergency repair calls spike during peak July and August heat when overworked fan motors finally burn out. Don't wait for a heatwave to test your system.
      </p>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
