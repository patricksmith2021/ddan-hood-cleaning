    headline="Sitemap"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Sitemap' },
    ]}
  />

  <section class="reveal bg-[#111111] py-16">
    <div class="container-narrow">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {pageGroups.map((group) => (
          <div>
            <h2 class="text-primary font-heading font-semibold text-lg mb-3">{group.title}</h2>
            <ul>
              {group.pages.map((page) => (
                <li>
                  <a
                    href={page.href}
                    class="text-body-text hover:text-primary transition-all duration-300 text-sm py-1 block"
                  >
                    {page.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
