---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import business from '../data/business.json';
---

<BaseLayout
  title="Thank You | DDAN Hood Cleaning and Repair"
  description="Thank you for contacting DDAN Hood Cleaning and Repair. We'll get back to you shortly."
  noindex={true}
>
  <HeroBanner
    headline="Thank You!"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Thank You' },
    ]}
  />

  <section class="reveal bg-[#111111] py-12 md:py-20 px-5">
    <div class="max-w-[600px] mx-auto text-center">
      <p class="font-heading text-xl md:text-2xl text-white mb-4 reveal-child">
        Your request has been received! A member of our team will be in touch with you shortly.
      </p>
      <p class="text-[#D4D4D4] font-body text-lg mb-6 reveal-child">
        For immediate assistance, call us directly:
      </p>
      <a href={`tel:${business.phoneRaw}`} class="btn-primary text-lg justify-center mb-8 reveal-child">
        {business.phone}
      </a>
      <p class="text-[#999999] text-sm mb-8 reveal-child">
        We typically respond within 1 business hour during normal business hours. For emergencies, we offer 24/7 phone support.
      </p>
      <a href="/" class="btn-ghost justify-center reveal-child">
        Return to Home
      </a>
    </div>
  </section>
</BaseLayout>
