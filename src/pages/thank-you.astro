---
import BaseLayout from '../layouts/BaseLayout.astro';
import business from '../data/business.json';
---

<BaseLayout
  title="Thank You | DDAN Hood Cleaning and Repair"
  description="Thank you for contacting DDAN Hood Cleaning and Repair. We'll get back to you shortly."
  noindex={true}
>

  <!-- SECTION 1: Animated Success Confirmation -->
  <section class="relative overflow-hidden flex items-center justify-center px-5" style="min-height:80vh; background: linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.85)), url('/images/homepage/truck-cta-bg.webp'); background-size:cover; background-position:center;">

    <div class="relative z-10 max-w-[700px] mx-auto text-center py-20">

      <!-- Animated Checkmark -->
      <div class="checkmark-container mx-auto mb-8">
        <svg class="checkmark-svg" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
          <circle class="checkmark-circle" cx="60" cy="60" r="54" fill="none" stroke="#FF5E15" stroke-width="4" />
          <path class="checkmark-check" d="M38 62 L52 76 L82 46" fill="none" stroke="#FFFFFF" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>

      <!-- Text (fades in after animation) -->
      <div class="thankyou-text">
        <h1 class="font-display text-white text-3xl md:text-5xl font-bold mb-4">We Got Your Request!</h1>
        <p class="font-body text-[#D4D4D4] text-base md:text-lg leading-relaxed mb-8 max-w-[500px] mx-auto">
          A member of the DDAN team will reach out within the hour. For emergencies, call us now.
        </p>
        <a href={`tel:${business.phoneRaw}`} class="btn-primary text-lg justify-center mb-5 inline-flex">
          {business.phone}
        </a>
        <p class="text-[#999999] text-sm">
          24/7 Emergency Service &bull; Licensed, Bonded &amp; Insured
        </p>
      </div>

      <!-- Truck drives in -->
      <div class="mt-10">
        <img src="/images/truck.png" alt="DDAN Hood Cleaning and Repair truck" width="781" height="319" class="truck-drive-in max-w-full w-full md:w-auto mx-auto" loading="eager" style="animation-delay: 1.5s;" />
      </div>

    </div>
  </section>

  <!-- SECTION 2: Helpful Resources -->
  <section class="py-16 md:py-20 px-5 bg-[#111111]">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="font-heading text-white text-2xl md:text-3xl font-semibold text-center mb-10">While You Wait — Learn More About Kitchen Exhaust Safety</h2>

      <style>
        .thankyou-grid {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 1.5rem;
        }
        @media (max-width: 768px) {
          .thankyou-grid {
            grid-template-columns: 1fr !important;
          }
        }
      </style>

      <div class="thankyou-grid">

        <!-- Card 1: NFPA 96 -->
        <div class="bg-[#1A1A1A] border border-[#FF5E15] rounded-xl p-8 reveal">
          <svg class="w-10 h-10 text-[#FF5E15] mb-4" fill="currentColor" viewBox="0 0 512 512"><path d="M256 0c4.6 0 9.2 1 13.4 2.9L457.7 82.8c22 9.3 38.4 31 38.3 57.2c-.5 99.2-41.3 280.7-213.6 363.2c-16.7 8-36.1 8-52.8 0C57.3 420.7 16.5 239.2 16 140c-.1-26.2 16.3-47.9 38.3-57.2L242.7 2.9C246.8 1 251.4 0 256 0z"/></svg>
          <h3 class="font-heading text-white text-xl font-semibold mb-3">NFPA 96 Standards</h3>
          <p class="font-body text-[#D4D4D4] text-sm leading-relaxed mb-5">Understand the fire code that governs every commercial kitchen exhaust system in Tennessee and Kentucky.</p>
          <a href="/nfpa-code-96-standards/" class="inline-flex items-center gap-2 text-[#FF5E15] font-heading font-semibold text-sm hover:gap-3 transition-all duration-200">
            Learn More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
        </div>

        <!-- Card 2: FAQ -->
        <div class="bg-[#1A1A1A] border border-[#FF5E15] rounded-xl p-8 reveal">
          <svg class="w-10 h-10 text-[#FF5E15] mb-4" fill="currentColor" viewBox="0 0 512 512"><path d="M256 512A256 256 0 10256 0a256 256 0 100 512zM169.8 165.3c7.9-22.3 29.1-37.3 52.8-37.3h58.3c34.9 0 63.1 28.3 63.1 63.1 0 22.6-12.1 43.5-31.7 54.8L280 264.4c-.2 13-10.9 23.6-24 23.6c-13.3 0-24-10.7-24-24V250.5c0-8.6 4.6-16.5 12.1-20.8l44.3-25.4c4.7-2.7 7.6-7.7 7.6-13.1 0-8.4-6.8-15.1-15.1-15.1H222.6c-3.4 0-6.4 2.1-7.5 5.3l-.4 1.2c-4.4 12.5-18.2 19-30.6 14.6s-19-18.2-14.6-30.6l.4-1.2zM224 352a32 32 0 1164 0 32 32 0 11-64 0z"/></svg>
          <h3 class="font-heading text-white text-xl font-semibold mb-3">Kitchen Exhaust FAQ</h3>
          <p class="font-body text-[#D4D4D4] text-sm leading-relaxed mb-5">Answers to the most common questions about hood cleaning schedules, repair costs, and compliance.</p>
          <a href="/kitchen-exhaust-faq/" class="inline-flex items-center gap-2 text-[#FF5E15] font-heading font-semibold text-sm hover:gap-3 transition-all duration-200">
            Learn More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
        </div>

        <!-- Card 3: How Your System Works -->
        <div class="bg-[#1A1A1A] border border-[#FF5E15] rounded-xl p-8 reveal">
          <svg class="w-10 h-10 text-[#FF5E15] mb-4" fill="currentColor" viewBox="0 0 512 512"><path d="M495.9 166.6c3.2 8.7 .5 18.4-6.4 24.6l-43.3 39.4c1.1 8.3 1.7 16.8 1.7 25.4s-.6 17.1-1.7 25.4l43.3 39.4c6.9 6.2 9.6 15.9 6.4 24.6c-4.4 11.9-9.7 23.3-15.8 34.3l-4.7 8.1c-6.6 11-14 21.4-22.1 31.2c-5.9 7.2-15.7 9.6-24.5 6.8l-55.7-17.7c-13.4 10.3-28.2 18.9-44 25.4l-12.5 57.1c-2 9.1-9 16.3-18.2 17.8c-13.8 2.3-28 3.5-42.5 3.5s-28.7-1.2-42.5-3.5c-9.2-1.5-16.2-8.7-18.2-17.8l-12.5-57.1c-15.8-6.5-30.6-15.1-44-25.4L83.1 425.9c-8.8 2.8-18.6 .3-24.5-6.8c-8.1-9.8-15.5-20.2-22.1-31.2l-4.7-8.1c-6.1-11-11.4-22.4-15.8-34.3c-3.2-8.7-.5-18.4 6.4-24.6l43.3-39.4C64.6 273.1 64 264.6 64 256s.6-17.1 1.7-25.4L22.4 191.2c-6.9-6.2-9.6-15.9-6.4-24.6c4.4-11.9 9.7-23.3 15.8-34.3l4.7-8.1c6.6-11 14-21.4 22.1-31.2c5.9-7.2 15.7-9.6 24.5-6.8l55.7 17.7c13.4-10.3 28.2-18.9 44-25.4l12.5-57.1c2-9.1 9-16.3 18.2-17.8C227.3 1.2 241.5 0 256 0s28.7 1.2 42.5 3.5c9.2 1.5 16.2 8.7 18.2 17.8l12.5 57.1c15.8 6.5 30.6 15.1 44 25.4l55.7-17.7c8.8-2.8 18.6-.3 24.5 6.8c8.1 9.8 15.5 20.2 22.1 31.2l4.7 8.1c6.1 11 11.4 22.4 15.8 34.3zM256 336a80 80 0 100-160 80 80 0 100 160z"/></svg>
          <h3 class="font-heading text-white text-xl font-semibold mb-3">How Your System Works</h3>
          <p class="font-body text-[#D4D4D4] text-sm leading-relaxed mb-5">See exactly how your kitchen ventilation system is built — from hood canopy to rooftop fan.</p>
          <a href="/how-your-kitchen-ventilation-system-works/" class="inline-flex items-center gap-2 text-[#FF5E15] font-heading font-semibold text-sm hover:gap-3 transition-all duration-200">
            Learn More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  /* Checkmark container */
  .checkmark-container {
    width: 80px;
    height: 80px;
  }
  @media (min-width: 768px) {
    .checkmark-container {
      width: 120px;
      height: 120px;
    }
  }

  .checkmark-svg {
    width: 100%;
    height: 100%;
  }

  /* Circle draws itself */
  .checkmark-circle {
    stroke-dasharray: 340;
    stroke-dashoffset: 340;
    animation: drawCircle 0.6s ease-out 0.2s forwards;
  }

  /* Checkmark draws after circle */
  .checkmark-check {
    stroke-dasharray: 80;
    stroke-dashoffset: 80;
    animation: drawCheck 0.4s ease-out 0.8s forwards;
  }

  /* Text fades in after animations */
  .thankyou-text {
    opacity: 0;
    transform: translateY(15px);
    animation: fadeInUp 0.5s ease-out 1.2s forwards;
  }

  @keyframes drawCircle {
    to { stroke-dashoffset: 0; }
  }

  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Override truck animation delay for this page */
  .truck-drive-in {
    opacity: 0;
    transform: translateX(100%);
    animation: truckDriveIn 0.8s ease-out 1.5s forwards;
  }

  @keyframes truckDriveIn {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>
