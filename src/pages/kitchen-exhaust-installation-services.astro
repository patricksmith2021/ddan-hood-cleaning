---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import InlineCTA from '../components/InlineCTA.astro';
import ServiceAreaGrid from '../components/ServiceAreaGrid.astro';
import TruckCTA from '../components/TruckCTA.astro';
---

<BaseLayout
  title="Kitchen Ventilation Installation & Replacement"
  description="Full kitchen ventilation system installation and replacement. We install hoods, ducts, fans, and suppression systems to code. Mt. Juliet & Nashville."
>
  <HeroBanner
    headline="Kitchen Ventilation Installation | DDAN Hood Cleaning and Repair"
    subheadline="Full Commercial Kitchen Hood & Exhaust System Installation | Serving Mt. Juliet & Greater Nashville"
    backgroundImage="/images/services/hood-cleaning.jpg"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Kitchen Ventilation Installation' },
    ]}
  />

  <!-- Commercial Kitchen Ventilation Installation -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">

      <div class="reveal">
        <h2 class="section-headline reveal-child">Commercial Kitchen Ventilation Installation -- Built to Perform, Built to Last</h2>
        <p class="text-[#D4D4D4] mb-4 reveal-child">Opening a new restaurant? Renovating an older kitchen? You need a ventilation system that works right from day one. At DDAN Hood Cleaning and Repair, we install complete commercial kitchen exhaust systems across Middle Tennessee. Every installation is built to NFPA 96 fire code and engineered to hold up in real-world kitchens.</p>
        <p class="text-[#D4D4D4] mb-4 reveal-child">We provide full system installations, including:</p>
        <ul class="space-y-2 mb-4">
          <li class="check-item reveal-child">Commercial exhaust hoods</li>
          <li class="check-item reveal-child">Grease ductwork</li>
          <li class="check-item reveal-child">Rooftop exhaust fans</li>
          <li class="check-item reveal-child">Makeup air units (MUA)</li>
          <li class="check-item reveal-child">Rooftop grease containment systems</li>
        </ul>
        <p class="text-[#D4D4D4] mb-6 reveal-child">Whether it's a food truck or a full-scale restaurant, your system will be built to code, mounted securely, and ready to pass inspection.</p>
      </div>

    </div>
  </section>

  <!-- Full Ventilation System Installations -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">

      <div class="reveal">
        <h2 class="section-headline reveal-child">Full Ventilation System Installations</h2>
        <p class="text-[#D4D4D4] mb-6 reveal-child">We handle everything from sizing and layout to final electrical hookup.</p>

        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Commercial Exhaust Hood Installation</h3>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Precise sizing for your equipment and layout</li>
          <li class="check-item reveal-child">Wall-mounted, island, and custom configurations</li>
          <li class="check-item reveal-child">Proper capture area and smooth airflow transitions</li>
        </ul>
      </div>

      <InlineCTA headline="Get a Commercial Kitchen Installation Quote" />

      <div class="reveal mt-8">
        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Grease Duct Fabrication & Routing</h3>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Custom ductwork designed for airflow and access</li>
          <li class="check-item reveal-child">Fully welded, sealed, and pitched for drainage</li>
          <li class="check-item reveal-child">Heavy-duty, fire-rated materials with secure supports</li>
        </ul>

        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Rooftop Exhaust Fan Installation</h3>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">High-CFM fans matched to your kitchen's needs</li>
          <li class="check-item reveal-child">Hinged units for easy maintenance and cleaning</li>
          <li class="check-item reveal-child">Weatherproof sealing to protect your roof and system</li>
        </ul>

        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Makeup Air Unit (MUA) Installation</h3>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Delivers fresh, tempered air to balance kitchen pressure</li>
          <li class="check-item reveal-child">Prevents smoke and odors from escaping into dining areas</li>
          <li class="check-item reveal-child">Available in wall-mounted or rooftop-mounted designs</li>
        </ul>

        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Rooftop Grease Containment Installation</h3>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Captures grease before it damages the roof</li>
          <li class="check-item reveal-child">Installed with easy-access brackets for pad changes</li>
          <li class="check-item reveal-child">Protects EPDM, TPO, and other flat roofing systems</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- NFPA 96 Compliant & More -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">

      <div class="reveal">
        <h2 class="section-headline reveal-child">NFPA 96 Compliant & More</h2>
        <p class="text-[#D4D4D4] mb-4 reveal-child">We build every system to NFPA 96 fire safety code — but that's just the baseline. We also focus on:</p>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Airflow performance that prevents hot spots and smoke buildup</li>
          <li class="check-item reveal-child">Smart placement of access panels for future cleanings</li>
          <li class="check-item reveal-child">Materials that withstand heat, grease, and daily use</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Who We Install For -->
  <section class="bg-[#1A1A1A] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">

      <div class="reveal">
        <h2 class="section-headline reveal-child">Who We Install For</h2>
        <p class="text-[#D4D4D4] mb-4 reveal-child">We work with a wide range of commercial kitchens, including:</p>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Independent restaurants and national franchises</li>
          <li class="check-item reveal-child">Food trucks, ghost kitchens, and shared commissaries</li>
          <li class="check-item reveal-child">Hospitality groups, schools, hospitals, and churches</li>
          <li class="check-item reveal-child">General contractors building out new kitchens or remodels</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Split text/image section -->
  <section class="bg-[#1A1A1A] section-padding">
    <div class="container-narrow reveal">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="section-headline reveal-child">Installation Timeline & Costs</h2>
          <p class="text-[#D4D4D4] mb-4 reveal-child">Every install is custom, but here's a general idea of what to expect:</p>
          <ul class="space-y-2 mb-4">
            <li class="check-item reveal-child">Timeline: Most projects take 2-5 days</li>
            <li class="check-item reveal-child">Parts Only: Equipment costs typically range from $2,000-$10,000+</li>
            <li class="check-item reveal-child">Full Buildouts: Priced after a detailed on-site consultation</li>
          </ul>
          <p class="text-[#D4D4D4] mb-6 reveal-child">Working against the clock? We're used to fast-tracking installs for restaurants under pressure from health inspections or remodel deadlines.</p>
          <button type="button" class="btn-primary popup-trigger reveal-child">Request Service Online</button>
        </div>
        <div class="reveal-child">
          <img
            src="/images/services/rooftop-grease-containment.jpg"
            alt="rooftop grease containment installation - DDAN Hood Cleaning and Repair"
            class="w-full rounded"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <ServiceAreaGrid
    headline="Service Area"
    intro="We serve kitchens throughout Middle Tennessee:"
    outro="Managing multiple locations or a regional rollout? We can help with that too."
  />

  <TruckCTA />
</BaseLayout>
