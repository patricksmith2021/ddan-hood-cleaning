---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import business from '../data/business.json';
---

<BaseLayout
  title="Verified Google Reviews | DDAN Hood Cleaning and Repair"
  description="Read verified Google reviews from DDAN Hood Cleaning and Repair customers across Nashville and Middle Tennessee."
>
  <HeroBanner
    headline="Reviews"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Reviews' },
    ]}
  />

  <!-- Reviews Section -->
  <section class="section-padding">
    <div class="container-narrow reveal">
      <div class="text-center mb-10">
        <h2 class="section-headline mb-4 reveal-child">Verified Customer Reviews</h2>
        <p class="text-body-text max-w-2xl mx-auto reveal-child">Commercial Kitchen Exhaust System Experts: Cleaning, Repair, Installation &amp; Parts Sales in the Nashville Metro Area</p>
      </div>

      <!-- Trustindex Widget -->
      <div class="bg-secondary rounded p-6 mb-8 reveal-child">
        <div id="trustindex-reviews-widget">
          <script type="text/javascript" src="https://cdn.trustindex.io/loader.js?wp-widget" defer></script>
        </div>
      </div>

      <!-- Google Reviews CTA -->
      <div class="text-center reveal-child">
        <a href={business.googleReviewUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
          See All Reviews on Google
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
