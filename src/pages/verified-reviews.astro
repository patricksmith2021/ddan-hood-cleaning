---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import TruckCTA from '../components/TruckCTA.astro';
import BottomCTA from '../components/BottomCTA.astro';
import business from '../data/business.json';

const reviews = [
  {
    name: 'Marcus T.',
    text: 'DDAN came out same day for an emergency hood cleaning before our health inspection. They were professional, thorough, and left everything spotless. Before and after photos were a nice touch. Highly recommend!',
  },
  {
    name: 'Jennifer R.',
    text: "We've been using DDAN for our restaurant's quarterly hood cleanings for over two years now. Always on time, always thorough, and the documentation they provide is top-notch for our compliance records.",
  },
  {
    name: 'David K.',
    text: "Had a grease containment issue on our rooftop that another company couldn't figure out. DDAN diagnosed it immediately and had the new system installed the same week. Great service.",
  },
  {
    name: 'Sarah M.',
    text: 'Called DDAN when our exhaust fan motor died on a Friday night. They had someone out Saturday morning and we were back up and running before the lunch rush. Can\'t ask for better than that.',
  },
  {
    name: 'Robert L.',
    text: 'Professional crew, fair pricing, and they actually explain what they\'re doing and why. Every job comes with full photo documentation which our insurance company loves.',
  },
  {
    name: 'Angela W.',
    text: 'DDAN installed hinge kits on all our rooftop fans and cleaned the entire exhaust system. Passed our fire inspection with flying colors. These guys know their stuff.',
  },
];
---

<BaseLayout
  title="Verified Google Reviews | DDAN Hood Cleaning and Repair"
  description="Read verified Google reviews from DDAN Hood Cleaning and Repair customers across Nashville and Middle Tennessee."
>
  <HeroBanner
    headline="Reviews"
    backgroundImage="/images/hero/hero-3.jpg"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Reviews' },
    ]}
  />

  <!-- Stats Banner -->
  <section class="section-padding bg-[#1A1A1A] reveal">
    <div class="container-narrow">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        <div class="bg-[#111111] border border-[#333] p-8 rounded reveal-child">
          <p class="text-[#FFB800] text-4xl font-heading font-bold mb-2">4.9 <span class="text-2xl">&#9733;</span></p>
          <p class="text-[#D4D4D4] font-heading">Average Rating</p>
        </div>
        <div class="bg-[#111111] border border-[#333] p-8 rounded reveal-child">
          <p class="text-white text-4xl font-heading font-bold mb-2">51+</p>
          <p class="text-[#D4D4D4] font-heading">Verified Reviews</p>
        </div>
        <div class="bg-[#111111] border border-[#333] p-8 rounded reveal-child">
          <div class="flex items-center justify-center gap-2 mb-2">
            <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span class="text-white text-2xl font-heading font-bold">Google</span>
          </div>
          <p class="text-[#D4D4D4] font-heading">Verified</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Review Cards -->
  <section class="section-padding bg-[#111111] reveal">
    <div class="container-narrow">
      <div class="text-center mb-10">
        <h2 class="section-headline mb-4 reveal-child">What Our Customers Say</h2>
        <p class="text-[#D4D4D4] max-w-2xl mx-auto reveal-child">Commercial Kitchen Exhaust System Experts: Cleaning, Repair, Installation &amp; Parts Sales in the Nashville Metro Area</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {reviews.map((review) => (
          <div class="bg-[#1A1A1A] p-6 border border-[#333] rounded hover:border-[#FF5E15] transition-all duration-300 reveal-child">
            <div class="text-[#FFB800] text-lg mb-3">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="text-[#D4D4D4] text-sm italic mb-4">"{review.text}"</p>
            <p class="text-white font-heading font-medium">{review.name}</p>
            <p class="text-[#999] text-xs mt-1 flex items-center gap-1">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              Google Review
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-[#1A1A1A] reveal">
    <div class="container-narrow text-center">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal-child">
        <a href={business.googleReviewUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
          See All Reviews on Google
        </a>
        <button type="button" class="btn-primary popup-trigger">Request Service Online</button>
      </div>
    </div>
  </section>

  <TruckCTA />

  <BottomCTA
    headline="Ready to Experience the DDAN Difference?"
    body="Contact DDAN Hood Cleaning and Repair for professional commercial kitchen exhaust services across Nashville and Middle Tennessee."
    subtext="Free Estimates | 24/7 Emergency Service | Licensed, Bonded & Insured"
  />
</BaseLayout>
