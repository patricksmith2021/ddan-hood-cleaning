---
import BaseLayout from '../layouts/BaseLayout.astro';
import business from '../data/business.json';
import InlineCTA from '../components/InlineCTA.astro';
import TruckCTA from '../components/TruckCTA.astro';

const siteUrl = import.meta.env.SITE || 'https://ddanhoodservices.com';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${siteUrl}/exhaust-fan-belt-motor-repair/`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": business.address.city,
        "addressRegion": business.address.state,
        "postalCode": business.address.zip,
        "addressCountry": "US"
      },
      "areaServed": { "@type": "State", "name": "Tennessee" },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "serviceType": "Exhaust Fan Belt and Motor Repair",
      "provider": { "@type": "LocalBusiness", "name": business.name },
      "areaServed": { "@type": "State", "name": "Tennessee" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Belt & Motor Repair" }
      ]
    }
  ]
};
---

<BaseLayout
  title="Fan Belt & Motor Repair | DDAN Hood Services"
  description="Exhaust fan belt repair and kitchen hood fan motor replacement for commercial kitchens. Same-day belt-driven fan repair, upblast fan motor replacement, and 24/7 emergency service."
>
<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  <!-- SECTION 1: HERO -->
  <section role="img" aria-label="Kitchen exhaust motor service and belt-driven fan repair — DDAN Hood Cleaning and Repair" class="min-h-[400px] md:min-h-[550px] flex items-center justify-center" style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.3) 100%), url('/images/services/exhaust-fan-belt-motor-repair-service.webp') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <p class="text-[#FF5E15] font-heading font-bold text-xs md:text-sm tracking-widest uppercase mb-4">DDAN HOOD CLEANING AND REPAIR</p>
      <h1 class="font-display text-white text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">Exhaust Fan <span class="text-[#FF5E15]">Belt &amp; Motor Repair</span></h1>
      <p class="text-gray-200 font-body text-lg md:text-xl max-w-2xl mx-auto mb-6">Fix fan failures fast with professional hood repair services that restore proper airflow and keep your business running. Same-day diagnostics and commercial kitchen hood repair for all exhaust fan systems.</p>
      <p class="text-white font-heading font-bold text-base md:text-lg mb-2">Same-Day Repair • All Fan Types • Emergency Service 24/7</p>
      <div class="w-20 h-1 bg-[#FF5E15] mx-auto mt-3 mb-8"></div>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5E15] text-white font-heading font-bold text-lg rounded-lg transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
          Call Now: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-[#FF5E15] text-[#FF5E15] font-heading font-bold text-lg rounded-lg hover:bg-[#FF5E15] hover:text-white transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 320 512"><path d="M272 0H48C21.5 0 0 21.5 0 48v416c0 26.5 21.5 48 48 48h224c26.5 0 48-21.5 48-48V48c0-26.5-21.5-48-48-48zM160 480c-17.7 0-32-14.3-32-32s14.3-32 32-32 32 14.3 32 32-14.3 32-32 32zm112-108c0 6.6-5.4 12-12 12H60c-6.6 0-12-5.4-12-12V60c0-6.6 5.4-12 12-12h200c6.6 0 12 5.4 12 12v312z"/></svg>
          Request Service Online
        </button>
      </div>
      <div class="flex justify-center items-center gap-6 mt-8">
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/google-white-logo-1024x337.png" alt="Google" width="1024" height="337" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/facebook-logo-white-full-transparent-1024x341.png" alt="Facebook" width="1024" height="341" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/YELP_BIG.D-5a67c069-1024x392.png" alt="Yelp" width="1024" height="392" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BREADCRUMB STRIP -->
  <div class="bg-[#0A0A0A] py-2 px-5">
    <div class="max-w-[1200px] mx-auto">
      <nav class="flex items-center gap-2 text-sm font-heading text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF5E15] transition-colors">Home</a>
        <span class="text-[#FF5E15]">/</span>
        <span class="text-gray-300">Exhaust Fan Belt & Motor Repair</span>
      </nav>
    </div>
  </div>

  <!-- Main Content -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">

      <div class="reveal">
        <p class="font-heading font-semibold text-lg text-white mb-4 reveal-child">Fix Fan Failures Fast. Restore Proper Airflow. Keep Your Business Running.</p>
        <h2 class="section-headline reveal-child">What Keeps Your Exhaust System Running</h2>
        <p class="text-[#D4D4D4] mb-4 reveal-child">In a commercial kitchen, your exhaust fan system does more than move air — it keeps your operation safe and compliant. Two of the most critical parts are the motor and the fan belt. If either one fails, your entire ventilation system is compromised. That is why kitchen hood fan motor replacement and exhaust fan belt repair are among our most requested services.</p>
        <p class="text-[#D4D4D4] mb-6 reveal-child">At DDAN Hood Cleaning and Repair, we specialize in fast, reliable exhaust fan motor repair and belt-driven fan repair. Whether your fan is rattling, humming, or completely dead, our fan motor troubleshooting service pinpoints the problem quickly and gets it fixed — usually the same day.</p>
      </div>

      <div class="reveal mt-8">
        <h2 class="section-headline reveal-child">Signs You Need Exhaust Fan Noise Repair or Motor Service</h2>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Squealing or screeching noises coming from the rooftop unit — common exhaust fan noise repair issue</li>
          <li class="check-item reveal-child">Weak airflow or suction from your kitchen hood</li>
          <li class="check-item reveal-child">Fan not turning on or running intermittently</li>
          <li class="check-item reveal-child">Visible belt wear: fraying, cracks, or looseness</li>
          <li class="check-item reveal-child">Fan blades turning slowly or unevenly</li>
          <li class="check-item reveal-child">Motor overheating, humming, or tripping breakers</li>
        </ul>
        <p class="text-[#D4D4D4] mb-6 reveal-child">If you notice any of these issues, don't wait — a small part failure can turn into a system-wide shutdown fast. Call for commercial kitchen fan maintenance before it escalates.</p>
      </div>

      <div class="reveal mt-8">
        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Exhaust Fan Belt Repair and Replacement</h3>
        <p class="text-[#D4D4D4] mb-4 reveal-child">Fan belts transfer power from your motor to your fan blades. If a belt wears out, your airflow disappears. Our belt-driven fan repair service covers all commercial fan belt parts and sizes.</p>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">Inspection and tension testing of existing fan belts</li>
          <li class="check-item reveal-child">On-site replacement using high-quality commercial belts</li>
          <li class="check-item reveal-child">Proper alignment and tensioning to prevent premature wear</li>
          <li class="check-item reveal-child">Compatible belts for all major exhaust fan brands and models</li>
        </ul>
      </div>

      <InlineCTA headline="Request Exhaust Fan Parts Now" />

      <div class="reveal mt-8">
        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Motorized Hood Fan Repair and Motor Replacement</h3>
        <p class="text-[#D4D4D4] mb-4 reveal-child">Your motor is the heart of your fan system. When it fails, your kitchen exhaust motor service becomes urgent. We handle everything from upblast fan motor replacement to complete motorized hood fan repair.</p>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">On-site diagnostics for motor failures or power issues</li>
          <li class="check-item reveal-child">Upblast fan motor replacement for direct drive and belt drive units</li>
          <li class="check-item reveal-child">Proper sizing and wiring to meet system demands</li>
          <li class="check-item reveal-child">Quiet, efficient motor performance with durable components</li>
        </ul>
      </div>

      <div class="reveal mt-8">
        <h3 class="font-heading font-semibold text-lg text-white mb-3 reveal-child">Emergency Fan Repair & System Restoration</h3>
        <p class="text-[#D4D4D4] mb-4 reveal-child">Downtime costs money. A failed fan system can shut down your kitchen during a lunch rush or dinner service. Every emergency repair we perform is NFPA 96 hood repair — fire code compliant hood repair that restores your system to full compliance.</p>
        <ul class="space-y-2 mb-6">
          <li class="check-item reveal-child">24/7 emergency repair for exhaust fans, belts, and motors</li>
          <li class="check-item reveal-child">Local parts stocked for faster service turnaround</li>
          <li class="check-item reveal-child">Same-day repairs available in most cases</li>
          <li class="check-item reveal-child">Temporary airflow solutions if part replacement requires follow-up</li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Split text/image section -->
  <section class="bg-[#1A1A1A] py-12 md:py-16 lg:py-20 px-5">
    <div class="max-w-[1200px] mx-auto reveal">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="section-headline reveal-child">Repair Cost, Timeline & Availability</h2>
          <ul class="space-y-2 mb-6">
            <li class="check-item reveal-child">Typical Repair Time: 1-2 hours</li>
            <li class="check-item reveal-child">Cost Range: $125-$450 depending on issue and parts</li>
            <li class="check-item reveal-child">Availability: Emergency or scheduled repairs across Middle Tennessee</li>
          </ul>
          <p class="text-[#D4D4D4] mb-6 reveal-child">We'll give you a clear diagnosis, upfront pricing, and a detailed written service report.</p>
          <button type="button" class="btn-primary popup-trigger reveal-child">Request Service Online</button>
        </div>
        <div class="reveal-child">
          <img
            src="/images/services/upblast-fan-motor.jpg"
            alt="upblast fan motor replacement and exhaust fan belt repair - DDAN Hood Cleaning and Repair"
            class="w-full rounded"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>
