  <style>
    details summary::-webkit-details-marker { display: none; }
    details summary { list-style: none; }
    details[open] .faq-icon { transform: rotate(180deg); }
    details[open] { border-color: #FF5E15; }
    .faq-icon { transition: transform 0.2s ease; }
  </style>
</BaseLayout>
