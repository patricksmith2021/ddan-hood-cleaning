---
import BaseLayout from '../../layouts/BaseLayout.astro';
import business from '../../data/business.json';

const faqs = [
  {
    q: 'How quickly can DDAN install an exhaust fan for a Sam Ridley Parkway restaurant?',
    a: 'Single exhaust fan replacements and upgrades along Sam Ridley Parkway are typically same-day or next-day. We carry the most common fan sizes and motors in our local inventory. Full system builds for new restaurants take 3-7 business days depending on duct run length and building complexity.',
  },
  {
    q: 'What does the Smyrna Fire Department look for during a kitchen exhaust inspection?',
    a: 'The Smyrna Fire Department inspectors prioritize functional fire suppression systems, clean ductwork to bare metal, properly installed hinge kits on upblast fans, fire-rated access panels at every duct direction change, and complete rooftop grease containment. We build every installation to pass these checkpoints on the first inspection.',
  },
  {
    q: 'Why do exhaust fan motors fail so often in Smyrna restaurants?',
    a: 'The Sam Ridley Parkway corridor sees massive lunch-rush volume from the Nissan plant workforce. Continuous high-heat operation — especially during July and August — pushes exhaust fan motors past their thermal limits. Standard-grade motors burn out in 12-18 months under these conditions. We install heat-rated motors designed for sustained heavy use.',
  },
  {
    q: 'Can you install exhaust systems in Smyrna industrial commissary kitchens?',
    a: 'Yes. Smyrna has several large-scale commissary and industrial food production facilities near the Nissan plant area. These operations require high-CFM exhaust systems with multiple fan installations, extended duct runs, and industrial-grade grease containment. We design and install systems scaled for production-level cooking volume.',
  },
  {
    q: 'Does Smyrna Utilities enforce grease regulations for restaurants?',
    a: 'Yes. Smyrna Utilities strictly enforces F.O.G. (Fats, Oils, and Grease) regulations using local ordinances to protect city infrastructure. Rooftop grease runoff that reaches storm drains triggers municipal fines. We install containment systems with every exhaust installation to keep your restaurant compliant from day one.',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${import.meta.env.SITE || 'https://ddanhoodservices.com'}/installation/smyrna-tn/`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": business.address.city,
        "addressRegion": business.address.state,
        "postalCode": business.address.zip,
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Smyrna, TN"
      },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "name": "Commercial Kitchen Exhaust System Installation",
      "provider": { "@type": "LocalBusiness", "name": business.name },
      "areaServed": { "@type": "City", "name": "Smyrna, TN" },
      "description": "Exhaust system installation and setup in Smyrna, TN. Heat-rated fans, industrial-grade ductwork, and complete grease containment for high-volume Nissan corridor restaurants. Free estimates."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${import.meta.env.SITE || 'https://ddanhoodservices.com'}/` },
        { "@type": "ListItem", "position": 2, "name": "Installation", "item": `${import.meta.env.SITE || 'https://ddanhoodservices.com'}/installation/` },
        { "@type": "ListItem", "position": 3, "name": "Smyrna, TN" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Restaurant Fan Installation Smyrna, TN | DDAN"
  description="Exhaust system installation in Smyrna, TN. Heat-rated fans and heavy-duty builds for Nissan corridor restaurants. Free on-site estimates. (615) 881-6968."
  ogImage="/images/services/kitchen-exhaust-installation.jpg"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section role="img" aria-label="Exhaust system installation and setup in Smyrna, TN — DDAN Hood Cleaning and Repair" class="min-h-[400px] md:min-h-[550px] flex items-center justify-center" style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.3) 100%), url('/images/homepage-hero/restaurant-hood-fan-repair-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968.jpg') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <p class="text-[#FF5E15] font-heading font-bold text-xs md:text-sm tracking-widest uppercase mb-4">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-white text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">Restaurant Fan <span class="text-[#FF5E15]">Installation</span> in Smyrna, TN</h1>
      <p class="text-gray-200 font-body text-lg md:text-xl max-w-2xl mx-auto mb-6">From single fan replacements to complete turnkey kitchen exhaust systems — permitted, installed, and inspected. Free on-site estimates.</p>
      <p class="text-white font-heading font-bold text-base md:text-lg mb-2">Licensed, Bonded & Insured &bull; NFPA 96 Compliant &bull; Since 2006</p>
      <div class="w-20 h-1 bg-[#FF5E15] mx-auto mt-3 mb-8"></div>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5E15] text-white font-heading font-bold text-lg rounded-lg transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
          Get a Free Estimate: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-[#FF5E15] text-[#FF5E15] font-heading font-bold text-lg rounded-lg hover:bg-[#FF5E15] hover:text-white transition-all duration-300">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          Request Installation Quote
        </button>
      </div>
      <div class="flex justify-center items-center gap-6 mt-8">
        <div class="flex flex-col items-center gap-1"><img src="/images/homepage/google-white-logo-1024x337.png" alt="Google" width="1024" height="337" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" /><div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div></div>
        <div class="flex flex-col items-center gap-1"><img src="/images/homepage/facebook-logo-white-full-transparent-1024x341.png" alt="Facebook" width="1024" height="341" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" /><div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div></div>
        <div class="flex flex-col items-center gap-1"><img src="/images/homepage/YELP_BIG.D-5a67c069-1024x392.png" alt="Yelp" width="1024" height="392" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" /><div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div></div>
      </div>
    </div>
  </section>

  <div class="bg-[#0A0A0A] py-2 px-5"><div class="max-w-[1200px] mx-auto"><nav class="flex items-center gap-2 text-sm font-heading text-gray-400" aria-label="Breadcrumb"><a href="/" class="hover:text-[#FF5E15] transition-colors">Home</a><span class="text-[#FF5E15]">/</span><a href="/installation/" class="hover:text-[#FF5E15] transition-colors">Installation</a><span class="text-[#FF5E15]">/</span><span class="text-gray-300">Smyrna, TN</span></nav></div></div>

  <section class="bg-[#111111] py-8 reveal"><div class="max-w-[1200px] mx-auto px-5"><div class="bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl px-8 py-5 flex flex-col md:flex-row items-center justify-between gap-4 reveal-child"><p class="text-white font-heading font-semibold text-lg text-center md:text-left">Planning a new kitchen or upgrading your exhaust system? We do free on-site surveys to spec exactly what you need.</p><div class="text-center whitespace-nowrap"><p class="text-[#FF5E15] font-heading font-bold text-sm">FREE ON-SITE SURVEY</p><p class="text-[#FF5E15] font-heading font-bold text-xs">No Obligation Estimate</p></div><div class="flex gap-3 items-center"><a href={`tel:${business.phoneRaw}`} class="text-white font-heading font-bold text-2xl hover:text-[#FF5E15] transition-colors whitespace-nowrap">{business.phone}</a><button type="button" class="popup-trigger bg-[#FF5E15] text-white font-heading font-bold text-sm px-4 py-2 rounded-lg hover:bg-[#E54F0D] transition-colors whitespace-nowrap">Free On-Site Survey</button></div></div></div></section>

  <section class="bg-[#111111] pb-12 reveal"><div class="max-w-[1200px] mx-auto px-5"><h2 class="font-heading text-[#FF5E15] font-bold text-2xl text-center mb-8 reveal-child">Complete Installation Services for Smyrna Kitchens</h2><div class="grid grid-cols-2 md:grid-cols-4 gap-3"><a href="#fans" class="bg-[#1A1A1A] border border-[#FF5E15]/40 hover:border-[#FF5E15] rounded-xl p-5 text-center hover:-translate-y-1 transition-all duration-300 reveal-child"><svg class="w-10 h-10 text-[#FF5E15] mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 3v9l6 3M12 12L6 9"/></svg><span class="text-white font-heading font-semibold text-sm block">Exhaust Fan Installation</span></a><a href="#systems" class="bg-[#1A1A1A] border border-[#FF5E15]/40 hover:border-[#FF5E15] rounded-xl p-5 text-center hover:-translate-y-1 transition-all duration-300 reveal-child"><svg class="w-10 h-10 text-[#FF5E15] mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg><span class="text-white font-heading font-semibold text-sm block">Complete System Installation</span></a><a href="#mua" class="bg-[#1A1A1A] border border-[#FF5E15]/40 hover:border-[#FF5E15] rounded-xl p-5 text-center hover:-translate-y-1 transition-all duration-300 reveal-child"><svg class="w-10 h-10 text-[#FF5E15] mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M7 12h10M12 8v8"/></svg><span class="text-white font-heading font-semibold text-sm block">Make-Up Air Installation</span></a><a href="#supporting" class="bg-[#1A1A1A] border border-[#FF5E15]/40 hover:border-[#FF5E15] rounded-xl p-5 text-center hover:-translate-y-1 transition-all duration-300 reveal-child"><svg class="w-10 h-10 text-[#FF5E15] mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg><span class="text-white font-heading font-semibold text-sm block">Supporting Installations</span></a></div></div></section>

  <!-- ==================== EXHAUST FAN INSTALLATION ==================== -->
  <section id="fans" class="bg-black py-16 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="text-[#FF5E15] font-heading font-bold text-2xl md:text-3xl mb-2 reveal-child">Restaurant Exhaust Fan Installation for Smyrna Kitchens</h2>
      <p class="text-[#D4D4D4] font-body mb-8 reveal-child">Whether you need a restaurant fan replacement for a burned-out unit or a commercial kitchen exhaust fan upgrade to a higher-CFM model, we handle sizing, wiring, mounting, and code compliance.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="bg-[#1A1A1A] border border-[#FF5E15]/40 rounded-xl p-6 reveal-child"><div class="aspect-video bg-[#0A0A0A] rounded-lg overflow-hidden mb-4"><img src="/images/products/upblast-direct-drive-fan.webp" alt="Direct drive upblast restaurant exhaust fan installation Smyrna" class="w-full h-full object-contain p-3" loading="lazy" /></div><h3 class="text-white font-heading font-semibold text-lg mb-2">New Fan Installation</h3><p class="text-[#D4D4D4] text-sm">Complete install on new or replacement rooftop upblast fans. Includes roof curb, hinge kit, wiring, and startup testing. Direct drive and belt drive configurations available.</p></div>
        <div class="bg-[#1A1A1A] border border-[#FF5E15]/40 rounded-xl p-6 reveal-child"><div class="aspect-video bg-[#0A0A0A] rounded-lg overflow-hidden mb-4"><img src="/images/products/upblast-belt-drive-fan.webp" alt="Belt drive restaurant exhaust fan replacement Smyrna" class="w-full h-full object-contain p-3" loading="lazy" /></div><h3 class="text-white font-heading font-semibold text-lg mb-2">Fan Replacement & Upgrade</h3><p class="text-[#D4D4D4] text-sm">Swap undersized or failed fans with properly rated units. We calculate CFM requirements based on your hood size and cooking volume to spec the right replacement.</p></div>
        <div class="bg-[#1A1A1A] border border-[#FF5E15]/40 rounded-xl p-6 reveal-child"><div class="aspect-video bg-[#0A0A0A] rounded-lg overflow-hidden mb-4"><img src="/images/products/hinge-kit.webp" alt="Exhaust fan hinge kit installation Smyrna" class="w-full h-full object-contain p-3" loading="lazy" /></div><h3 class="text-white font-heading font-semibold text-lg mb-2">Fan Accessories</h3><p class="text-[#D4D4D4] text-sm">Hinge kits, speed controllers, disconnect switches, motor covers, and grease cups installed with every fan. Every accessory is NFPA 96 compliant.</p></div>
      </div>
      <div class="bg-[#1A1A1A] border border-[#333] rounded-xl p-8 mb-8 reveal-child"><h3 class="text-white font-heading font-semibold text-lg mb-6">Our Fan Installation Process</h3><div class="grid grid-cols-1 md:grid-cols-3 gap-6"><div class="flex gap-4"><div class="w-10 h-10 bg-[#FF5E15] rounded-full flex items-center justify-center flex-shrink-0"><span class="text-white font-heading font-bold">1</span></div><div><h4 class="text-white font-heading font-semibold mb-1">Site Survey</h4><p class="text-[#D4D4D4] text-sm">We measure your hood, ductwork, and rooftop access. Calculate CFM requirements for your cooking volume.</p></div></div><div class="flex gap-4"><div class="w-10 h-10 bg-[#FF5E15] rounded-full flex items-center justify-center flex-shrink-0"><span class="text-white font-heading font-bold">2</span></div><div><h4 class="text-white font-heading font-semibold mb-1">Spec & Source</h4><p class="text-[#D4D4D4] text-sm">We spec the right fan for your system and source from our supplier network. Most common sizes in stock locally.</p></div></div><div class="flex gap-4"><div class="w-10 h-10 bg-[#FF5E15] rounded-full flex items-center justify-center flex-shrink-0"><span class="text-white font-heading font-bold">3</span></div><div><h4 class="text-white font-heading font-semibold mb-1">Install & Test</h4><p class="text-[#D4D4D4] text-sm">Licensed installation with hinge kit, wiring, and startup testing. Full written service documentation for your records.</p></div></div></div></div>
      <div class="bg-[#0A0A0A] border border-[#333] rounded-xl p-6 reveal-child">
        <p class="text-[#D4D4D4]">The Sam Ridley Parkway restaurant corridor feeds one of the largest industrial workforces in Tennessee — the Nissan Smyrna Vehicle Assembly Plant. This means lunch-rush fryers and grills running at peak capacity five days a week, with continuous heat that pushes standard exhaust fan motors past their thermal limits. We install heat-rated 3-phase motors and heavy-duty belt-drive configurations built to survive Smyrna's relentless daily volume. Emergency repair calls here spike in July and August when overworked motors hit their breaking point — our installations are designed to prevent that failure in the first place.</p>
        <p class="text-[#999] text-sm mt-3">Need to browse specific fan models and parts? See our <a href="/parts-installation/smyrna-tn/#exhaust-fans" class="text-[#FF5E15] hover:underline">exhaust fan parts catalog for Smyrna</a>.</p>
      </div>
    </div>
  </section>

  <!-- ==================== COMPLETE SYSTEM INSTALLATION ==================== -->
  <section id="systems" class="py-16 px-5 reveal" style="background: linear-gradient(to bottom, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.92) 100%), url('/images/homepage-hero/kitchen-exhaust-cleaning-services-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968.jpg') center/cover no-repeat fixed;">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="text-[#FF5E15] font-heading font-bold text-2xl md:text-3xl mb-2 reveal-child">Complete Hood System Installation in Smyrna</h2>
      <p class="text-[#D4D4D4] font-body text-lg mb-10 reveal-child">Turnkey commercial kitchen hood installation for new restaurants, renovations, and kitchen expansions. Hood, ductwork, restaurant fan, fire suppression — one contractor, one warranty.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
        <div class="reveal-child"><ul class="space-y-4">{['Type I or Type II exhaust hood canopy (custom-sized)','Grease ductwork with fire-rated access panels','Rooftop upblast exhaust fan with hinge kit','Electrical wiring and disconnect','Startup testing and airflow balancing'].map(item => (<li class="flex items-start gap-3 text-[#D4D4D4]"><svg class="w-5 h-5 text-[#FF5E15] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span>{item}</span></li>))}</ul></div>
        <div class="reveal-child"><ul class="space-y-4">{['UL 300 fire suppression system (coordinated)','Make-up air integration','Code-compliant grease containment','Permit coordination with Smyrna Fire Department','Full documentation package for inspectors'].map(item => (<li class="flex items-start gap-3 text-[#D4D4D4]"><svg class="w-5 h-5 text-[#FF5E15] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg><span>{item}</span></li>))}</ul></div>
      </div>
      <div class="grid grid-cols-3 gap-4 mb-10 reveal-child">
        <div class="bg-[#0A0A0A] rounded-xl overflow-hidden aspect-square">
          <img src="/images/products/complete-hood-system.webp" alt="Complete commercial kitchen hood system installation Smyrna" class="w-full h-full object-contain p-4" loading="lazy" />
        </div>
        <div class="bg-[#0A0A0A] rounded-xl overflow-hidden aspect-square">
          <img src="/images/products/fire-suppression-system.webp" alt="Restaurant fire suppression system installation Smyrna" class="w-full h-full object-contain p-4" loading="lazy" />
        </div>
        <div class="bg-[#0A0A0A] rounded-xl overflow-hidden aspect-square">
          <img src="/images/products/duct-access-door.webp" alt="Grease duct access door installation Smyrna" class="w-full h-full object-contain p-4" loading="lazy" />
        </div>
      </div>
      <div class="bg-[#1A1A1A]/80 backdrop-blur border border-[#FF5E15]/40 rounded-xl p-8 mb-8 reveal-child"><div class="grid grid-cols-1 md:grid-cols-3 gap-6"><div><h3 class="text-[#FF5E15] font-heading font-semibold text-lg mb-2">Typical Timeline</h3><p class="text-[#D4D4D4]">3-7 business days for complete system builds. Industrial commissary installations may take longer. Single fan installs are often same-day.</p></div><div><h3 class="text-[#FF5E15] font-heading font-semibold text-lg mb-2">What We Coordinate</h3><p class="text-[#D4D4D4]">We work with your general contractor, electrician, and fire suppression sub. One point of contact for the exhaust scope.</p></div><div><h3 class="text-[#FF5E15] font-heading font-semibold text-lg mb-2">Smyrna Permits</h3><p class="text-[#D4D4D4]">We handle all Smyrna permit applications and coordinate final NFPA 96 inspections with the Smyrna Fire Department directly.</p></div></div></div>
      <div class="bg-[#0A0A0A]/80 border border-[#333] rounded-xl p-6 reveal-child">
        <p class="text-[#D4D4D4]">The Smyrna Fire Department rigorously inspects high-traffic restaurant installations due to the density of industrial operations and high-volume dining along Sam Ridley Parkway. Inspectors prioritize functional fire suppression, clean ductwork, and proper fan installations. The heavy grease production from continuous Southern comfort food and chain restaurant fryers also threatens commercial roofs — TPO and EPDM membranes along the retail corridors need aggressive containment from the start. Every system we install in Smyrna includes complete rooftop grease containment engineered for industrial-level output.</p>
        <p class="text-[#999] text-sm mt-3">Browse individual system components in our <a href="/parts-installation/smyrna-tn/" class="text-[#FF5E15] hover:underline">parts catalog for Smyrna</a>.</p>
      </div>
    </div>
  </section>

  <!-- ==================== MAKE-UP AIR INSTALLATION ==================== -->
  <section id="mua" class="bg-[#111111] py-16 px-5 reveal">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="text-[#FF5E15] font-heading font-bold text-2xl md:text-3xl mb-2 reveal-child">Make-Up Air Unit Installation for Smyrna Kitchens</h2>
      <p class="text-[#D4D4D4] font-body mb-8 reveal-child">Your exhaust system can't function without balanced airflow. When MUA fails, doors slam, gas appliances backdraft, and fans lose efficiency.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
