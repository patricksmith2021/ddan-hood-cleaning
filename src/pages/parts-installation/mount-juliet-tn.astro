---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'My Mount Juliet landlord is demanding a rooftop grease containment system. Can you install one?',
    a: 'Yes. Providence Marketplace and North Mt. Juliet Road property managers are increasingly requiring rooftop grease containment as a lease condition. We install high-capacity grease boxes, containment pads, and drain-line systems that protect expensive white TPO roofing membranes. Every installation includes photo documentation for your landlord\'s property management records.',
  },
  {
    q: 'How fast can you get exhaust fan parts in Mount Juliet?',
    a: 'Because DDAN is headquartered in Mount Juliet, we stock the most common motors, belts, bearings, and fan wheels locally for same-day pickup or installation. For specialty or less common parts, we source through our commercial supply network within 24–48 hours. Mt. Juliet businesses get the fastest parts access in our entire service area.',
  },
  {
    q: "Are you familiar with the Fire Department of Mt. Juliet's equipment requirements?",
    a: "Absolutely — FDMJ is our local fire department. They enforce NFPA 96 rigorously on all new builds and existing inspections. We know exactly what their inspectors look for: proper hinge kits, functional fire suppression, and equipment that meets current commercial standards. Every part we install comes with documentation for your compliance file.",
  },
  {
    q: 'Do you offer priority parts service for local Mt. Juliet restaurants?',
    a: "Yes. As our home base, Mount Juliet businesses receive first-priority scheduling, same-day parts availability from our local stock, and zero travel fees. When a Providence Marketplace kitchen needs a motor replaced, our crew can often be on-site within 20 minutes with the exact part in hand.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
      "name": business.name,
      "image": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/images/hero/hero-1.jpg`,
      "telephone": business.phone,
      "email": business.email,
      "url": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev',
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": "Mt. Juliet",
        "addressRegion": "TN",
        "postalCode": "37122",
        "addressCountry": "US"
      },
      "areaServed": { "@type": "City", "name": "Mount Juliet, TN" }
    },
    {
      "@type": "Service",
      "name": "Commercial Kitchen Exhaust Fan Parts & Installation",
      "provider": { "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business` },
      "areaServed": { "@type": "City", "name": "Mount Juliet, TN" },
      "description": "Same-day exhaust fan parts and professional installation from DDAN's home base in Mount Juliet — motors, belts, bearings, filters, grease containment, and make-up air units."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/` },
        { "@type": "ListItem", "position": 2, "name": "Parts & Installation", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/parts-installation/` },
        { "@type": "ListItem", "position": 3, "name": "Mount Juliet, TN" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": { "@type": "Answer", "text": faq.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Same-Day Exhaust Parts in Mt. Juliet, TN | DDAN"
  description="Same-day exhaust fan parts and professional installation from DDAN's home base in Mt. Juliet. Motors, belts, filters, grease containment. Call (615) 881-6968."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/services/exhaust-fan-parts.webp');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/parts-installation/" class="hover:text-[#FF5E15] transition-all duration-300">Parts &amp; Installation</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Mount Juliet, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Same-Day Exhaust Fan Parts in <span class="text-[#FF5E15]">Mt. Juliet</span> — Our Home Base
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Local stock, zero travel fees, and the fastest parts service in Middle Tennessee — because this is home
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Free Consult: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Parts
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUE PROP BANNER -->
  <section class="bg-[#FF5E15] py-4 px-5">
    <div class="max-w-[1280px] mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 text-center text-white font-heading font-semibold text-sm md:text-base">
      <div class="flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 10 10-12h-9l1-10z"/></svg>
        Same-Day Parts
      </div>
      <div class="flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        All Major Brands
      </div>
      <div class="flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        24/7 Emergency
      </div>
      <div class="flex items-center justify-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
        Photo Documentation
      </div>
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="grid md:grid-cols-2 gap-10 items-start">
        <div>
          <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
            DDAN's Home Base — Mt. Juliet's Local Parts Supply
          </h2>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            Mount Juliet is where DDAN Hood Cleaning and Repair keeps its warehouse and parts inventory. That means when your exhaust fan motor burns out at a Providence Marketplace restaurant or a belt snaps in a North Mt. Juliet Road kitchen, we don't have to ship anything — we grab the part from our local stock and drive it to your door.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
            We stock motors, belts, bearings, fan wheels, baffle filters, and grease containment components for all major commercial kitchen exhaust brands. CaptiveAire, Loren Cook, Greenheck, Canarm, NAKS, Accurex, PennBarry, Dayton, Fantech — if it sits on a commercial roof or hangs over a kitchen line, we carry the parts for it.
          </p>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
            Being headquartered here also means Mt. Juliet restaurants get priority scheduling, zero travel fees, and response times that are often under 20 minutes. No other exhaust parts supplier can match that in this market.
          </p>
        </div>
        <div class="reveal-child">
          <img
            src={`${HP}/grease-hood-cleaning-near-me-nashville-tn-DDAN-Hood-Cleaning-and-Repair-615-881-6968-768x1024.jpg`}
            alt="Exhaust fan parts and installation in Mount Juliet TN - DDAN home base"
            class="w-full rounded-2xl border-[3px] border-[#FF5E15]"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- EXHAUST FANS — MAIN SECTION -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Exhaust Fan Parts — Mt. Juliet's Most Common Needs
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-6 reveal-child">
        The high-volume corporate kitchens in Providence Marketplace run their exhaust systems 16+ hours daily. That kind of continuous operation chews through factory-grade components. Here's what we replace most often in Mount Juliet:
      </p>
      <ul class="space-y-3 mb-6">
        <li class="check-item reveal-child"><strong>Motors</strong> — Single-phase and 3-phase upblast fan motors. We stock the most common sizes for same-day swap.</li>
        <li class="check-item reveal-child"><strong>Belts</strong> — Notched, heat-resistant V-belts that outlast factory belts in high-heat environments.</li>
        <li class="check-item reveal-child"><strong>Bearings</strong> — Sealed pillow-block bearings that resist grease infiltration and extend motor life.</li>
        <li class="check-item reveal-child"><strong>Fan Wheels & Impellers</strong> — Balanced replacements that restore proper airflow and eliminate vibration.</li>
        <li class="check-item reveal-child"><strong>Hinge Kits</strong> — NFPA 96 compliant hinge kits for safe rooftop fan access during cleaning and maintenance.</li>
        <li class="check-item reveal-child"><strong>Speed Controllers</strong> — Variable-speed fan controllers to match exhaust to cooking demand and reduce energy costs.</li>
      </ul>
    </div>
  </section>

  <!-- OTHER PARTS — MUA, FILTERS, GREASE CONTAINMENT -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Beyond Exhaust Fans — Complete Parts Inventory
      </h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-3">Make-Up Air Units</h3>
          <p class="text-[#D4D4D4] text-sm leading-relaxed">
            Replacement components for make-up air systems that balance your kitchen's air pressure. Filters, motors, dampers, and controls. Proper make-up air is critical for exhaust efficiency and employee comfort in Mt. Juliet's hot summers.
          </p>
        </div>
        <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-3">Hood Filters & Baffles</h3>
          <p class="text-[#D4D4D4] text-sm leading-relaxed">
            Stainless steel baffle filters, mesh grease filters, and charcoal odor-control filters. We match exact dimensions for your hood canopy. Providence Marketplace kitchens go through filters fast — we keep your sizes in stock.
          </p>
        </div>
        <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-3">Grease Containment</h3>
          <p class="text-[#D4D4D4] text-sm leading-relaxed">
            Rooftop grease boxes, containment pads, drain lines, and filter systems. Mt. Juliet landlords are ruthless about white TPO roof protection — our <a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">grease containment systems</a> keep you in compliance and off their radar.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- INSTALLATION UPSELL -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="border-l-4 border-[#FF5E15] bg-black p-6 rounded-r-xl reveal-child">
        <h2 class="font-heading text-[#FF5E15] text-xl font-semibold mb-3">Need More Than Parts?</h2>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4">
          If your exhaust system needs diagnosis, repair, or a full overhaul — not just a part swap — our repair team handles everything from motor replacements to complete system rebuilds. One contractor, one call.
        </p>
        <a href="/repair/mt-juliet-tn/" class="inline-flex items-center gap-2 text-[#FF5E15] font-heading font-semibold hover:text-white transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Hood Repair Services in Mt. Juliet
        </a>
      </div>
    </div>
  </section>

  <!-- COMMON EQUIPMENT ISSUES -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Equipment Issues in Mount Juliet
      </h2>
      <div class="space-y-6">
        <div class="reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-2">High-Volume Motor & Belt Wear</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
            High-volume corporate kitchens in Providence run exhaust systems 16+ hours daily, leading to burned-out fan motors and the need for frequent preventive <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">belt replacements</a>. These aren't emergencies when you stay on schedule — but they become emergencies fast when you don't. DDAN inspects belts, bearings, and motors during every service visit and flags components approaching failure before they shut you down.
          </p>
        </div>
        <div class="reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-2">Aggressive Landlord Rooftop Standards</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
            Providence and North Mt. Juliet Road landlords are ruthless regarding grease stains on their new TPO roofs. Proper rooftop grease containment isn't a suggestion — it's enforced in lease agreements with financial penalties that can run into thousands of dollars per incident. We install high-capacity containment systems and provide the photographic proof your landlord requires.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Who Buys Parts From DDAN in Mt. Juliet?
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-3">Restaurant Owners & Managers</h3>
          <p class="text-[#D4D4D4] text-sm leading-relaxed">
            Your exhaust fan is making noise, your belt snapped, or your motor died during service. You need the right commercial part fast, installed correctly, with documentation for your landlord and fire inspector. That's what we do — same day, from right here in town.
          </p>
        </div>
        <div class="bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
          <h3 class="font-heading text-white text-lg font-semibold mb-3">Other Hood Service Companies</h3>
          <p class="text-[#D4D4D4] text-sm leading-relaxed">
            We supply parts to other hood cleaning and repair companies across Middle Tennessee. Same-day availability, competitive pricing, and we can ship or arrange pickup from our Mt. Juliet location. No markup games — just the right part, fast.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA LINKS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Mount Juliet Service Area & Nearby Cities
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">
        Year-round high demand. Because Mount Juliet is our home base, we handle an immense volume of parts orders and installations locally. Schedule now before our calendar fills up.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Other Services in Mt. Juliet</p>
          <ul class="space-y-2">
            <li><a href="/cleaning/mount-juliet-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hood Cleaning — Mt. Juliet, TN</a></li>
            <li><a href="/repair/mt-juliet-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hood Repair — Mt. Juliet, TN</a></li>
          </ul>
        </div>
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Nearby Cities</p>
          <ul class="space-y-2">
            <li><a href="/parts-installation/lebanon-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Lebanon, TN</a></li>
            <li><a href="/parts-installation/hermitage-tn/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Hermitage, TN</a></li>
          </ul>
        </div>
        <div class="reveal-child">
          <p class="text-[#FF5E15] font-heading font-semibold mb-2">Service Hub</p>
          <ul class="space-y-2">
            <li><a href="/parts-installation/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">All Parts & Installation Areas</a></li>
            <li><a href="/restaurant-exhaust-fan-parts/" class="text-[#D4D4D4] hover:text-[#FF5E15] transition-all duration-300">Exhaust Fan Parts Overview</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Mt. Juliet Parts & Installation FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-black rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- TRUCK CTA -->
  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
