---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';

const HP = '/images/homepage';

const partsAreas = [
  { city: 'Nashville', state: 'TN', zips: '37201–37250', slug: 'nashville-tn' },
  { city: 'Murfreesboro', state: 'TN', zips: '37127–37130', slug: 'murfreesboro-tn' },
  { city: 'Antioch', state: 'TN', zips: '37013', slug: 'antioch-tn' },
  { city: 'Hendersonville', state: 'TN', zips: '37075, 37077', slug: 'hendersonville-tn' },
  { city: 'Spring Hill', state: 'TN', zips: '37174', slug: 'spring-hill-tn' },
  { city: 'Smyrna', state: 'TN', zips: '37167', slug: 'smyrna-tn' },
  { city: 'Gallatin', state: 'TN', zips: '37066', slug: 'gallatin-tn' },
  { city: 'Lebanon', state: 'TN', zips: '37087, 37090', slug: 'lebanon-tn' },
  { city: 'Goodlettsville', state: 'TN', zips: '37072', slug: 'goodlettsville-tn' },
  { city: 'Brentwood', state: 'TN', zips: '37027, 37024', slug: 'brentwood-tn' },
  { city: 'Mount Juliet', state: 'TN', zips: '37122, 37121', slug: 'mt-juliet-tn' },
  { city: 'Hermitage', state: 'TN', zips: '37076', slug: 'hermitage-tn' },
  { city: 'Madison', state: 'TN', zips: '37115', slug: 'madison-tn' },
  { city: 'La Vergne', state: 'TN', zips: '37086', slug: 'la-vergne-tn' },
  { city: 'Franklin', state: 'TN', zips: '37064, 37067', slug: 'franklin-tn' },
  { city: 'Clarksville', state: 'TN', zips: '37040–37044', slug: 'clarksville-tn' },
  { city: 'Columbia', state: 'TN', zips: '38401, 38402', slug: 'columbia-tn' },
  { city: 'Dickson', state: 'TN', zips: '37055', slug: 'dickson-tn' },
  { city: 'Cookeville', state: 'TN', zips: '38501, 38502', slug: 'cookeville-tn' },
  { city: 'Shelbyville', state: 'TN', zips: '37160', slug: 'shelbyville-tn' },
  { city: 'Tullahoma', state: 'TN', zips: '37388', slug: 'tullahoma-tn' },
  { city: 'McMinnville', state: 'TN', zips: '37110', slug: 'mcminnville-tn' },
  { city: 'Springfield', state: 'TN', zips: '37172', slug: 'springfield-tn' },
  { city: 'Bellevue', state: 'TN', zips: '37221', slug: 'bellevue-tn' },
  { city: 'Donelson', state: 'TN', zips: '37214', slug: 'donelson-tn' },
  { city: 'Green Hills', state: 'TN', zips: '37215', slug: 'green-hills-tn' },
  { city: 'White House', state: 'TN', zips: '37188', slug: 'white-house-tn' },
  { city: 'Bowling Green', state: 'KY', zips: '42101–42104', slug: 'bowling-green-ky' },
  { city: 'Fort Campbell', state: 'KY', zips: '42223', slug: 'fort-campbell-ky' },
];

const faqs = [
  {
    q: 'Do I have to buy the part from DDAN to get installation?',
    a: 'No — we\'ll install parts you\'ve sourced elsewhere. But when you purchase through us, installation is discounted and the part comes with our compatibility guarantee. We verify fit before ordering so you never get the wrong part.',
  },
  {
    q: 'How fast can you get parts?',
    a: 'We stock the most common exhaust fan motors, belts, bearings, filters, and fan wheels locally for same-day pickup or delivery. For specialty or less common parts, we source through our commercial supply network within 24–48 hours.',
  },
  {
    q: 'Do you work on CaptiveAire, Loren Cook, Greenheck, and other brands?',
    a: 'Yes. We supply and install parts for all major commercial kitchen exhaust brands including CaptiveAire, Loren Cook, Canarm, NAKS, EconAir, Greenheck, Accurex, PennBarry, Dayton, and Fantech. If your brand isn\'t listed, call us.',
  },
  {
    q: 'Can you install a complete new exhaust system from scratch?',
    a: 'Absolutely. We design and install turnkey commercial kitchen exhaust systems — hood canopy, ductwork, exhaust fan, make-up air unit, fire suppression, grease containment, and electrical. One contractor, one call, fully NFPA 96 compliant.',
  },
  {
    q: 'Do you sell parts to other hood cleaning companies?',
    a: 'Yes. We supply parts to other hood service companies across Middle Tennessee. Same-day availability, competitive pricing, and we can ship or arrange pickup from our Mt. Juliet location.',
  },
  {
    q: 'What warranty do you offer on parts and installation?',
    a: 'All parts carry their manufacturer\'s warranty. Our installation labor is backed by a workmanship guarantee. Every job is documented with before-and-after photos and a written service report for your records.',
  },
];
---

<BaseLayout
  title="Restaurant Exhaust Fan Parts & Installation | Same-Day | DDAN Nashville"
  description="Restaurant exhaust fan parts, make-up air units, hood filters, and grease containment. Same-day parts & discounted professional installation. Call (615) 881-6968."
>
  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/services/exhaust-fan-parts.webp');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Parts &amp; Installation</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Commercial Kitchen Exhaust Fan Parts &amp; Installation in <span class="text-[#FF5E15]">Middle Tennessee</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Same-Day Parts | Discounted Installation | Free Fitting Consult
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Free Consult: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUE PROPOSITION BANNER -->
  <section class="bg-[#111111] py-10 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: 'bolt', label: 'Same-Day / Next-Day Parts' },
          { icon: 'tools', label: 'Discounted Install With Purchase' },
          { icon: 'shield', label: 'Warranty on Parts & Labor' },
          { icon: 'phone', label: 'Free Fitting Consult' },
        ].map((item) => (
          <div class="bg-black border border-[#333] hover:border-[#FF5E15] rounded-xl p-4 text-center transition-all duration-300 reveal-child">
            <div class="w-10 h-10 flex items-center justify-center bg-[#FF5E15] rounded-full mx-auto mb-3">
              {item.icon === 'bolt' && <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 10 10-12h-9l1-10z"/></svg>}
              {item.icon === 'tools' && <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>}
              {item.icon === 'shield' && <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {item.icon === 'phone' && <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>}
            </div>
            <p class="text-white font-heading font-semibold text-sm">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXHAUST FANS — THE MAIN EVENT -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.8rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Exhaust Fans — The Heart of Your Kitchen
      </h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-12 reveal-child">
        Your exhaust fan moves every cubic foot of air through your kitchen ventilation system. When it fails, your kitchen shuts down. We stock, source, and install every type of commercial kitchen exhaust fan.
      </p>

      <!-- Upblast -->
      <div class="mb-12 reveal">
        <h3 class="font-heading font-bold text-white text-xl md:text-2xl mb-4 reveal-child">Upblast Centrifugal Exhaust Fans</h3>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">The most common exhaust fan in commercial kitchens. Mounted on your rooftop, it pulls grease-laden air up and out. Every restaurant needs one — and we carry the most common sizes for same-day replacement.</p>
        <ul class="space-y-2 mb-4">
          <li class="check-item reveal-child">Direct drive — sealed motor, less maintenance, more energy efficient</li>
          <li class="check-item reveal-child">Belt drive — quieter operation, cheaper upfront, adjustable speed via pulleys</li>
          <li class="check-item reveal-child">High-speed direct drive (CaptiveAire DU series and equivalents)</li>
          <li class="check-item reveal-child">Sizes from 400 CFM to 6,000+ CFM — matched to your kitchen's requirements</li>
        </ul>
      </div>

      <!-- Downblast -->
      <div class="mb-12 reveal">
        <h3 class="font-heading font-bold text-white text-xl md:text-2xl mb-4 reveal-child">Downblast Centrifugal Exhaust Fans</h3>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">For non-grease exhaust applications — dining rooms, dishwashing areas, restrooms. Direct and belt drive options available.</p>
        <ul class="space-y-2 mb-4">
          <li class="check-item reveal-child">Discharges air downward along the rooftop for quieter operation</li>
          <li class="check-item reveal-child">Direct and belt drive options for different performance needs</li>
        </ul>
      </div>

      <!-- Inline -->
      <div class="mb-12 reveal">
        <h3 class="font-heading font-bold text-white text-xl md:text-2xl mb-4 reveal-child">Inline Centrifugal Fans</h3>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">Mounted inside your ductwork for commercial and light industrial applications where rooftop mounting isn't practical.</p>
        <ul class="space-y-2 mb-4">
          <li class="check-item reveal-child">Ideal for interior installations and multi-floor exhaust runs</li>
          <li class="check-item reveal-child">Available in grease-rated and general ventilation configurations</li>
        </ul>
      </div>

      <!-- Axial + Propeller -->
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="reveal">
          <h3 class="font-heading font-bold text-white text-xl md:text-2xl mb-4 reveal-child">Axial / Tube Fans</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">High-volume air movement through duct systems. Common in industrial kitchens and large-scale food production facilities.</p>
        </div>
        <div class="reveal">
          <h3 class="font-heading font-bold text-white text-xl md:text-2xl mb-4 reveal-child">Propeller Wall &amp; Roof Fans</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 reveal-child">General ventilation for warehouses, loading docks, and storage areas adjacent to commercial kitchens.</p>
        </div>
      </div>

      <!-- Fan Replacement Parts -->
      <div class="mb-8 reveal">
        <h3 class="font-heading font-bold text-white text-xl md:text-2xl mb-6 reveal-child">Fan Replacement Parts</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {[
            'Motors (ODP, TEFC, single & 3-phase)',
            'Fan wheels & blade assemblies',
            'Belts & drive kits',
            'Bearings',
            'Roof curbs & adapters',
            'Hinge kits (NFPA 96 required)',
            'Speed controllers & VFDs',
            'Electrical disconnects & switches',
          ].map((part) => (
            <div class="flex items-start gap-2 bg-[#111111] border border-[#333] hover:border-[#FF5E15] rounded-xl p-4 transition-all duration-300 reveal-child">
              <svg class="w-4 h-4 text-[#FF5E15] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-[#D4D4D4] text-sm font-heading">{part}</span>
            </div>
          ))}
        </div>
      </div>

      <p class="text-[#999] text-sm reveal-child">Not sure what you need? <a href={`tel:${business.phoneRaw}`} class="text-[#FF5E15] hover:underline font-semibold">Call for a free fitting consult — {business.phone}</a></p>
    </div>
  </section>

  <!-- MAKE-UP AIR UNITS -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Make-Up Air Units
      </h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-4 reveal-child">
        Your exhaust system can't function without proper make-up air. If your front doors won't open, slam shut on their own, or you feel negative pressure in the kitchen — you likely need a MUA unit.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-6">
        {[
          { title: 'Gas-Fired Heated', desc: 'The standard for Tennessee. Tempers incoming air during winter months to maintain kitchen comfort and airflow balance.' },
          { title: 'Electric Heated', desc: 'Alternative heating option for locations without gas access. Higher operating cost but simpler installation.' },
          { title: 'Heated + Cooled', desc: 'Year-round comfort. Conditions incoming air in both winter and summer for demanding environments.' },
          { title: 'Perforated Supply Plenum', desc: 'Mounts directly to your hood. Delivers tempered air right at the cooking line for maximum efficiency.' },
        ].map((item) => (
          <div class="bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl p-5 transition-all duration-300 reveal-child">
            <h3 class="font-heading font-semibold text-white text-base mb-2">{item.title}</h3>
            <p class="text-[#D4D4D4] text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
      <p class="text-[#999] text-sm reveal-child">Call for free fitting consult to verify fit &amp; need — <a href={`tel:${business.phoneRaw}`} class="text-[#FF5E15] hover:underline font-semibold">{business.phone}</a></p>
    </div>
  </section>

  <!-- FILTERS & BAFFLES -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Filters &amp; Baffles
      </h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-6 reveal-child">
        Wrong filter = fire hazard + failed inspection. We match exact specifications for your hood system.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-6">
        {[
          { title: 'Stainless Steel Baffle Filters', desc: 'Industry standard. Type 304 or 430 stainless steel. Captures grease through multi-pass baffles. Dishwasher safe.' },
          { title: 'Mesh Grease Filters', desc: 'Budget option for lower-grease applications. Aluminum or galvanized steel mesh construction.' },
          { title: 'Charcoal / Carbon Filters', desc: 'Odor control for ventless hoods and recirculating systems. Removes smoke and cooking odors from exhaust air.' },
        ].map((item) => (
          <div class="bg-[#111111] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
            <h3 class="font-heading font-semibold text-white text-lg mb-2">{item.title}</h3>
            <p class="text-[#D4D4D4] text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
      <p class="text-[#999] text-sm reveal-child">Standard sizes in stock. Custom sizes sourced within 24–48 hours. <a href={`tel:${business.phoneRaw}`} class="text-[#FF5E15] hover:underline font-semibold">Call to verify your specs — {business.phone}</a></p>
    </div>
  </section>

  <!-- GREASE CONTAINMENT -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-2 reveal-child">
        Grease Containment
      </h2>
      <p class="text-[#DDDDDD] font-body text-base leading-relaxed mb-6 reveal-child">
        Unchecked rooftop grease means fire risk, roof damage, and environmental fines. We supply and install complete containment systems.
      </p>
      <ul class="space-y-3 mb-6">
        <li class="check-item reveal-child">Rooftop grease boxes and full containment systems — captures grease before it hits your roof</li>
        <li class="check-item reveal-child">Grease cups and drip pans — for individual fan units and overflow protection</li>
        <li class="check-item reveal-child">Grease pillows and absorbent pads — replaceable absorption media for ongoing maintenance</li>
        <li class="check-item reveal-child">Grease duct access doors — NFPA 96 required every 12 feet for proper cleaning access</li>
      </ul>
      <p class="text-[#999] text-sm reveal-child">Call for free fitting consult — <a href={`tel:${business.phoneRaw}`} class="text-[#FF5E15] hover:underline font-semibold">{business.phone}</a></p>
    </div>
  </section>

  <!-- FULL CUSTOM SYSTEM INSTALLATION -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="bg-[#111111] border-2 border-[#FF5E15] rounded-2xl p-8 md:p-12">
        <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-4 reveal-child">
          We Design &amp; Install Complete Commercial Kitchen Exhaust Systems
        </h2>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-6 reveal-child">
          Opening a new restaurant? Renovating an existing kitchen? Building out a food truck? We provide turnkey exhaust system installation — one contractor, one call, fully code-compliant.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
          {[
            'Hood canopy (wall-mount, island, custom)',
            'Grease ductwork (welded, sealed, pitched)',
            'Exhaust fan (sized for your kitchen)',
            'Make-up air unit (heated, cooled, or PSP)',
            'Fire suppression system (UL 300)',
            'Grease containment (rooftop)',
            'Access panels (NFPA 96 spacing)',
            'Electrical hookup and controls',
            'Final inspection and certification',
          ].map((item) => (
            <div class="flex items-start gap-2 reveal-child">
              <svg class="w-4 h-4 text-[#FF5E15] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <span class="text-[#D4D4D4] text-sm">{item}</span>
            </div>
          ))}
        </div>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-6 reveal-child">
          We work with restaurants, food trucks, ghost kitchens, schools, churches, hospitals, hotels, and general contractors building new commercial kitchens.
        </p>
        <button type="button" class="popup-trigger inline-flex items-center gap-2 px-7 py-3 bg-[#FF5E15] text-white font-heading text-lg font-medium rounded hover:bg-black transition-all duration-300 reveal-child">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Schedule Your Installation Consult
        </button>
      </div>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[900px] mx-auto">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl p-8 transition-all duration-300 reveal-child">
          <h3 class="font-heading font-bold text-[#FF5E15] text-xl mb-3">Restaurant Owners</h3>
          <p class="text-[#D4D4D4] font-body text-base leading-relaxed">
