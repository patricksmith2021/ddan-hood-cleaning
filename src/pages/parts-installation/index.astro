<BaseLayout
  title="Same-Day Restaurant Exhaust Fan Parts & Installation | DDAN Nashville"
  description={`Restaurant exhaust fan parts, make-up air units, hood filters, and grease containment. Same-day parts & discounted professional installation. Call ${business.phone}.`}
>

  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 1 — HERO
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/services/exhaust-fan-parts.webp');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>

    <div class="relative z-10 max-w-[1280px] mx-auto px-5 py-20 md:py-28 w-full">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm font-heading text-white/70 mb-6 tracking-widest uppercase reveal-child" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF5E15] transition-colors">Home</a>
        <span class="text-white/40">/</span>
        <span class="text-white">Parts &amp; Installation</span>
