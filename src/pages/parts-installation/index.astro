---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const partsAreas = [
  { city: 'Nashville', state: 'TN', zips: '37201–37250', slug: 'nashville-tn' },
  { city: 'Murfreesboro', state: 'TN', zips: '37127–37130', slug: 'murfreesboro-tn' },
  { city: 'Antioch', state: 'TN', zips: '37013', slug: 'antioch-tn' },
  { city: 'Hendersonville', state: 'TN', zips: '37075, 37077', slug: 'hendersonville-tn' },
  { city: 'Spring Hill', state: 'TN', zips: '37174', slug: 'spring-hill-tn' },
  { city: 'Smyrna', state: 'TN', zips: '37167', slug: 'smyrna-tn' },
  { city: 'Gallatin', state: 'TN', zips: '37066', slug: 'gallatin-tn' },
  { city: 'Lebanon', state: 'TN', zips: '37087, 37090', slug: 'lebanon-tn' },
  { city: 'Goodlettsville', state: 'TN', zips: '37072', slug: 'goodlettsville-tn' },
  { city: 'Brentwood', state: 'TN', zips: '37027, 37024', slug: 'brentwood-tn' },
  { city: 'Mount Juliet', state: 'TN', zips: '37122, 37121', slug: 'mount-juliet-tn' },
  { city: 'Hermitage', state: 'TN', zips: '37076', slug: 'hermitage-tn' },
  { city: 'Madison', state: 'TN', zips: '37115', slug: 'madison-tn' },
  { city: 'La Vergne', state: 'TN', zips: '37086', slug: 'la-vergne-tn' },
  { city: 'Franklin', state: 'TN', zips: '37064, 37067', slug: 'franklin-tn' },
  { city: 'Clarksville', state: 'TN', zips: '37040–37044', slug: 'clarksville-tn' },
  { city: 'Columbia', state: 'TN', zips: '38401, 38402', slug: 'columbia-tn' },
  { city: 'Dickson', state: 'TN', zips: '37055', slug: 'dickson-tn' },
  { city: 'Shelbyville', state: 'TN', zips: '37160', slug: 'shelbyville-tn' },
  { city: 'Springfield', state: 'TN', zips: '37172', slug: 'springfield-tn' },
  { city: 'Nolensville', state: 'TN', zips: '37135', slug: 'nolensville-tn' },
  { city: 'Portland', state: 'TN', zips: '37148', slug: 'portland-tn' },
  { city: 'White House', state: 'TN', zips: '37188', slug: 'white-house-tn' },
  { city: 'Lewisburg', state: 'TN', zips: '37091', slug: 'lewisburg-tn' },
  { city: 'Hartsville', state: 'TN', zips: '37074', slug: 'hartsville-tn' },
  { city: 'Fairview', state: 'TN', zips: '37062', slug: 'fairview-tn' },
  { city: "Thompson's Station", state: 'TN', zips: '37179', slug: 'thompsons-station-tn' },
];

const faqs = [
  {
    q: 'Do I have to buy the part from DDAN to get installation?',
    a: "No — we'll install parts you've sourced elsewhere. But when you purchase through us, installation is discounted and the part comes with our compatibility guarantee.",
  },
  {
    q: 'How fast can you get parts?',
    a: 'Common motors, belts, bearings, and filters are stocked locally for same-day pickup or delivery. Specialty parts sourced within 24–48 hours.',
  },
  {
    q: 'Can you install a complete new exhaust system from scratch?',
    a: 'Yes. Turnkey installation — hood, ductwork, fan, MUA, fire suppression, containment, electrical. One contractor, fully NFPA 96 compliant.',
  },
  {
    q: 'Do you sell parts to other hood cleaning companies?',
    a: 'Yes. Same-day availability, competitive pricing. Pickup from Mt. Juliet or delivery across Middle Tennessee.',
  },
  {
    q: 'What warranty do you offer?',
    a: 'All parts carry manufacturer warranty. Installation backed by our workmanship guarantee. Fully documented with a written service report.',
  },
  {
    q: "What if I don't know what part I need?",
    a: "Call us. Describe the symptom — noise, smell, failure — and we'll diagnose it, identify the exact part, verify fit for your specific unit, and handle everything from there.",
  },
];

const fans = [
  { name: 'Upblast Centrifugal — Direct Drive', desc: 'The #1 restaurant exhaust fan. Sealed motor, low maintenance, high efficiency. 400–6,000+ CFM. We stock common sizes for same-day replacement.', badge: 'MOST POPULAR' },
  { name: 'Upblast Centrifugal — Belt Drive', desc: 'Quieter operation, adjustable speed via pulley. Cost-effective for moderate-volume kitchens. All belt sizes in stock.' },
  { name: 'Downblast Centrifugal', desc: 'For non-grease exhaust — dining rooms, dishwashing areas, general ventilation. Direct and belt drive options.' },
  { name: 'Inline Centrifugal', desc: "Mounts inside ductwork. Ideal for commercial and light industrial applications where roof mounting isn't possible." },
  { name: 'Axial / Tube Fans', desc: 'High-volume air movement through duct systems. Tubeaxial and vaneaxial configurations.' },
  { name: 'Propeller Wall & Roof Fans', desc: 'General ventilation for warehouses, loading docks, equipment rooms. Low-profile rooftop options available.' },
];

const parts = [
  { name: 'Motors (ODP & TEFC)', desc: 'Direct & belt drive replacements' },
  { name: 'Fan Wheels & Blades', desc: 'Centrifugal & axial replacements' },
  { name: 'Belts & Drive Kits', desc: 'All sizes, matched sets' },
  { name: 'Bearings', desc: 'Pillow block & flange mount' },
  { name: 'Roof Curbs & Adapters', desc: 'Standard & custom sizes' },
  { name: 'Hinge Kits (NFPA 96)', desc: 'Code-compliant fan access' },
  { name: 'Speed Controllers & VFDs', desc: 'Variable speed operation' },
  { name: 'Grease Cups & Fittings', desc: 'Drain cups, nipples, elbows' },
  { name: 'Motor Covers & Guards', desc: 'Weather & debris protection' },
];

const muaUnits = [
  { name: 'Heated / Tempered MUA', desc: 'Required for Tennessee winters. Direct gas-fired or electric. Prevents dangerous negative pressure and freezing drafts.' },
  { name: 'Unheated MUA', desc: 'Budget-friendly fresh air supply. Best for mild weather or supplemental use.' },
  { name: 'Heated + Cooled MUA', desc: 'Year-round comfort. Evaporative cooling or DX coils plus heating. The premium choice.' },
  { name: 'Rooftop Packaged Units', desc: 'Combined exhaust/supply in one unit. Pre-wired, factory-mounted. CaptiveAire and compatible.' },
];

const filters = [
  { name: 'Stainless Steel Baffle', desc: 'Type 304/430 stainless. Longest lasting, easiest to clean. All standard sizes in stock.' },
  { name: 'Mesh Grease Filters', desc: 'Aluminum or galvanized. Budget option for low-grease applications.' },
  { name: 'Charcoal / Carbon', desc: 'Odor control for ventless hoods. Replace every 3–6 months.' },
];

const greaseItems = [
  'Rooftop Grease Boxes',
  'Grease Trays & Drip Pans',
  'Grease Pillows & Pads',
  'Duct Access Doors (NFPA 96)',
];

const brands = ['CaptiveAire', 'Loren Cook', 'Canarm', 'NAKS', 'EconAir', 'Greenheck', 'Accurex', 'PennBarry', 'Dayton', 'Fantech'];

const installChecks = [
  'Hood canopy (Type I & Type II)',
  'Ductwork — welded, code-compliant',
  'Exhaust fan — sized & mounted',
  'Make-up air unit — balanced airflow',
  'Fire suppression system — UL 300',
  'Grease containment — rooftop compliant',
  'Access panels — NFPA 96 required',
  'Electrical — wiring & controls',
  'Final inspection & documentation',
];

const siteUrl = import.meta.env.SITE || 'https://ddanhoodservices.com';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${siteUrl}/parts-installation/`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": business.address.city,
        "addressRegion": business.address.state,
        "postalCode": business.address.zip,
        "addressCountry": "US"
      },
      "areaServed": { "@type": "State", "name": "Tennessee" },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "serviceType": "Commercial Kitchen Exhaust Parts and Installation",
      "provider": { "@type": "LocalBusiness", "name": business.name },
      "areaServed": { "@type": "State", "name": "Tennessee" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Parts & Installation" }
      ]
    }
  ]
};
---

<BaseLayout
  title="Exhaust Fan Parts & Installation | DDAN"
  description={`Restaurant exhaust fan parts, hood filters, and grease containment. Same-day parts and professional installation. Call ${business.phone}.`}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- SECTION 1: HERO -->
  <section role="img" aria-label="Commercial kitchen exhaust parts and installation in Middle Tennessee — DDAN Hood Cleaning and Repair" class="min-h-[400px] md:min-h-[550px] flex items-center justify-center" style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.3) 100%), url('/images/services/kitchen-exhaust-parts-installation.webp') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <p class="text-[#FF5E15] font-heading font-bold text-xs md:text-sm tracking-widest uppercase mb-4">DDAN HOOD CLEANING AND REPAIR</p>
      <h1 class="font-display text-white text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">Kitchen Exhaust <span class="text-[#FF5E15]">Parts &amp; Installation</span> Across Middle Tennessee</h1>
      <p class="text-gray-200 font-body text-lg md:text-xl max-w-2xl mx-auto mb-6">Exhaust fans, make-up air units, filters, grease containment, and everything your commercial kitchen needs. In stock or next-day sourced.</p>
      <p class="text-white font-heading font-bold text-base md:text-lg mb-2">Rapid Warrantied Parts and Installation by a Licensed Professional</p>
      <div class="w-20 h-1 bg-[#FF5E15] mx-auto mt-3 mb-8"></div>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5E15] text-white font-heading font-bold text-lg rounded-lg transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
          Schedule Consultation: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-[#FF5E15] text-[#FF5E15] font-heading font-bold text-lg rounded-lg hover:bg-[#FF5E15] hover:text-white transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 320 512"><path d="M272 0H48C21.5 0 0 21.5 0 48v416c0 26.5 21.5 48 48 48h224c26.5 0 48-21.5 48-48V48c0-26.5-21.5-48-48-48zM160 480c-17.7 0-32-14.3-32-32s14.3-32 32-32 32 14.3 32 32-14.3 32-32 32zm112-108c0 6.6-5.4 12-12 12H60c-6.6 0-12-5.4-12-12V60c0-6.6 5.4-12 12-12h200c6.6 0 12 5.4 12 12v312z"/></svg>
          Request Service Online
        </button>
      </div>
      <div class="flex justify-center items-center gap-6 mt-8">
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/google-white-logo-1024x337.png" alt="Google" width="1024" height="337" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/facebook-logo-white-full-transparent-1024x341.png" alt="Facebook" width="1024" height="341" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/YELP_BIG.D-5a67c069-1024x392.png" alt="Yelp" width="1024" height="392" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BREADCRUMB STRIP -->
  <div class="bg-[#0A0A0A] py-2 px-5">
    <div class="max-w-[1200px] mx-auto">
      <nav class="flex items-center gap-2 text-sm font-heading text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF5E15] transition-colors">Home</a>
        <span class="text-[#FF5E15]">/</span>
        <span class="text-gray-300">Parts & Installation</span>
      </nav>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 2 — VALUE PROP CARDS
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">

        <!-- Rapid -->
        <div class="bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl p-5 text-center reveal-child">
          <div class="w-12 h-12 bg-[#FF5E15] rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <p class="text-white font-heading font-semibold mb-1">Rapid Parts</p>
          <p class="text-[#D4D4D4] text-sm">We stock common fans and parts locally</p>
        </div>

        <!-- Discounted Install -->
        <div class="bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl p-5 text-center reveal-child">
          <div class="w-12 h-12 bg-[#FF5E15] rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <p class="text-white font-heading font-semibold mb-1">Discounted Installation</p>
          <p class="text-[#D4D4D4] text-sm">Buy from us, save on labor</p>
        </div>

        <!-- Warranty -->
        <div class="bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl p-5 text-center reveal-child">
          <div class="w-12 h-12 bg-[#FF5E15] rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <p class="text-white font-heading font-semibold mb-1">Warranty on Parts &amp; Labor</p>
          <p class="text-[#D4D4D4] text-sm">Guaranteed right part, guaranteed work</p>
        </div>

        <!-- Free Consult -->
        <div class="bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl p-5 text-center reveal-child">
          <div class="w-12 h-12 bg-[#FF5E15] rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
          </div>
          <p class="text-white font-heading font-semibold mb-1">Free Fitting Consult</p>
          <p class="text-[#D4D4D4] text-sm">Call before you buy. We verify exact specs.</p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 3 — PRODUCT CATALOG
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">

      <h2 class="font-heading text-[#FF5E15] text-2xl md:text-3xl font-semibold mb-12 text-center reveal-child">
        Commercial Kitchen Exhaust Parts We Supply &amp; Install
      </h2>

      <!-- ── EXHAUST FANS ── -->
      <div class="mb-16">
        <h3 class="font-heading text-white text-xl md:text-2xl font-semibold mb-6 reveal-child">Exhaust Fans</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {fans.map((fan) => (
            <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
              {fan.badge && (
                <span class="inline-block bg-[#FF5E15] text-white text-xs font-heading font-bold px-3 py-1 rounded-full mb-3">{fan.badge}</span>
              )}
              <h4 class="font-heading font-semibold text-[#FF5E15] text-lg mb-2">{fan.name}</h4>
              <p class="text-[#D4D4D4] text-sm mb-4">{fan.desc}</p>
              <button type="button" class="popup-trigger inline-flex items-center gap-2 px-5 py-2 bg-[#FF5E15] text-white text-sm font-heading font-medium rounded hover:bg-black transition-all duration-300">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
                Call for Availability
              </button>
            </div>
          ))}
        </div>
      </div>

      <!-- ── FAN REPLACEMENT PARTS ── -->
      <div class="mb-16">
        <h3 class="font-heading text-white text-xl md:text-2xl font-semibold mb-6 reveal-child">Fan Replacement Parts</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          {parts.map((part) => (
            <div class="bg-[#111111] border border-[#333] hover:border-[#FF5E15] rounded-xl p-4 text-center transition-all duration-300 reveal-child">
              <p class="text-white font-heading font-semibold text-sm mb-1">{part.name}</p>
              <p class="text-[#999] text-xs mb-2">{part.desc}</p>
              <a href={`tel:${business.phoneRaw}`} class="text-[#FF5E15] text-xs font-heading font-medium hover:text-white transition-colors">Call for Part</a>
            </div>
          ))}
        </div>
      </div>

      <!-- ── MAKE-UP AIR UNITS ── -->
      <div class="mb-16">
        <h3 class="font-heading text-white text-xl md:text-2xl font-semibold mb-6 reveal-child">Make-Up Air Units</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {muaUnits.map((unit) => (
            <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
              <h4 class="font-heading font-semibold text-[#FF5E15] text-lg mb-2">{unit.name}</h4>
              <p class="text-[#D4D4D4] text-sm mb-4">{unit.desc}</p>
              <button type="button" class="popup-trigger inline-flex items-center gap-2 px-5 py-2 bg-[#FF5E15] text-white text-sm font-heading font-medium rounded hover:bg-black transition-all duration-300">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
                Call for Availability
              </button>
            </div>
          ))}
        </div>
      </div>

      <!-- ── FILTERS & BAFFLES ── -->
      <div class="mb-16">
        <h3 class="font-heading text-white text-xl md:text-2xl font-semibold mb-6 reveal-child">Filters &amp; Baffles</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {filters.map((filter) => (
            <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-2xl p-6 transition-all duration-300 reveal-child">
              <h4 class="font-heading font-semibold text-[#FF5E15] text-lg mb-2">{filter.name}</h4>
