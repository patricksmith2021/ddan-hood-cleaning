---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'Why do Goodlettsville I-65 restaurants need parts so frequently?',
    a: 'Goodlettsville sits at the I-65 interchange with one of Middle Tennessee\'s densest fast-food concentrations. Many restaurants operate 24/7 to serve interstate travelers, meaning exhaust fans never rest. A fan designed for 14-hour daily operation running 24 hours hits its rated lifespan in roughly half the expected time — belts stretch past adjustment, motors accumulate thermal fatigue, and bearings wear at double the normal rate.',
  },
  {
    q: 'Can you protect white TPO roofs during parts installation?',
    a: 'Yes. Many of Goodlettsville\'s newer commercial buildings around Rivergate and Dollar General HQ have pristine white TPO roof membranes. Corporate landlords issue massive fines for grease staining. During every parts installation, we take precautions to prevent grease contact with the membrane and install upgraded containment systems to prevent future runoff.',
  },
  {
    q: 'How quickly can DDAN deliver and install parts in Goodlettsville?',
    a: `Goodlettsville is one of our closest service areas from our Mt. Juliet base. We carry common motors, belts, bearings, hinge kits, and grease containment components on every truck. Most emergency parts installations in Goodlettsville are completed same-day. Call ${business.phone} any time — 24/7 dispatch.`,
  },
  {
    q: 'Do you service both Davidson and Sumner County restaurants?',
    a: 'Yes. Goodlettsville straddles both counties, and DDAN is familiar with both jurisdictions\' fire inspection requirements. We provide parts installation documentation that satisfies either county\'s fire marshal — no confusion, no gaps in compliance, regardless of which side of the county line your address falls on.',
  },
];

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev',
      "image": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/images/logo.png`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": "Mt. Juliet",
        "addressRegion": "TN",
        "postalCode": "37122",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Goodlettsville",
        "addressRegion": "TN"
      },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "serviceType": "Commercial Kitchen Exhaust Parts & Installation",
      "provider": { "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business` },
      "areaServed": {
        "@type": "City",
        "name": "Goodlettsville",
        "addressRegion": "TN"
      },
      "description": "Exhaust fan parts and installation for Goodlettsville's I-65 corridor restaurants. Heavy-duty motors and belts for 24/7 operations near Rivergate and Dollar General HQ."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev' },
        { "@type": "ListItem", "position": 2, "name": "Parts & Installation", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/parts-installation/` },
        { "@type": "ListItem", "position": 3, "name": "Goodlettsville, TN", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/parts-installation/goodlettsville-tn/` }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="Exhaust Fan Parts Goodlettsville, TN | DDAN"
  description="Heavy-duty exhaust fan parts for Goodlettsville's 24/7 I-65 corridor restaurants. Motors, belts, bearings, hinge kits. Same-day installation. (615) 881-6968."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/hero-2.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/parts-installation/" class="hover:text-[#FF5E15] transition-all duration-300">Parts & Installation</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Goodlettsville, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Exhaust Fan Parts & Installation in <span class="text-[#FF5E15]">Goodlettsville</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        I-65 corridor fans run 24/7 and burn through OEM parts twice as fast — heavy-duty replacements sourced and installed same-day
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUE PROP BANNER -->
  <section class="bg-[#111111] py-8 px-5 border-b border-[#333] reveal">
    <div class="max-w-[1280px] mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { icon: '⚡', label: 'Same-Day Parts' },
        { icon: '🔧', label: 'Expert Installation' },
        { icon: '📋', label: 'NFPA 96 Compliant' },
        { icon: '🕐', label: '24/7 Emergency' },
      ].map((item) => (
        <div class="flex flex-col items-center gap-2 reveal-child">
          <span class="text-2xl">{item.icon}</span>
          <span class="text-[#D4D4D4] font-heading text-sm font-semibold">{item.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Why Goodlettsville's I-65 Corridor Burns Through Exhaust Parts Faster Than Anywhere
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Goodlettsville sits at the I-65 interchange with one of Middle Tennessee's densest concentrations of fast-food and chain restaurants. Dollar General Corporate HQ anchors the commercial landscape, Rivergate Mall drives dozens of surrounding restaurant operations, and the interstate feeds a constant stream of travelers who need to eat fast and keep moving. Many of these restaurants operate 24/7, and their exhaust fans never get a rest cycle. A fan designed for 14-hour daily operation running continuously hits its rated lifespan in roughly half the expected time — every component wears at an accelerated rate.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Generic parts catalogs don't account for this. They sell you the same OEM belt that failed in three months and expect a different result. DDAN sources commercial-grade components specifically rated for continuous-duty applications — notched V-belts that resist the stretching caused by 24/7 operation, sealed high-heat bearings that survive without rest cycles, and motors with thermal protection rated for the actual duty demands of I-65 corridor kitchens. We deliver and install with full documentation that satisfies both Davidson and Sumner County fire marshals.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Corporate landlords around the Rivergate area add another parts dimension — white TPO roofs on newer buildings come with aggressive grease-stain fines. When containment components fail, grease escapes onto the membrane and the landlord sends a bill measured in thousands. DDAN installs upgraded grease containment systems that prevent this scenario, protecting both your compliance and your lease.
        </p>
      </div>
    </div>
  </section>

  <!-- EXHAUST FANS (MAIN SECTION) -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Exhaust Fan Parts — Built for Goodlettsville's Non-Stop Volume
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-8 max-w-4xl reveal-child">
        I-65 restaurants run harder and longer than standard operations. Every part we install is rated for the actual duty cycle:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        {[
          { title: 'Continuous-Duty Motors', desc: '24/7 operation burns through motor windings at double the normal rate. We install commercial-grade units with thermal overload protection rated for non-stop I-65 corridor demand.' },
          { title: 'Commercial V-Belts', desc: 'Non-stop operation shreds OEM belts within months. Commercial-grade notched V-belts with proper tensioning handle Goodlettsville\'s relentless duty cycles without stretching past adjustment.' },
          { title: 'Sealed High-Heat Bearings', desc: 'Continuous operation without rest cycles accelerates bearing fatigue exponentially. Sealed bearings rated for 24/7 commercial kitchen environments resist heat and grease infiltration.' },
          { title: 'Grease Containment Systems', desc: 'Multi-tier rooftop catchers that protect Rivergate\'s white TPO roofs from grease staining. Prevents the massive landlord fines that hit Goodlettsville operators.' },
          { title: 'Hinge Kits', desc: 'NFPA 96 requires service access via hinge kits on upblast fans. Many I-65 corridor installations were done without them — we retrofit to standard and non-standard curbs.' },
          { title: 'VFD & Speed Controllers', desc: 'Variable frequency drives optimize fan speed for energy efficiency. High-volume I-65 operations wear VFD components faster — we stock commercial-grade replacements.' },
        ].map((card) => (
          <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-xl p-6 transition-all duration-300 reveal-child">
            <h3 class="font-heading text-white text-lg font-semibold mb-2">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-sm leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OTHER PARTS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Beyond Fans — Complete Exhaust System Parts
      </h2>
      <ul class="space-y-3 max-w-3xl">
        <li class="check-item reveal-child"><a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Rooftop grease containment</a> — multi-tier systems to protect TPO roofs from landlord fines</li>
        <li class="check-item reveal-child">Fire-rated <a href="/access-panel-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">duct access panels</a> for inspection and cleaning access</li>
        <li class="check-item reveal-child">Baffle filters, mesh filters, and spark arrestor screens</li>
        <li class="check-item reveal-child"><a href="/restaurant-fire-suppression-systems/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Fire suppression</a> links, nozzles, and fusible elements</li>
        <li class="check-item reveal-child">Duct clamps, transitions, and cleanout ports</li>
        <li class="check-item reveal-child">Hood light fixtures and make-up air dampers</li>
        <li class="check-item reveal-child">Impellers and fan wheels — cleaned or replaced with balanced assemblies</li>
      </ul>
    </div>
  </section>

  <!-- INSTALLATION UPSELL -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="bg-[#111111] border-2 border-[#FF5E15] rounded-2xl p-8 md:p-12 reveal-child">
        <h2 class="font-heading text-white text-2xl md:text-3xl font-bold mb-3">Parts Without Installation Is Just a Box on Your Roof</h2>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-4 max-w-3xl">
          Incorrect installation voids warranties, fails inspections, and causes premature failure. Every DDAN parts order includes professional installation with full NFPA 96 documentation that satisfies both Davidson and Sumner County fire marshals. Need repair instead?
        </p>
        <a href="/repair/goodlettsville-tn/" class="inline-flex items-center gap-2 text-[#FF5E15] font-heading font-semibold hover:text-white transition-all duration-300">
          Goodlettsville Exhaust Repair Services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- COMMON EQUIPMENT ISSUES -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Equipment Issues in Goodlettsville Kitchens
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Factory-installed OEM belts are rated for standard restaurant schedules — 12 to 16 hours per day with overnight rest. When those belts run continuously without rest at Goodlettsville's 24/7 franchises, they reach failure in months instead of years. The belt stretches past its adjustment range, starts slipping on the pulleys, and either snaps outright or causes the motor to overheat trying to compensate. Motors burn through windings at double the normal rate under continuous duty. Standard bearings fail even faster — continuous rotation without cooling periods accelerates seal degradation and grease breakdown.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Corporate landlords around Rivergate issue massive fines for TPO roof grease stains. When exhaust fan bearings fail, the housing vibrates loose, and grease escapes containment onto the pristine white membrane below. Once grease stains TPO, it doesn't come off — the membrane is permanently discolored. DDAN installs upgraded multi-tier <a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">grease containment systems</a> that prevent this scenario entirely.
        </p>
      </div>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Who Needs Exhaust Parts in Goodlettsville?
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { title: 'I-65 Fast-Food Franchises', desc: '24/7 operations that destroy OEM components at double the normal rate. Heavy-duty commercial parts are the only solution that survives the duty cycle.' },
          { title: 'Rivergate Area Restaurants', desc: 'High-volume dining near the mall with corporate landlords who fine heavily for roof grease stains. Upgraded containment is mandatory.' },
          { title: 'Dollar General HQ Corridor', desc: 'Corporate dining facilities and surrounding restaurants serving massive daily lunch crowds need parts that handle concentrated peak-hour demand.' },
          { title: 'Hotel Kitchen Operations', desc: 'Goodlettsville\'s I-65 hotel clusters include breakfast-to-late-night kitchen operations that push equipment beyond standard duty ratings.' },
          { title: 'Multi-Location Operators', desc: 'Standardized commercial-grade parts across multiple Goodlettsville locations reduces emergency downtime and simplifies maintenance scheduling.' },
          { title: 'New Franchise Builds', desc: 'Builder-installed components are often the cheapest available. Upgrade to commercial-grade before the first belt snaps during your busiest shift.' },
        ].map((card) => (
          <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-xl p-6 transition-all duration-300 reveal-child">
            <h3 class="font-heading text-white text-lg font-semibold mb-2">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-sm leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Goodlettsville Parts & Installation Service Area
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN delivers and installs commercial kitchen exhaust parts across all of Goodlettsville — the I-65 interchange, Rivergate Mall area, Dollar General Corporate HQ corridor, and both Davidson and Sumner County sides of the city. We carry common parts on every truck for same-day emergency installation.
        </p>
        <div class="space-y-3 reveal-child">
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also serving nearby:</span>
            <a href="/parts-installation/madison-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Madison</a>,
            <a href="/repair/hendersonville-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hendersonville</a>, and
            <a href="/parts-installation/springfield-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Springfield</a>
          </p>
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">All DDAN services in Goodlettsville:</span>
            <a href="/cleaning/goodlettsville-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hood Cleaning</a> &middot;
            <a href="/repair/goodlettsville-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hood Repair</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Goodlettsville Exhaust Parts FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-black rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed" set:html={faq.a}></p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
