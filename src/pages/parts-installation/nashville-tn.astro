---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';


const faqs = [
  {
    q: 'What does the Metro Nashville Fire Marshal look for during a hood inspection?',
    a: 'Metro Nashville inspectors check for bare-metal cleanliness, proper hinge kits, fire-rated access panels, and current service documentation. Every part we install — from hinge kits to access panels to grease containment — is NFPA 96 compliant and documented with photos.',
  },
  {
    q: 'Can heavy grease void my commercial roof warranty in Nashville?',
    a: 'Yes. Many Nashville buildings use white TPO roofing that manufacturers will not cover if grease damage is present. Our rooftop grease containment systems — boxes, trays, and absorbent pads — prevent grease from reaching your membrane.',
  },
  {
    q: 'Do you install hinge kits on older Nashville buildings?',
    a: 'Absolutely. NFPA 96 requires hinge kits on all upblast fans. Historic Broadway buildings often have non-standard curbs — we carry adapters and heavy-duty kits that work on any mounting configuration.',
  },
  {
    q: 'How fast can you get parts to a Nashville restaurant?',
    a: 'We stock common motors, belts, bearings, filters, hinge kits, and grease cups locally. For in-stock parts, same-day delivery is standard. Specialty items are typically next-day via our distributor network.',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/parts-installation/nashville-tn/`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": business.address.city,
        "addressRegion": business.address.state,
        "postalCode": business.address.zip,
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Nashville, TN"
      },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "name": "Commercial Kitchen Exhaust Parts and Installation",
      "provider": { "@type": "LocalBusiness", "name": business.name },
      "areaServed": { "@type": "City", "name": "Nashville, TN" },
      "description": "Same-day exhaust fan parts and professional installation for Nashville commercial kitchens. Motors, belts, filters, hinge kits, grease containment, and make-up air units."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/` },
        { "@type": "ListItem", "position": 2, "name": "Parts & Installation", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/parts-installation/` },
        { "@type": "ListItem", "position": 3, "name": "Nashville, TN" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Same-Day Exhaust Fan Parts in Nashville, TN | DDAN"
  description="Exhaust fan parts for Nashville's 3,000+ commercial kitchens. Broadway to Vanderbilt. Same-day from local stock. Discounted installation. (615) 881-6968."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section class="min-h-[400px] md:min-h-[550px] flex items-center justify-center" style="background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 50%, rgba(0,0,0,0.3) 100%), url('/images/services/kitchen-exhaust-installation.jpg') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <p class="text-[#FF5E15] font-heading font-bold text-xs md:text-sm tracking-widest uppercase mb-4">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-white text-3xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4">Same-Day Exhaust Fan Parts and Installation in <span class="text-[#FF5E15]">Nashville, TN</span></h1>
      <p class="text-gray-200 font-body text-lg md:text-xl max-w-2xl mx-auto mb-6">Serving Nashville's 3,000+ commercial kitchens. Replacement parts in stock or next-day sourced.</p>
      <p class="text-white font-heading font-bold text-base md:text-lg mb-2">Same-Day / Next-Day Warrantied Parts and Installation by a Licensed Professional</p>
      <div class="w-20 h-1 bg-[#FF5E15] mx-auto mt-3 mb-8"></div>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#FF5E15] text-white font-heading font-bold text-lg rounded-lg hover:scale-95 transition-all duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
          Free Fitting Consult: {business.phone}
        </a>
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-[#FF5E15] text-[#FF5E15] font-heading font-bold text-lg rounded-lg hover:bg-[#FF5E15] hover:text-white hover:scale-95 transition-all duration-300">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 9v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          EMERGENCY FAN REPLACEMENT
        </a>
      </div>
      <div class="flex justify-center items-center gap-6 mt-8">
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/google-white-logo-1024x337.png" alt="Google" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/facebook-logo-white-full-transparent-1024x341.png" alt="Facebook" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
        <div class="flex flex-col items-center gap-1">
          <img src="/images/homepage/YELP_BIG.D-5a67c069-1024x392.png" alt="Yelp" class="h-5 md:h-7 object-contain opacity-90" loading="lazy" />
          <div class="flex gap-0.5">{Array(5).fill(0).map(() => <svg class="w-3 h-3 md:w-4 md:h-4 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- BREADCRUMB STRIP -->
  <div class="bg-[#0A0A0A] py-2 px-5">
    <div class="max-w-[1200px] mx-auto">
      <nav class="flex items-center gap-2 text-sm font-heading text-gray-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF5E15] transition-colors">Home</a>
        <span class="text-[#FF5E15]">/</span>
        <a href="/parts-installation/" class="hover:text-[#FF5E15] transition-colors">Parts & Installation</a>
        <span class="text-[#FF5E15]">/</span>
        <span class="text-gray-300">Nashville, TN</span>
      </nav>
    </div>
  </div>

  <!-- CATEGORY SUMMARY + CONSULT CARD -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 reveal">
    <div class="max-w-[1200px] mx-auto px-5">
      <div class="flex flex-col lg:flex-row gap-10">
        <div class="lg:w-[55%]">
          <h2 class="font-heading text-[#FF5E15] font-bold text-xl md:text-2xl mb-6 reveal-child">What We Supply, Deliver and Install</h2>
          <div class="space-y-3">
            {['Exhaust Fans and Replacement Parts', 'Complete Restaurant Hood Systems', 'Make-Up Air Units', 'Grease Filters, Baffles, and Mesh', 'Grease Containment Systems', 'Fire Suppression Components', 'Duct Access Doors and Accessories'].map(item => (
              <div class="flex items-center gap-3 reveal-child">
                <svg class="w-4 h-4 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
                <span class="text-white font-heading font-semibold text-base md:text-lg">{item}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="lg:w-[45%] reveal-child">
          <div class="bg-[#1A1A1A] border-2 border-[#FF5E15] rounded-xl p-6">
            <p class="text-white font-heading font-bold text-lg mb-2">Don't know exactly what you need?</p>
            <p class="text-gray-300 text-sm mb-3">Call now for a FREE immediate consult from a seasoned repair and installation pro.</p>
            <p class="text-[#FF5E15] font-heading font-bold text-sm mb-4">SAME DAY / NEXT DAY SERVICE on most parts</p>
            <a href={`tel:${business.phoneRaw}`} class="block text-white font-heading font-bold text-2xl mb-3 hover:text-[#FF5E15] transition-colors">{business.phone}</a>
            <a href={`tel:${business.phoneRaw}`} class="block w-full text-center px-6 py-3 bg-[#FF5E15] text-white font-heading font-semibold rounded hover:scale-95 transition-all duration-300 mb-4">Call Now — Free Consult</a>
            <div class="border-t border-[#333] pt-4 mt-2">
              <p class="text-white font-heading font-bold text-lg mb-1">Fan Down? Kitchen Closed?</p>
              <p class="text-[#FF5E15] font-heading font-bold text-sm">24/7 Emergency Line</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INSTALLATION UPSELL -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 reveal">
    <div class="max-w-[1280px] mx-auto px-5">
      <div class="flex flex-col lg:flex-row gap-10 items-center">
        <div class="lg:w-[60%] reveal-child">
          <h2 class="font-heading text-[#FF5E15] text-2xl md:text-4xl font-bold mb-5">Buy From Us &rarr; Get Discounted Professional Installation</h2>
          <p class="text-[#D4D4D4] text-lg mb-6">When you purchase parts through DDAN, installation labor is discounted. We know the parts because we spec them. No guesswork, no callbacks, no warranty finger-pointing.</p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3 text-[#D4D4D4]">
              <svg class="w-5 h-5 text-[#FF5E15] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
              <span>Parts and labor under one warranty</span>
            </li>
            <li class="flex items-start gap-3 text-[#D4D4D4]">
              <svg class="w-5 h-5 text-[#FF5E15] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
              <span>We verify fit before we order — no returns, no delays</span>
            </li>
            <li class="flex items-start gap-3 text-[#D4D4D4]">
              <svg class="w-5 h-5 text-[#FF5E15] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
              <span>Same technician specs, sources, and installs your part</span>
            </li>
            <li class="flex items-start gap-3 text-[#D4D4D4]">
              <svg class="w-5 h-5 text-[#FF5E15] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
              <span>Photo documentation for your compliance files</span>
            </li>
          </ul>
          <button type="button" class="popup-trigger inline-flex items-center gap-2 px-8 py-3.5 bg-[#FF5E15] text-white font-heading font-semibold rounded hover:bg-[#E54F0D] hover:scale-95 transition-all duration-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            Get a Parts & Install Quote
          </button>
        </div>
        <div class="lg:w-[40%] reveal-child">
          <img src="/images/hero/rooftop-exhaust-fan.jpg" alt="Professional exhaust fan installation" class="w-full h-72 object-cover rounded-2xl" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- EXHAUST FANS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 reveal">
    <div class="max-w-[1280px] mx-auto px-5">
      <h2 class="font-heading text-[#FF5E15] text-2xl md:text-4xl font-bold mb-3 reveal-child">Exhaust Fans</h2>
      <p class="text-[#D4D4D4] text-lg mb-10 reveal-child">The heart of your kitchen ventilation. We stock common sizes for same-day replacement.</p>
      <div class="bg-[#FF5E15] -mx-5 px-5 py-4 mb-8 text-center reveal-child">
        <p class="text-white font-heading font-bold text-lg md:text-xl uppercase tracking-widest">All Sizes — All Power Levels — Variable Speed and Standard</p>
        <p class="text-white/90 text-sm mt-1">From 400 CFM to 6,000+ CFM. If your restaurant uses it, we carry it.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Upblast Centrifugal — Direct Drive -->
        <a href={`tel:${business.phoneRaw}`} class="group block bg-[#1A1A1A] border border-[#333] hover:border-white rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 reveal-child">
          <div class="relative h-48 md:h-56 bg-[#0A0A0A] flex items-center justify-center">
            <img src="/images/services/commercial-hood-repair-split.jpeg" alt="Upblast Centrifugal Direct Drive Fan - DDAN Hood Cleaning Nashville" class="w-full h-full object-contain p-4 bg-white rounded-t-2xl" loading="lazy" />
            <div class="absolute inset-0 bg-black/70 opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col items-center justify-center">
              <svg class="w-8 h-8 text-[#FF5E15] mb-2" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
              <span class="text-white font-heading font-bold text-sm">Verify Fit & Specs</span>
              <span class="text-[#FF5E15] text-xs mt-1">{business.phone}</span>
            </div>
          </div>
          <div class="p-5">
            <h3 class="font-heading font-semibold text-[#FF5E15] text-base mb-1">Upblast Centrifugal — Direct Drive</h3>
            <p class="text-[#D4D4D4] text-sm">The number one restaurant exhaust fan. Sealed motor compartment protects from heat, grease, and moisture. Low maintenance, high efficiency. All sizes from 400 CFM to 6,000+ CFM. Variable speed and standard configurations. Same-day replacement from local stock.</p>
          </div>
        </a>
        <!-- Upblast Centrifugal — Belt Drive -->
        <a href={`tel:${business.phoneRaw}`} class="group block bg-[#1A1A1A] border border-[#333] hover:border-white rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 reveal-child">
          <div class="relative h-48 md:h-56 bg-[#0A0A0A] flex items-center justify-center">
            <img src="/images/services/hood-repair-hero.jpg" alt="Upblast Centrifugal Belt Drive Fan - DDAN Hood Cleaning Nashville" class="w-full h-full object-contain p-4 bg-white rounded-t-2xl" loading="lazy" />
            <div class="absolute inset-0 bg-black/70 opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col items-center justify-center">
              <svg class="w-8 h-8 text-[#FF5E15] mb-2" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
              <span class="text-white font-heading font-bold text-sm">Verify Fit & Specs</span>
              <span class="text-[#FF5E15] text-xs mt-1">{business.phone}</span>
            </div>
          </div>
          <div class="p-5">
            <h3 class="font-heading font-semibold text-[#FF5E15] text-base mb-1">Upblast Centrifugal — Belt Drive</h3>
            <p class="text-[#D4D4D4] text-sm">Quieter operation with adjustable speed via belt and pulley system. Cost-effective for moderate-volume kitchens. All belt sizes and motor configurations in stock. We carry every size and can match any existing unit.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- FAN REPLACEMENT PARTS -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 reveal">
    <div class="max-w-[1280px] mx-auto px-5">
      <h2 class="font-heading text-[#FF5E15] text-2xl md:text-4xl font-bold mb-3 reveal-child">Fan Replacement Parts — In Stock</h2>
      <p class="text-[#D4D4D4] text-lg mb-10 reveal-child">Common components stocked locally. Call to verify fit for your specific unit.</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        <!-- Motors -->
        <a href={`tel:${business.phoneRaw}`} class="group block bg-[#1A1A1A] border border-[#333] hover:border-white rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 reveal-child">
          <div class="relative h-40 md:h-48 bg-[#0A0A0A] flex items-center justify-center">
            <img src="/images/products/fan-motor-odp.webp" alt="Motors ODP and TEFC - DDAN Hood Cleaning Nashville" class="w-full h-full object-contain p-4 bg-white rounded-t-2xl" loading="lazy" />
            <div class="absolute inset-0 bg-black/70 opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col items-center justify-center">
              <svg class="w-7 h-7 text-[#FF5E15] mb-1" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
              <span class="text-white font-heading font-bold text-xs">Verify Fit</span>
              <span class="text-[#FF5E15] text-xs mt-0.5">{business.phone}</span>
            </div>
          </div>
          <div class="p-4">
            <h3 class="font-heading font-semibold text-[#FF5E15] text-sm mb-1">Motors (ODP & TEFC)</h3>
            <p class="text-[#D4D4D4] text-xs">Replacement motors for all fan types</p>
          </div>
        </a>
        <!-- Fan Wheels & Blades -->
        <a href={`tel:${business.phoneRaw}`} class="group block bg-[#1A1A1A] border border-[#333] hover:border-white rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 reveal-child">
          <div class="relative h-40 md:h-48 bg-[#0A0A0A] flex items-center justify-center">
            <img src="/images/products/fan-wheel-blades.webp" alt="Fan Wheels and Blades - DDAN Hood Cleaning Nashville" class="w-full h-full object-contain p-4 bg-white rounded-t-2xl" loading="lazy" />
            <div class="absolute inset-0 bg-black/70 opacity-0 group-hover:opacity-100 transition-all duration-300 flex flex-col items-center justify-center">
              <svg class="w-7 h-7 text-[#FF5E15] mb-1" fill="currentColor" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
              <span class="text-white font-heading font-bold text-xs">Verify Fit</span>
              <span class="text-[#FF5E15] text-xs mt-0.5">{business.phone}</span>
            </div>
          </div>
          <div class="p-4">
            <h3 class="font-heading font-semibold text-[#FF5E15] text-sm mb-1">Fan Wheels & Blades</h3>
            <p class="text-[#D4D4D4] text-xs">Impellers and blade assemblies</p>
          </div>
        </a>
