---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'Can you supply parts for massive institutional kitchen exhaust systems in Hartsville?',
    a: 'Yes. We specialize in high-capacity commercial and institutional kitchens. We stock the heavy-duty 3-phase motors, commercial-grade fan belts, and oversized bearings that institutional feeding operations demand. For specialized institutional components, we source directly from the manufacturer and typically deliver within 24 to 48 hours.',
  },
  {
    q: 'Do I need access panels installed in my Hartsville restaurant\'s ductwork?',
    a: `If you operate in an older building near the Hartsville square, likely yes. NFPA 96 code requires <a href="/access-panel-installation/" class="text-[#FF5E15] underline hover:text-white">fire-rated access panels</a> at every change of duct direction to ensure the entire system can be properly cleaned. We supply and install these panels to bring older Trousdale County establishments up to current fire code.`,
  },
  {
    q: 'How quickly can you replace a seized exhaust fan motor in Hartsville?',
    a: `We offer 24/7 emergency parts and installation service. If your exhaust fan goes down during a critical shift, our technicians dispatch immediately with common commercial-grade motors, belts, and bearings on every truck. Call ${business.phone} any time — day or night.`,
  },
  {
    q: 'Can you supply parts for institutional kitchen exhaust systems?',
    a: 'Absolutely. Institutional kitchens like correctional facilities, school cafeterias, and hospital kitchens run at extreme volume and require heavy-duty components that consumer-grade parts suppliers cannot provide. We source and install commercial 3-phase motors, industrial-rated fan belts, and high-capacity grease containment systems designed for continuous institutional duty cycles.',
  },
];

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev',
      "image": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/images/logo.png`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": "Mt. Juliet",
        "addressRegion": "TN",
        "postalCode": "37122",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Hartsville",
        "addressRegion": "TN"
      },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "serviceType": "Commercial Kitchen Exhaust Fan Parts & Installation",
      "provider": { "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business` },
      "areaServed": {
        "@type": "City",
        "name": "Hartsville",
        "addressRegion": "TN"
      },
      "description": "Institutional and commercial kitchen exhaust parts and installation for Hartsville and Trousdale County. Heavy-duty motors, fan belts, access panels, and grease containment systems."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev' },
        { "@type": "ListItem", "position": 2, "name": "Parts & Installation", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/parts-installation/` },
        { "@type": "ListItem", "position": 3, "name": "Hartsville, TN", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/parts-installation/hartsville-tn/` }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="Hartsville Commercial Kitchen Fan Parts | DDAN"
  description="Institutional and commercial kitchen exhaust parts and installation in Hartsville, TN. Heavy-duty motors, fan belts, access panels. Trousdale County 24/7 service. (615) 881-6968."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/rooftop-exhaust-fan.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/parts-installation/" class="hover:text-[#FF5E15] transition-all duration-300">Parts & Installation</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Hartsville, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Hartsville Institutional Kitchen Parts <span class="text-[#FF5E15]">& Installation</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Heavy-duty exhaust parts and professional installation for Trousdale County's institutional and commercial kitchens
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUE PROP BANNER -->
  <section class="bg-[#111111] border-b border-[#333] py-6 px-5 reveal">
    <div class="max-w-[1280px] mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      {[
        { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', label: '24/7 Parts & Service' },
        { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', label: 'NFPA 96 Compliant' },
        { icon: 'M5 13l4 4L19 7', label: 'Licensed & Insured' },
        { icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', label: 'OEM & Commercial Parts' },
      ].map((item) => (
        <div class="flex flex-col items-center gap-2 reveal-child">
          <svg class="w-7 h-7 text-[#FF5E15]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/></svg>
          <span class="text-white font-heading text-xs md:text-sm font-semibold">{item.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Exhaust System Parts for Hartsville's Toughest Kitchens
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Hartsville's commercial kitchen landscape is unique in Trousdale County. The town square is home to traditional Southern diners that have been feeding the community for decades, while massive institutional kitchens — including the Trousdale Turner Correctional Center — represent some of the highest-volume feeding operations in the region. Both ends of this spectrum put extraordinary demands on exhaust system components that standard parts suppliers simply cannot meet.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN Hood Cleaning and Repair supplies and installs the <a href="/restaurant-exhaust-fan-parts/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">commercial-grade exhaust parts</a> that Hartsville kitchens actually need. From heavy-duty 3-phase motors for institutional operations to fire-rated access panels for older downtown ductwork, we deliver the right components and handle the full installation. Every part we supply is rated for real cooking loads — not the minimum-spec components that fail under actual use.
        </p>
      </div>
    </div>
  </section>

  <!-- EXHAUST FAN PARTS -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Exhaust Fan Parts We Supply & Install
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-8 max-w-4xl reveal-child">
        Hartsville's institutional and commercial kitchens demand components built for punishing duty cycles:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        {[
          { title: 'Fan Motors', desc: 'Heavy-duty 3-phase motors rated for continuous institutional operation. Direct replacements for seized and overheated OEM units.' },
          { title: 'Fan Belts', desc: 'Commercial-grade notched V-belts that resist the extreme heat and grease from high-volume Southern cooking and institutional frying.' },
          { title: 'Bearings & Pillow Blocks', desc: 'Sealed commercial bearings for high-heat environments. Replace failed factory bearings before they destroy the entire motor assembly.' },
          { title: 'Impellers & Fan Wheels', desc: 'Balanced replacement impellers and fan wheels. Heavy institutional grease loads throw impellers off-balance rapidly.' },
          { title: 'Grease Containment', desc: 'Rooftop grease catchers and containment pads that satisfy Trousdale County wastewater regulations and protect your roof.' },
          { title: 'Hinge Kits', desc: 'NFPA 96-required hinge kits for rooftop upblast fans. Essential for safe cleaning access on institutional and commercial systems.' },
        ].map((card) => (
          <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-xl p-6 transition-all duration-300 reveal-child">
            <h3 class="font-heading text-white text-lg font-semibold mb-2">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-sm leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OTHER PARTS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Additional Parts & Components
      </h2>
      <ul class="space-y-3 max-w-3xl">
        <li class="check-item reveal-child"><a href="/access-panel-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Fire-rated duct access panels</a> — critical for Hartsville's older downtown buildings with concealed ductwork</li>
        <li class="check-item reveal-child"><a href="/restaurant-fire-suppression-systems/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Fire suppression</a> links, nozzles, and fusible alloy replacements</li>
        <li class="check-item reveal-child">Stainless steel baffle grease filters for hood canopies</li>
        <li class="check-item reveal-child">Duct connectors, transitions, and replacement sections</li>
        <li class="check-item reveal-child">Speed controllers and VFDs for institutional exhaust systems</li>
        <li class="check-item reveal-child">Rooftop grease pads and curb adapters</li>
      </ul>
    </div>
  </section>

  <!-- INSTALLATION UPSELL -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="bg-[#111111] border-2 border-[#FF5E15] rounded-2xl p-8 md:p-12 reveal-child">
        <h2 class="font-heading text-white text-2xl md:text-3xl font-bold mb-3">Parts + Installation in One Visit</h2>
        <p class="text-[#FF5E15] font-heading text-lg font-semibold mb-4">No second contractor. No coordination. Done right the first time.</p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-6 max-w-3xl">
          Every part we supply gets installed by our certified technicians on the same trip. Whether it is a 3-phase motor for a massive institutional kitchen or access panels for an older downtown diner, we arrive with the right components, install them to NFPA 96 standards, and document everything with photos for the Hartsville/Trousdale County Fire Department.
        </p>
        <a href={`tel:${business.phoneRaw}`} class="inline-block text-white font-display text-3xl md:text-5xl font-bold tracking-wide hover:text-[#FF5E15] transition-all duration-300">
          {business.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- COMMON EQUIPMENT ISSUES -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Equipment Issues in Hartsville
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          The intense daily volume required to feed massive institutional populations pushes exhaust fan motors past their intended limits, causing snapped belts and seized bearings. These are not standard restaurant loads — institutional kitchens run heavy-duty 3-phase motors at near-continuous duty cycles, and when those motors fail, the consequences cascade through the entire feeding operation. Meanwhile, older Southern diners on the Hartsville town square often have outdated, concealed ductwork that requires specialized <a href="/access-panel-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">access panel installation</a> before the system can even be properly cleaned or inspected.
        </p>
      </div>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Who We Supply Parts For in Hartsville
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl">
        {[
          'Institutional and correctional facility kitchens',
          'School and cafeteria operations',
          'Southern diners and meat-and-threes',
          'Historic downtown restaurants',
          'Highway restaurant and fast-food operations',
          'High-volume frying and cooking operations',
        ].map((item) => (
          <div class="check-item reveal-child">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Hartsville Parts & Installation Service Area
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN provides 24/7 commercial kitchen exhaust parts and installation across all of Hartsville and Trousdale County. Whether you need a 3-phase motor for an institutional kitchen, access panels for a downtown diner, or emergency fan parts on Highway 25, we deliver and install — day or night.
        </p>
        <div class="space-y-3 reveal-child">
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also in Hartsville:</span>
            <a href="/cleaning/hartsville-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hood Cleaning</a> &middot;
            <a href="/repair/hartsville-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hood Repair</a>
          </p>
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also serving nearby:</span>
            <a href="/parts-installation/lebanon-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Lebanon</a> and
            <a href="/parts-installation/gallatin-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Gallatin</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Hartsville Parts & Installation FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-black rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed" set:html={faq.a}></p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
