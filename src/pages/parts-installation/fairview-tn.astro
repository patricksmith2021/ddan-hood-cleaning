---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TruckCTA from '../../components/TruckCTA.astro';
import business from '../../data/business.json';
const HP = '/images/homepage';

const faqs = [
  {
    q: 'How fast can you get replacement fan parts to Fairview?',
    a: `We carry common commercial fan belts, motors, and bearings on every service truck. For emergency calls along Highway 100, we dispatch immediately with the parts needed for same-day installation. For less common components, we source directly from the manufacturer within 24 to 48 hours. Call ${business.phone} any time.`,
  },
  {
    q: 'Can you protect my Fairview restaurant\'s TPO roof with proper grease containment parts?',
    a: `Yes. Corporate landlords in Fairview's newer developments have zero tolerance for roof damage. We supply and install high-capacity, multi-tier rooftop <a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white">grease containment systems</a> designed specifically to capture grease while letting rainwater flow through, completely protecting your expensive roofing membrane from F.O.G. degradation.`,
  },
  {
    q: 'What does the Fairview Fire Department look for regarding exhaust system parts?',
    a: `The Fairview Fire Department utilizes full-time inspectors who expect strict <a href="/nfpa-code-96-standards/" class="text-[#FF5E15] underline hover:text-white">NFPA 96 compliance</a>. This means your exhaust system must have functional hinge kits, proper fire-rated access panels, clean fire suppression links, and components in good working order. We supply and install every part needed to pass inspection.`,
  },
  {
    q: 'How far do you deliver parts?',
    a: 'We deliver and install commercial kitchen exhaust parts across all of Middle Tennessee, including Fairview and the entire Highway 100 corridor. Our service area extends from Nashville through Williamson County and into Dickson County. There is no separate delivery fee — parts delivery is included with professional installation on every service call.',
  },
];

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business`,
      "name": business.name,
      "telephone": business.phone,
      "email": business.email,
      "url": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev',
      "image": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/images/logo.png`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": business.address.street,
        "addressLocality": "Mt. Juliet",
        "addressRegion": "TN",
        "postalCode": "37122",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Fairview",
        "addressRegion": "TN"
      },
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "serviceType": "Commercial Kitchen Exhaust Fan Parts & Installation",
      "provider": { "@id": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/#business` },
      "areaServed": {
        "@type": "City",
        "name": "Fairview",
        "addressRegion": "TN"
      },
      "description": "Hood parts and professional installation for Fairview commercial kitchens. Fan belts, motors, grease containment, and access panels for Highway 100 corridor restaurants."
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev' },
        { "@type": "ListItem", "position": 2, "name": "Parts & Installation", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/parts-installation/` },
        { "@type": "ListItem", "position": 3, "name": "Fairview, TN", "item": `${import.meta.env.SITE || 'https://ddan-hood-cleaning.pages.dev'}/parts-installation/fairview-tn/` }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="Hood Parts & Installation Fairview, TN | DDAN"
  description="Commercial kitchen hood parts and installation in Fairview, TN. Fan belts, motors, grease containment for Highway 100 restaurants. 24/7 service. (615) 881-6968."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaData)} />

  <!-- HERO -->
  <section class="relative min-h-[450px] md:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero/rooftop-exhaust-fan.jpg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(255,94,21,0.2) 0%, rgba(17,17,17,0.75) 70%);"></div>
    <div class="max-w-[1280px] mx-auto px-5 relative z-10 py-16 text-white w-full">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-xs font-heading uppercase tracking-widest text-white/80">
          <li><a href="/" class="hover:text-[#FF5E15] transition-all duration-300">Home</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li><a href="/parts-installation/" class="hover:text-[#FF5E15] transition-all duration-300">Parts & Installation</a></li>
          <li class="text-[#FF5E15]">/</li>
          <li class="text-white">Fairview, TN</li>
        </ol>
      </nav>
      <p class="font-heading text-[#FF5E15] font-bold uppercase text-sm md:text-base tracking-wide mb-2">DDAN Hood Cleaning and Repair</p>
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
        Hood Parts & Installation <span class="text-[#FF5E15]">in Fairview, Tennessee</span>
      </h1>
      <p class="font-heading text-sm md:text-base text-white/90 max-w-2xl mb-6">
        Commercial-grade replacement parts and professional installation for Fairview's growing Highway 100 restaurant corridor
      </p>
      <div class="flex flex-col sm:flex-row items-start gap-3 mb-8">
        <a href={`tel:${business.phoneRaw}`} class="inline-flex items-center gap-2.5 px-7 py-3 bg-[#032C5B] text-white font-body text-lg font-medium rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Call Us: {business.phone}
        </a>
        <button type="button" class="popup-trigger inline-flex items-center gap-2.5 px-7 py-3 bg-transparent text-white font-body text-lg font-medium border-2 border-[#FF5E15] rounded hover:bg-[#FF5E15] transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Request Service
        </button>
      </div>
      <!-- Review Badges -->
      <div class="flex flex-row items-center gap-3 md:gap-8">
        {[
          { img: `${HP}/google-white-logo-1024x337.png`, w: '70%' },
          { img: `${HP}/facebook-logo-white-full-transparent-1024x341.png`, w: '100%' },
          { img: `${HP}/YELP_BIG.D-5a67c069-1024x392.png`, w: '86%' },
        ].map((badge) => (
          <div class="flex flex-col items-center gap-0.5 md:gap-1.5 md:border-2 md:border-[#FF5E15] md:rounded-2xl md:px-5 md:py-2">
            <img src={badge.img} alt="" class="h-4 md:h-9 object-contain" style={`width:${badge.w};max-width:180px`} loading="lazy" />
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => <svg class="w-2.5 h-2.5 md:w-5 md:h-5 text-[#FF5E15] fill-current" viewBox="0 0 1000 1000"><path d="M450 75L338 312 88 350C46 354 25 417 58 450L238 633 196 896C188 942 238 975 275 954L500 837 725 954C767 975 813 942 804 896L763 633 942 450C975 417 954 358 913 350L663 312 550 75C529 33 471 33 450 75Z"/></svg>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUE PROP BANNER -->
  <section class="bg-[#111111] border-b border-[#333] py-6 px-5 reveal">
    <div class="max-w-[1280px] mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      {[
        { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', label: '24/7 Parts & Service' },
        { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', label: 'NFPA 96 Compliant' },
        { icon: 'M5 13l4 4L19 7', label: 'Licensed & Insured' },
        { icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', label: 'OEM & Commercial Parts' },
      ].map((item) => (
        <div class="flex flex-col items-center gap-2 reveal-child">
          <svg class="w-7 h-7 text-[#FF5E15]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/></svg>
          <span class="text-white font-heading text-xs md:text-sm font-semibold">{item.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- LOCAL INTRO -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Commercial Exhaust Parts for Fairview's Growing Restaurant Scene
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Fairview's dining sector is booming. Fueled by massive residential growth and heavy traffic along the Highway 100 corridor, fast-food franchises, family casual restaurants, and pizza shops are pushing their exhaust systems harder than ever. The continuously running fryers and ovens tear through standard OEM fan belts, overheat factory motors, and overwhelm cheap grease catchers that were never designed for this kind of volume. When a component fails, the kitchen stops — and in a highway-traffic restaurant, every hour of downtime is money lost.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN Hood Cleaning and Repair supplies and installs the commercial-grade <a href="/restaurant-exhaust-fan-parts/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">exhaust fan parts</a> that Fairview kitchens actually need. We carry heavy-duty fan belts, motors, bearings, and grease containment components on every service truck. No waiting for a parts order. No coordinating a second installer. One call gets the right parts delivered and professionally installed on the same visit.
        </p>
      </div>
    </div>
  </section>

  <!-- EXHAUST FAN PARTS -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Exhaust Fan Parts We Supply & Install
      </h2>
      <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-8 max-w-4xl reveal-child">
        Fairview's highway-volume kitchens need parts rated for continuous, high-heat operation:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        {[
          { title: 'Fan Motors', desc: 'Commercial-grade 1-phase and 3-phase motors sized for real cooking volume. Replace factory units that overheat under continuous use.' },
          { title: 'Fan Belts', desc: 'Heavy-duty notched V-belts that resist heat, grease, and stretching. Factory smooth belts snap fast in Fairview\'s high-volume kitchens.' },
          { title: 'Bearings & Pillow Blocks', desc: 'Sealed commercial bearings rated for high-heat environments. Prevent the premature seizures that plague OEM bearings.' },
          { title: 'Impellers & Fan Wheels', desc: 'Balanced replacement impellers. Grease-coated fan wheels create dangerous vibration and accelerate motor failure.' },
          { title: 'Grease Containment', desc: 'Multi-tier rooftop grease catchers designed for Fairview\'s newer TPO roofs. Protect your lease and satisfy landlord requirements.' },
          { title: 'Hinge Kits', desc: 'NFPA 96-compliant hinge kits for upblast exhaust fans. Required for safe rooftop cleaning access during maintenance.' },
        ].map((card) => (
          <div class="bg-[#1A1A1A] border border-[#333] hover:border-[#FF5E15] rounded-xl p-6 transition-all duration-300 reveal-child">
            <h3 class="font-heading text-white text-lg font-semibold mb-2">{card.title}</h3>
            <p class="text-[#D4D4D4] font-body text-sm leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OTHER PARTS -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Additional Parts & Components
      </h2>
      <ul class="space-y-3 max-w-3xl">
        <li class="check-item reveal-child"><a href="/access-panel-installation/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Fire-rated duct access panels</a> — required by NFPA 96 at every change of duct direction</li>
        <li class="check-item reveal-child"><a href="/restaurant-fire-suppression-systems/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Fire suppression</a> links, nozzles, and fusible alloy replacements</li>
        <li class="check-item reveal-child">Stainless steel baffle grease filters for hood canopies</li>
        <li class="check-item reveal-child">Duct connectors, transitions, and replacement sections</li>
        <li class="check-item reveal-child">Speed controllers and VFDs for exhaust fan systems</li>
        <li class="check-item reveal-child">Rooftop grease pads and curb adapters</li>
      </ul>
    </div>
  </section>

  <!-- INSTALLATION UPSELL -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <div class="bg-[#111111] border-2 border-[#FF5E15] rounded-2xl p-8 md:p-12 reveal-child">
        <h2 class="font-heading text-white text-2xl md:text-3xl font-bold mb-3">Parts + Installation in One Trip</h2>
        <p class="text-[#FF5E15] font-heading text-lg font-semibold mb-4">No second contractor. No waiting. Done right the first time.</p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed mb-6 max-w-3xl">
          Every part we supply gets installed by our certified technicians on the same visit. We arrive with the right components, install them to NFPA 96 standards, and document everything with photos for the Fairview Fire Department and your records. One call handles the entire job — parts, labor, and compliance documentation.
        </p>
        <a href={`tel:${business.phoneRaw}`} class="inline-block text-white font-display text-3xl md:text-5xl font-bold tracking-wide hover:text-[#FF5E15] transition-all duration-300">
          {business.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- COMMON EQUIPMENT ISSUES -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Common Equipment Issues in Fairview
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          The rapidly growing volume of highway travelers and new residents means Fairview's fast-food exhaust fans are running constantly. This continuous high-heat operation rapidly stretches standard OEM fan belts and overwhelms cheap factory grease catchers. During the hottest summer months, ambient rooftop temperatures compound the problem — overworked motors overheat and seize, shutting down exhaust airflow entirely.
        </p>
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          Landlords in Fairview's newer developments issue massive fines when leaking grease damages their white TPO roofs. A single failed grease catcher can cascade into a containment failure, a roof staining incident, and a lease violation. We supply and install the heavy-duty <a href="/exhaust-fan-belt-motor-repair/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">commercial-grade components</a> and <a href="/grease-containment/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">grease containment systems</a> that prevent these costly failures.
        </p>
      </div>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Who We Supply Parts For in Fairview
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl">
        {[
          'Fast-food and QSR franchises on Highway 100',
          'Family casual dining restaurants',
          'Pizza shops and high-heat oven operations',
          'Standalone restaurant outparcels',
          'Strip center food service tenants',
          'Growing suburban dining concepts',
        ].map((item) => (
          <div class="check-item reveal-child">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="bg-black py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-6 reveal-child">
        Fairview Parts & Installation Service Area
      </h2>
      <div class="max-w-4xl space-y-5">
        <p class="text-[#D4D4D4] font-body text-base leading-relaxed reveal-child">
          DDAN provides 24/7 commercial kitchen exhaust parts and installation across all of Fairview and the Highway 100 corridor. Whether you manage a high-speed corporate franchise, a local pizza shop, or a casual dining spot near Bowie Nature Park, we deliver and install the parts your kitchen needs — day or night.
        </p>
        <div class="space-y-3 reveal-child">
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also in Fairview:</span>
            <a href="/cleaning/fairview-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hood Cleaning</a> &middot;
            <a href="/repair/fairview-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Hood Repair</a>
          </p>
          <p class="text-[#D4D4D4] font-body text-base">
            <span class="text-[#FF5E15] font-semibold">Also serving nearby:</span>
            <a href="/parts-installation/dickson-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Dickson</a> and
            <a href="/parts-installation/nashville-tn/" class="text-[#FF5E15] underline hover:text-white transition-all duration-300">Nashville</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[#111111] py-12 md:py-16 lg:py-20 px-5 reveal">
    <div class="max-w-[1280px] mx-auto">
      <h2 class="font-heading text-[#FF5E15] text-lg md:text-[2.2rem] font-semibold leading-[1.2] mb-8 reveal-child">
        Fairview Parts & Installation FAQ
      </h2>
      <div class="max-w-3xl space-y-4">
        {faqs.map((faq) => (
          <details class="faq-item bg-black border border-[#333] hover:border-[#FF5E15] rounded-2xl transition-all duration-300 group reveal-child">
            <summary class="flex items-center justify-between gap-3 p-5 cursor-pointer">
              <span class="font-heading font-semibold text-[#FF5E15] text-base">{faq.q}</span>
              <svg class="faq-icon w-5 h-5 text-[#FF5E15] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 bg-black rounded-b-2xl">
              <p class="text-[#DDDDDD] font-heading text-base leading-relaxed" set:html={faq.a}></p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <TruckCTA />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] .faq-icon {
    transform: rotate(180deg);
  }
  details[open] {
    border-color: #FF5E15;
  }
  .faq-icon {
    transition: transform 0.2s ease;
  }
</style>
